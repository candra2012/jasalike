---
import DefaultLayout from './DefaultLayout.astro'

const { frontmatter } = Astro.props
const currentUrl = frontmatter.url || new URL(Astro.url.pathname, Astro.site).href
const heroImage = frontmatter.heroImage || frontmatter.image || '/default-og-image.jpg'
---

<DefaultLayout title={frontmatter.title} description={frontmatter.description} keywords={frontmatter.keywords} image="/og/page/blog.webp">
  <Fragment slot="head">
    <link rel="canonical" href={currentUrl} />
    <script type="application/ld+json" is:inline set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BlogPosting",
      "mainEntityOfPage": {
        "@type": "WebPage",
        "@id": currentUrl
      },
      "headline": frontmatter.title,
      "description": frontmatter.description,
      "image": heroImage,
      "datePublished": frontmatter.pubDate,
      "dateModified": frontmatter.updatedDate || frontmatter.pubDate,
      "author": {
        "@type": "Organization",
        "name": frontmatter.author || "Aura Digital Team",
        "url": "https://jasalike.com/tentang-kami/"
      },
      "publisher": {
        "@type": "Organization",
        "name": "Aura Digital",
        "logo": {
          "@type": "ImageObject",
          "url": "https://jasalike.com/logo.png"
        }
      }
    })} />
  </Fragment>

  <div class="container my-12">
    <div class="max-w-3xl mx-auto">
      <!-- Tombol Kembali -->
      <a href="/blog/" class="text-blue-600 mb-8 inline-block hover:underline">← Kembali ke Blog</a>
      
      <!-- Judul dan Meta -->
      <header class="mb-12">
        <h1 class="text-4xl md:text-5xl font-bold mb-4">{frontmatter.title}</h1>
        <p class="opacity-60 text-lg">{frontmatter.pubDate || 'Mei 2026'} · Oleh {frontmatter.author || 'Admin Jasalike'}</p>
        
        {frontmatter.heroImage && (
          <img 
            src={frontmatter.heroImage} 
            alt={frontmatter.title} 
            class="w-full h-auto rounded-3xl mt-8 shadow-lg"
          />
        )}
      </header>

      <!-- Isi Artikel dengan Style "Prose" -->
      <article class="prose prose-lg dark:prose-invert max-w-none prose-img:rounded-3xl prose-headings:text-primary-500">
        <slot />
      </article>
      
      <!-- Penutup/CTA -->
      <div class="mt-16 p-8 rounded-3xl bg-neutral-100 dark:bg-neutral-900 border border-neutral-200 dark:border-neutral-800 text-center">
        <h3 class="text-2xl font-bold mb-4">Butuh Dorongan Interaksi Awal?</h3>
        <p class="mb-6">Jadikan konten Anda lebih dipercaya dengan layanan profesional dari JasaLike.</p>
        <a href="/layanan/" class="button px-8 py-3">Lihat Layanan Kami</a>
      </div>
    </div>
  </div>
</DefaultLayout>
