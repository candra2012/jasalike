---
// src/layouts/DefaultLayout.astro
import '../styles/tailwind.css'
import '../assets/scss/index.scss'
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'
import FloatingCS from '../components/FloatingCS.astro'
import Aurabot from '../components/Aurabot.astro' 
import { ClientRouter } from 'astro:transitions'

// 1. Import komponen SEO khusus yang murni fokus Jasa Like
import SEO from '@components/SEO.astro'

// 👇 TAMBAHKAN 'keywords' DI DALAM SINI, CAN!
const {
  title = 'Jasa Like Terpercaya No. 1 | Tambah Likes Media Sosial Cepat & Aman', 
  description = 'Layanan jasa like terbaik untuk Instagram, TikTok, Facebook, dan Twitter. Proses cepat, aman tanpa password, murah, dan bergaransi penuh.', 
  keywords, // <--- Ini kunci utamanya agar tidak kosong!
  image = '/logo-auradigital.png', 
} = Astro.props
---

<html lang="id" dir="ltr">
  <head>
<!-- POTONG ANTREAN FONT UTAMA (PRELOAD) -->
<link rel="preload" href="/fonts/AtkinsonHyperlegibleNext-Regular.woff2" as="font" type="font/woff2" crossorigin="anonymous" />
<link rel="preload" href="/fonts/AtkinsonHyperlegibleNext-Bold.woff2" as="font" type="font/woff2" crossorigin="anonymous" />

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="X-UA-Compatible" content="ie=edge" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <SEO title={title} description={description} keywords={keywords} image={image} />

    <slot name="head" />

<script is:inline>
  // ==========================================
  // 1. SENSOR WHATSAPP (Selalu siaga 24 jam)
  // ==========================================
  window.addEventListener('click', (e) => {
    const anchor = e.target.closest('a');
    if (!anchor) return;

    const href = anchor.href;
    if (href.includes('wa.me') || href.includes('api.whatsapp.com')) {
      const savedRef = localStorage.getItem('affiliate_ref');
      if (!savedRef) return; 

      // Mencegah double tulisan referral kalau diklik berkali-kali
      if (href.includes('Kode Referral:')) return; 

      let newHref = href;
      if (href.includes('text=')) {
        // Jika sudah ada teks bawaan, tinggal tambahkan enter dan kode
        newHref = href + encodeURIComponent("\n\nKode Referral: " + savedRef);
      } else {
        // JIKA TEKS WA KOSONG: Kita buatkan kalimat sapaan default yang ramah
        const pesanDefault = "Halo Admin Auradigital, saya tertarik dan ingin pesan layanannya.\n\nKode Referral: " + savedRef;
        const separator = href.includes('?') ? '&' : '?';
        newHref = href + separator + 'text=' + encodeURIComponent(pesanDefault);
      }
      anchor.href = newHref;
    }
  });

  // ==========================================
  // 2. RADAR TELEGRAM & PENYIMPAN REFFERAL (Versi Tahan Banting Astro)
  // ==========================================
  // 'astro:page-load' membuat script ini akan selalu dipicu SETIAP KALI pengunjung pindah halaman, tanpa perlu refresh!
  document.addEventListener('astro:page-load', () => {
    
    // Simpan kode ref ke memori jika ada
    const params = new URLSearchParams(window.location.search);
    const refUrl = params.get('ref');
    if (refUrl) {
      localStorage.setItem('affiliate_ref', refUrl);
    }

    const activeRef = refUrl || localStorage.getItem('affiliate_ref');

    // Pengaturan Webhook Radar Telegram
    const webhookUrl = "https://script.google.com/macros/s/AKfycbwVf5QV5ch8s5OHzfYqoEKYgmPdiVd-NAGUoQ2IBYb6_OeZdGCD9YOlcQso1ToiI5Ys/exec"; 
    if(webhookUrl.includes("KODE_PANJANG")) return;

    // Format url untuk pesan di Telegram
    let urlLengkap = window.location.pathname + window.location.search;
    if (activeRef) {
      urlLengkap += " (Ref: " + activeRef + ")";
    } else {
      urlLengkap += " (Organik)";
    }

    const dataPengunjung = {
      halaman: urlLengkap,
      waktu: new Date().toLocaleString('id-ID', { timeZone: 'Asia/Jakarta' })
    };
    
    fetch(webhookUrl, {
      method: "POST",
      headers: { "Content-Type": "text/plain;charset=utf-8" },
      body: JSON.stringify(dataPengunjung)
    }).catch(error => console.log("Radar gagal:", error));
    
  });
</script>


    <ClientRouter />
  </head>
  <body>
    <Header />
    <main id="main-content" transition:animate="fade">
      <slot />
    </main>
    <Footer />
    <FloatingCS />
    <Aurabot />

    <style lang="scss" is:global>
      html, body { height: 100%; }
      body { display: flex; flex-direction: column; overflow-x: clip; }
      main { flex: 1 0 auto; }
      footer { flex-shrink: 0; }
      pre { border: 2px solid var(--link-color); border-radius: .35rem; padding: 1rem; }
    </style>

    <script>
      document.addEventListener('astro:page-load', () => {
        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
            }
          });
        }, {
          threshold: 0.1 // Memicu animasi ketika 10% elemen sudah terlihat di layar
        });

        // Minta script untuk mengawasi semua elemen yang punya class reveal di seluruh website
        document.querySelectorAll('.reveal-up, .reveal-left, .reveal-right').forEach((el) => {
          observer.observe(el);
        });
      });
    </script>

    </body>
</html>
