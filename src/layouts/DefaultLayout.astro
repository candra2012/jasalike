---
// src/layouts/DefaultLayout.astro
import '../styles/tailwind.css'
import '../assets/scss/index.scss'
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'
import FloatingCS from '../components/FloatingCS.astro'
import ReferralTracker from '../components/ReferralTracker.astro'
import Aurabot from '../components/Aurabot.astro' 
import { ClientRouter } from 'astro:transitions'

// 1. Import komponen SEO khusus yang murni fokus Jasa Like
import SEO from '@components/SEO.astro'

// 👇 TAMBAHKAN 'keywords' DI DALAM SINI, CAN!
const {
  title = 'Jasa Like Terpercaya No. 1 | Tambah Likes Media Sosial Cepat & Aman', 
  description = 'Layanan jasa like terbaik untuk Instagram, TikTok, Facebook, dan Twitter. Proses cepat, aman tanpa password, murah, dan bergaransi penuh.', 
  keywords, // <--- Ini kunci utamanya agar tidak kosong!
  image = '/logo-auradigital.png', 
} = Astro.props
---

<html lang="id" dir="ltr">
  <head>
<!-- POTONG ANTREAN FONT UTAMA (PRELOAD) -->
<link rel="preload" href="/fonts/AtkinsonHyperlegibleNext-Regular.woff2" as="font" type="font/woff2" crossorigin="anonymous" />
<link rel="preload" href="/fonts/AtkinsonHyperlegibleNext-Bold.woff2" as="font" type="font/woff2" crossorigin="anonymous" />

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="X-UA-Compatible" content="ie=edge" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <SEO title={title} description={description} keywords={keywords} image={image} />

    <slot name="head" />

<script is:inline>
  // Radar akan langsung berjalan saat halaman dimuat
  (function() {
    const webhookUrl = "https://script.google.com/macros/s/AKfycbwVf5QV5ch8s5OHzfYqoEKYgmPdiVd-NAGUoQ2IBYb6_OeZdGCD9YOlcQso1ToiI5Ys/exec"; 
    
    if(webhookUrl.includes("KODE_PANJANG_DARI_GOOGLE_TADI")) return;

    // 1. Ambil kode referral dari URL (jika ada) atau dari memori (jika sudah pindah halaman)
    const params = new URLSearchParams(window.location.search);
    const refUrl = params.get('ref');
    const refStorage = localStorage.getItem('affiliate_ref');
    
    // Tentukan kode referral yang aktif (prioritas dari URL, lalu memori)
    const activeRef = refUrl || refStorage;
    
    // 2. Format tampilan halaman untuk Telegram
    // Menggabungkan nama halaman (misal: /) dengan parameter (misal: ?ref=123)
    let urlLengkap = window.location.pathname + window.location.search;
    
    // Tambahkan keterangan label Referral agar di Telegram terlihat sangat jelas
    if (activeRef) {
      urlLengkap = urlLengkap + " (Ref: " + activeRef + ")";
    } else {
      urlLengkap = urlLengkap + " (Organik)";
    }

    const dataPengunjung = {
      halaman: urlLengkap,
      waktu: new Date().toLocaleString('id-ID', { timeZone: 'Asia/Jakarta' })
    };
    
    fetch(webhookUrl, {
      method: "POST",
      headers: { "Content-Type": "text/plain;charset=utf-8" },
      body: JSON.stringify(dataPengunjung)
    }).then(response => {
      console.log("Radar traffic terkirim sukses!");
    }).catch(error => {
      console.log("Radar gagal:", error);
    });
  })();
</script>

    <ClientRouter />
  </head>
  <body>
    <Header />
    <main id="main-content" transition:animate="fade">
      <slot />
    </main>
    <Footer />
    <ReferralTracker />
    <FloatingCS />
    <Aurabot />

    <style lang="scss" is:global>
      html, body { height: 100%; }
      body { display: flex; flex-direction: column; overflow-x: clip; }
      main { flex: 1 0 auto; }
      footer { flex-shrink: 0; }
      pre { border: 2px solid var(--link-color); border-radius: .35rem; padding: 1rem; }
    </style>

    <script>
      document.addEventListener('astro:page-load', () => {
        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
            }
          });
        }, {
          threshold: 0.1 // Memicu animasi ketika 10% elemen sudah terlihat di layar
        });

        // Minta script untuk mengawasi semua elemen yang punya class reveal di seluruh website
        document.querySelectorAll('.reveal-up, .reveal-left, .reveal-right').forEach((el) => {
          observer.observe(el);
        });
      });
    </script>

    </body>
</html>
