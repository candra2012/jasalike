---
// src/pages/kontak-admin-1.astro
import DefaultLayout from '../layouts/DefaultLayout.astro'
import Hero from '../components/Hero.astro'

const title = "Hubungi Admin | JasaLike";
const description = "Halaman kontak resmi JasaLike untuk konsultasi layanan dan bantuan operasional.";
const keywords = "kontak admin jasalike, bantuan layanan jasalike, admin auradigital, chat admin jasalike";

const dataHero = {
  tipe: "service",
  labelTeks: "Pusat Bantuan & Konsultasi",
  labelIcon: "lucide:headset",
  judulUtama: 'Konsultasikan <span class="text-pink-600">Strategi Interaksi</span> Bersama Admin Kami',
  deskripsi: "Tim ahli JasaLike siap membantu merencanakan solusi optimasi terbaik untuk akun media sosial Anda. Hubungi kami langsung melalui WhatsApp untuk respons cepat dan rekomendasi personal.<br class='hidden md:block mt-2' /> <span class='text-pink-500 font-semibold block mt-4'>✓ Respons Cepat &nbsp; ✓ Konsultasi Personal &nbsp; ✓ Privasi Terjamin</span>",
  teksTombol1: "Chat Admin JasaLike",
  // UBAH TEKS BAWAAN WA DI SINI SESUAI GRUP
  linkTombol1: "https://wa.me/6289634740308?text=Halo%20admin%20saya%20mau%20order%20like",
  teksTombol2: "Lihat Semua Layanan",
  linkTombol2: "/",
  gambarHero: "/image/hero-beranda.png" 
};
---

<DefaultLayout title={title} description={description} keywords={keywords} image="/og/page/contact.webp">
  <Fragment slot="head">
    <meta name="robots" content="noindex, nofollow" />
  </Fragment>

  <Hero {...dataHero} />
</DefaultLayout>
