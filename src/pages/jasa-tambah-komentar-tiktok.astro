      "bestRating": "5",
      "worstRating": "1",
      "reviewCount": 1837
    },
    "offers": {
      "@type": "AggregateOffer",
      "lowPrice": "20000",
      "highPrice": "2000000",
      "priceCurrency": "IDR",
      "offerCount": "4"
    },
    "image": "https://jasalike.com/image/hero-jasalike-Tiktok.png",
    "brand": {
      "@type": "Brand",
      "name": "JasaLike"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Beranda",
        "item": "https://jasalike.com/"
