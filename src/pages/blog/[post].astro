---
import DefaultLayout from '@layouts/DefaultLayout.astro'
import PageHeader from '@components/PageHeader.astro'
import SocialShares from '@components/SocialShares.astro'

// 1. Mengambil data dari file lokal (.md)
export async function getStaticPaths() {
  const posts = await Astro.glob('./*.md');

  return posts.map((post) => {
    // Membuat slug URL dari judul artikel jika file tidak punya slug bawaan
    const slug = post.frontmatter.title
      .toLowerCase()
      .replace(/[^a-z0-9]+/g, '-')
      .replace(/(^-|-$)+/g, '');

    return {
      params: { post: slug },
      props: { post },
    };
  });
}

const { post } = Astro.props;
const { Content, frontmatter } = post;

// Menyesuaikan author ke Jasalike
const author = {
  name: frontmatter.author || 'Tim Jasalike',
  image: '/logo-jasalike.png',
  bio: 'Spesialis optimasi interaksi dan algoritma sosial media.',
};

// URL Dinamis untuk artikel ini
const currentUrl = `https://jasalike.my.id/blog/${Astro.params.post}/`;
---

<DefaultLayout title={`${frontmatter.title} | Blog Jasalike`}>
  
  <!-- ============== SEO & SCHEMA DINAMIS (DIRECT VERSION) ============== -->
  <Fragment slot="head">
    <meta name="description" content={frontmatter.description} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={currentUrl} />

    <!-- Open Graph (Untuk dibagikan ke sosmed) -->
    <meta property="og:type" content="article" />
    <meta property="og:url" content={currentUrl} />
    <meta property="og:site_name" content="Jasalike" />
    <meta property="og:title" content={frontmatter.title} />
    <meta property="og:description" content={frontmatter.description} />
    <meta property="og:image" content={frontmatter.image ? `https://jasalike.my.id${frontmatter.image}` : "https://jasalike.my.id/logo-jasalike.png"} />
    
    <!-- Tag Artikel -->
    <meta property="article:published_time" content={frontmatter.pubDate} />
    <meta property="article:author" content={author.name} />

    <!-- JSON-LD Schema (BlogPosting & Breadcrumb) -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "BreadcrumbList",
          "itemListElement": [
            { "@type": "ListItem", "position": 1, "name": "Beranda", "item": "https://jasalike.my.id/" },
            { "@type": "ListItem", "position": 2, "name": "Blog", "item": "https://jasalike.my.id/blog/" },
            { "@type": "ListItem", "position": 3, "name": frontmatter.title, "item": currentUrl }
          ]
        },
        {
          "@type": "BlogPosting",
          "mainEntityOfPage": { "@type": "WebPage", "@id": currentUrl },
          "headline": frontmatter.title,
          "description": frontmatter.description,
          "image": frontmatter.image ? `https://jasalike.my.id${frontmatter.image}` : "https://jasalike.my.id/logo-jasalike.png",
          "author": { "@type": "Person", "name": author.name },
          "publisher": {
            "@type": "Organization",
            "name": "Jasalike",
            "logo": { "@type": "ImageObject", "url": "https://jasalike.my.id/logo-jasalike.png" }
          },
          "datePublished": frontmatter.pubDate
        }
      ]
    })} />
  </Fragment>

  <!-- ============== ISI KONTEN ============== -->
  <PageHeader
    title={frontmatter.title}
    subtitle={frontmatter.description}
    author={author}
    bgType="bordered"
    featuredImage={frontmatter.image || '/logo-jasalike.png'}
  />
  
  <section class="my-12">
    <div class="narrow space-content container prose prose-lg max-w-none dark:prose-invert">
      <Content />
    </div>
  </section>

  <section class="my-16 border-t border-neutral-200 dark:border-neutral-800 pt-12">
    <div class="narrow space-content container text-center">
      <h2 class="text-3xl font-semibold mb-4">Bagikan Artikel Ini</h2>
      <p class="opacity-80 mb-8">Bermanfaat? Jangan lupa bagikan tips ini ke rekan bisnis Anda!</p>
      <div class="flex justify-center">
        <SocialShares />
      </div>
    </div>
  </section>
</DefaultLayout>

<style lang="scss" is:global>
  .prose {
    h2 { margin-top: 2em; margin-bottom: 0.5em; color: var(--color-primary-600); }
    h3 { margin-top: 1.5em; margin-bottom: 0.5em; }
    p { margin-bottom: 1.25em; line-height: 1.8; }
    a { color: var(--color-primary-500); text-decoration: underline; font-weight: 500; }
    img { border-radius: 1rem; box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1); }
  }
</style>
