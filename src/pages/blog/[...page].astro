---
import DefaultLayout from '@layouts/DefaultLayout.astro'
import { Card, Pagination } from 'accessible-astro-components'
import type { PaginateFunction, Page } from 'astro'

export async function getStaticPaths({ paginate }: { paginate: PaginateFunction }) {
  // 1. Mengambil semua data artikel dari file .md
  const allPosts = await Astro.glob('./*.md');

  // 2. Mengurutkan postingan berdasarkan tanggal terbaru
  const sortedPosts = allPosts.sort((a, b) => new Date(b.frontmatter.pubDate).valueOf() - new Date(a.frontmatter.pubDate).valueOf());

  // 3. Paginasi (menampilkan 6 artikel per halaman)
  return paginate(sortedPosts, { pageSize: 6 })
}

interface Props {
  page: Page<any>
}

const { page } = Astro.props as Props

const title = "Blog Edukasi & Strategi Media Sosial | JasaLike";
const description = "Kupas tuntas rahasia algoritma terbaru, tips meningkatkan engagement, dan strategi optimasi likes untuk melejitkan bisnis digital Anda.";
---

<DefaultLayout title={title} description={description}>
  
  <header class="blog-hero">
    <div class="container text-center">
      <span class="badge">Aura Digital Insight</span>
      <h1 class="hero-title">Blog Jasalike</h1>
      <p class="hero-subtitle">Kumpulan artikel edukasi dan tips seputar optimasi sosial media untuk meningkatkan bisnis Anda.</p>
      <div class="hero-divider"></div>
    </div>
  </header>

  <main class="blog-main-content">
    <div class="container">
      
      <div class="blog-meta-info">
        <p class="text-sm">
          Menampilkan artikel teratas <span class="highlight">Halaman {page.currentPage}</span> dari {page.lastPage}
        </p>
      </div>
      
      <ul class="blog-grid">
        {
          page.data.map((post) => (
            <li class="blog-grid-item">
              <Card
                imageComponent={post.frontmatter.heroImage || post.frontmatter.image || '/logo-jasalike.png'}
                url={post.url}
                title={post.frontmatter.title}
                footer={new Date(post.frontmatter.pubDate).toLocaleDateString('id-ID', {
                  year: 'numeric',
                  month: 'long',
                  day: 'numeric'
                })}
              >
                {post.frontmatter.description}
              </Card>
            </li>
          ))
        }
      </ul>

      <div class="blog-pagination-wrapper">
        <Pagination
          firstPage={page.url.prev ? '/blog' : null}
          previousPage={page.url.prev ? page.url.prev : null}
          nextPage={page.url.next ? page.url.next : null}
          lastPage={page.url.next ? `/blog/${page.lastPage}` : null}
          currentPage={`${page.currentPage}`}
          totalPages={`${page.lastPage}`}
          ariaLabel="Navigasi Halaman Blog"
        />
      </div>
    </div>
  </main>
</DefaultLayout>

<style lang="scss" is:global>
  @use '../../assets/scss/base/mixins' as *;

  // 1. Styling Area Atas (Hero Section)
  .blog-hero {
    background: linear-gradient(180deg, rgba(59, 130, 246, 0.05) 0%, transparent 100%);
    padding: 5rem 0 3.5rem 0;
    border-bottom: 1px solid var(--neutral-100, #f3f4f6);
    
    .badge {
      display: inline-block;
      background-color: #dbeafe;
      color: #1d4ed8;
      font-size: 0.85rem;
      font-weight: 700;
      padding: 0.35rem 1rem;
      border-radius: 9999px;
      margin-bottom: 1.25rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    .hero-title {
      font-size: clamp(2.5rem, 6vw, 4rem);
      font-weight: 900;
      line-height: 1.1;
      color: var(--neutral-900, #111827);
      margin-bottom: 1rem;
      letter-spacing: -0.03em;
    }

    .hero-subtitle {
      font-size: clamp(1.1rem, 2vw, 1.35rem);
      line-height: 1.6;
      color: var(--neutral-600, #4b5563);
      max-width: 720px;
      margin: 0 auto 2rem auto;
    }

    .hero-divider {
      width: 60px;
      height: 4px;
      background-color: #3b82f6;
      margin: 0 auto;
      border-radius: 2px;
    }
  }

  // 2. Styling Area Konten Utama
  .blog-main-content {
    padding: 3.5rem 0 6rem 0;
    background-color: #fafafa;

    .blog-meta-info {
      margin-bottom: 2rem;
      border-bottom: 1px dashed var(--neutral-200, #e5e7eb);
      padding-bottom: 1rem;
      color: var(--neutral-500, #6b7280);

      .highlight {
        color: var(--neutral-900, #111827);
        font-weight: 600;
      }
    }
  }

  // 3. Penataan Grid Kartu
  .blog-grid {
    display: grid;
    grid-template-cols: 1fr;
    gap: 2.5rem;
    padding: 0;
    margin: 0;

    @media (min-width: 768px) {
      grid-template-cols: repeat(2, 1fr);
    }

    @media (min-width: 1024px) {
      grid-template-cols: repeat(3, 1fr);
    }
  }

  .blog-grid-item {
    list-style: none;
    display: flex;
  }

  // 4. Perapian Komponen Kartu Bawaan
  .card {
    display: flex;
    flex-direction: column;
    width: 100%;
    border-radius: 1.25rem !important;
    border: 1px solid var(--neutral-200, #e5e7eb) !important;
    box-shadow: 0 4px 20px -2px rgba(0, 0, 0, 0.03) !important;
    background: #ffffff !important;
    overflow: hidden;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1) !important;

    &:hover {
      transform: translateY(-6px) !important;
      box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.07), 0 10px 10px -5px rgba(0, 0, 0, 0.04) !important;
      border-color: #93c5fd !important;
    }

    .card__image {
      height: 200px !important;
      overflow: hidden;
      
      img {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }
    }

    .card__content {
      padding: 1.5rem !important;
      display: flex;
      flex-direction: column;
      flex-grow: 1;

      h3 {
        font-size: 1.35rem !important;
        font-weight: 700 !important;
        line-height: 1.35 !important;
        margin-block-end: 0.75rem !important;
        
        a {
          text-decoration: none !important;
          color: var(--neutral-900, #111827);
          @include text-decoration(transparent, var(--foreground-color), 4px, 2px);
          transition: color 0.2s ease;

          &:hover {
            color: #2563eb;
          }
        }
      }

      p {
        color: var(--neutral-600, #4b5563);
        line-height: 1.6;
        font-size: 0.95rem;
        margin-bottom: 1.5rem;
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
      }
    }

    .card__footer {
      padding: 0 1.5rem 1.5rem 1.5rem !important;
      margin-top: auto;
      font-size: 0.85rem;
      font-weight: 500;
      color: var(--neutral-400, #9ca3af);
    }
  }

  // 5. Pembungkus Navigasi Paginasi
  .blog-pagination-wrapper {
    margin-top: 5rem;
    padding-top: 2.5rem;
    border-top: 1px solid var(--neutral-200, #e5e7eb);
  }
</style>

