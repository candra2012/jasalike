---
import DefaultLayout from '@layouts/DefaultLayout.astro'
import PageHeader from '@components/PageHeader.astro'
import { Card, Pagination } from 'accessible-astro-components'
import type { PaginateFunction, Page } from 'astro'

export async function getStaticPaths({ paginate }: { paginate: PaginateFunction }) {
  // 1. Mengambil semua data artikel dari file .md
  const allPosts = await Astro.glob('./*.md');

  // 2. Mengurutkan postingan berdasarkan tanggal terbaru
  const sortedPosts = allPosts.sort((a, b) => new Date(b.frontmatter.pubDate).valueOf() - new Date(a.frontmatter.pubDate).valueOf());

  // 3. Paginasi (menampilkan 6 artikel per halaman)
  return paginate(sortedPosts, { pageSize: 6 })
}

interface Props {
  page: Page<any>
}

const { page } = Astro.props as Props
---

<DefaultLayout title="Blog Jasalike - Edukasi & Tips Sosial Media">
  
  <!-- ============== SEO & SCHEMA (DIRECT VERSION) ============== -->
  <Fragment slot="head">
    <meta name="description" content="Kumpulan artikel edukasi, tips, dan trik seputar optimasi sosial media dari spesialis Jasalike." />
    <meta name="keywords" content="blog jasalike, tips sosial media, cara fyp tiktok, optimasi instagram, edukasi sosmed" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={`https://jasalike.my.id/blog${page.url.current === '/' ? '' : page.url.current}/`} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={`https://jasalike.my.id/blog${page.url.current === '/' ? '' : page.url.current}/`} />
    <meta property="og:site_name" content="Jasalike" />
    <meta property="og:title" content="Blog Jasalike - Edukasi & Tips Sosial Media" />
    <meta property="og:description" content="Kumpulan artikel edukasi dan trik rahasia optimasi sosial media." />
    <meta property="og:image" content="https://jasalike.my.id/logo-jasalike.png" />

    <!-- JSON-LD Schema (Blog & Breadcrumb) -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "BreadcrumbList",
          "itemListElement": [
            { "@type": "ListItem", "position": 1, "name": "Beranda", "item": "https://jasalike.my.id/" },
            { "@type": "ListItem", "position": 2, "name": "Blog", "item": "https://jasalike.my.id/blog/" }
          ]
        },
        {
          "@type": "Blog",
          "url": "https://jasalike.my.id/blog/",
          "name": "Blog Jasalike",
          "description": "Artikel edukasi dan tips seputar optimasi sosial media.",
          "publisher": {
            "@type": "Organization",
            "name": "Jasalike",
            "logo": { "@type": "ImageObject", "url": "https://jasalike.my.id/logo-jasalike.png" }
          }
        }
      ]
    })} />
  </Fragment>

  <!-- ============== ISI KONTEN ============== -->
  <PageHeader
    title="Blog Jasalike"
    subtitle="Kumpulan artikel edukasi dan tips seputar optimasi sosial media untuk meningkatkan bisnis Anda."
    bgType="bordered"
  />

  <section class="my-12">
    <div class="container">
      <p class="text-sm opacity-70"><em>Halaman {page.currentPage} dari {page.lastPage}</em></p>
      
      <ul class="my-6 grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
        {
          page.data.map((post) => (
            <li class="list-none">
              <Card
                imageComponent={post.frontmatter.image || '/logo-jasalike.png'}
                url={post.url}
                title={post.frontmatter.title}
                footer={post.frontmatter.pubDate}
              >
                {post.frontmatter.description}
              </Card>
            </li>
          ))
        }
      </ul>

      <div class="mt-16 grid place-content-center">
        <Pagination
          firstPage={page.url.prev ? '/blog' : null}
          previousPage={page.url.prev ? page.url.prev : null}
          nextPage={page.url.next ? page.url.next : null}
          lastPage={page.url.next ? `/blog/${page.lastPage}` : null}
          currentPage={`${page.currentPage}`}
          totalPages={`${page.lastPage}`}
          ariaLabel="Navigasi Blog"
        />
      </div>
    </div>
  </section>
</DefaultLayout>

<style lang="scss" is:global>
  @use '../../assets/scss/base/mixins' as *;

  .card {
    h3 {
      margin-block-end: var(--space-xs);
      line-height: 1.3;
    }
    a {
      @include text-decoration(transparent, var(--foreground-color), 4px, 2px);
    }
  }
</style>
