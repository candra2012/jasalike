---
import DefaultLayout from '@layouts/DefaultLayout.astro'
import SiteMetaKomentarInstagram from '@components/SiteMetaKomentarInstagram.astro'
import SchemaKomentarInstagram from '@components/SchemaKomentarInstagram.astro'
---

<DefaultLayout title="Komentar Instagram">
  <Fragment slot="head">
    <!-- Meta + JSON-LD -->
    <SiteMetaKomentarInstagram />
    <SchemaKomentarInstagram />
  </Fragment>

  <!-- ============== HERO ============== -->
  <section class="container my-12">
    <h1 class="text-5xl md:text-6xl font-bold">Jasa Komentar Instagram Organik & Relevan</h1>
    <p class="text-xl opacity-80 mt-4 max-w-3xl">
      Tambah komentar yang natural, relevan, dan aman untuk meningkatkan <em>engagement</em> serta
      <em>social proof</em>. Cocok untuk Feed, Reels, maupun kampanye brand.
    </p>

    <figure class="mt-8 overflow-hidden rounded-2xl border">
      <picture>
        <source srcset="/komentar-instagram.webp" type="image/webp" />
        <img src="/komentar-instagram.png" alt="Layanan Komentar Instagram" loading="eager" class="w-full h-auto" />
      </picture>
    </figure>
  </section>

  <!-- ============== MENGAPA KOMENTAR PENTING ============== -->
  <section class="container my-16">
    <h2 class="text-3xl md:text-4xl font-semibold">Mengapa Komentar Sangat Berpengaruh?</h2>

    <div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-2">
      <article class="p-6 rounded-2xl border shadow-sm bg-white/70 dark:bg-neutral-900/60">
        <h3 class="text-xl font-semibold">Sinyal Algoritma</h3>
        <p class="mt-2 opacity-80">
          Komentar adalah interaksi bernilai tinggi. Rasio komentar terhadap tayangan/likes
          membantu algoritma menilai kontenmu layak didorong ke audiens yang lebih luas.
        </p>
      </article>

      <article class="p-6 rounded-2xl border shadow-sm bg-white/70 dark:bg-neutral-900/60">
        <h3 class="text-xl font-semibold">Social Proof & Kepercayaan</h3>
        <p class="mt-2 opacity-80">
          Thread diskusi di kolom komentar membangun persepsi “ramai” dan kredibel, mendorong
          orang lain ikut terlibat dan mengikuti akunmu.
        </p>
      </article>

      <article class="p-6 rounded-2xl border shadow-sm bg-white/70 dark:bg-neutral-900/60">
        <h3 class="text-xl font-semibold">Dampak ke Reach & Explore</h3>
        <p class="mt-2 opacity-80">
          Percakapan yang aktif sering menjadi pemicu jangkauan organik. Komentar relevan
          mengundang balasan dan menyuburkan interaksi.
        </p>
      </article>

      <article class="p-6 rounded-2xl border shadow-sm bg-white/70 dark:bg-neutral-900/60">
        <h3 class="text-xl font-semibold">Insight Konten</h3>
        <p class="mt-2 opacity-80">
          Isi komentar bisa menjadi umpan balik untuk riset konten, ide konten lanjutan,
          sekaligus mengetahui keberatan/pertanyaan audiens.
        </p>
      </article>
    </div>
  </section>

  <!-- ============== FITUR & KEUNGGULAN ============== -->
  <section class="container my-16">
    <h2 class="text-3xl md:text-4xl font-semibold">Fitur & Keunggulan Layanan Komentar</h2>

    <div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-2">
      <article class="p-6 rounded-2xl border shadow-sm bg-white/70 dark:bg-neutral-900/60">
        <h3 class="text-xl font-semibold">Metode Aman & Bertahap</h3>
        <p class="mt-2 opacity-80">
          Distribusi komentar dilakukan bertahap agar terlihat natural dan tidak menonjol.
        </p>
      </article>

      <article class="p-6 rounded-2xl border shadow-sm bg-white/70 dark:bg-neutral-900/60">
        <h3 class="text-xl font-semibold">Harga Transparan</h3>
        <p class="mt-2 opacity-80">
          Tarif dasar: <strong>IDR 3.000 per komentar</strong>. Mulai dari paket kecil untuk uji performa, lalu
          naikkan sesuai kebutuhan kampanye.
        </p>
      </article>

      <article class="p-6 rounded-2xl border shadow-sm bg-white/70 dark:bg-neutral-900/60">
        <h3 class="text-xl font-semibold">Kustom Tone & Topik</h3>
        <p class="mt-2 opacity-80">
          Bisa memberi contoh gaya/tema komentar. Tim kami kurasi agar tetap relevan dan positif.
        </p>
      </article>

      <article class="p-6 rounded-2xl border shadow-sm bg-white/70 dark:bg-neutral-900/60">
        <h3 class="text-xl font-semibold">Support Cepat</h3>
        <p class="mt-2 opacity-80">
          Butuh rekomendasi jumlah dan tempo? Kami bantu susun ritme aman & efektif.
        </p>
      </article>
    </div>
  </section>

  <!-- ============== PAKET & ESTIMASI (MATCH STYLE LIKES) ============== -->
  <section class="container my-16">
    <h2 class="text-3xl md:text-4xl font-semibold">Paket & Estimasi</h2>
    <p class="mt-3 opacity-80">
      Rate dasar: <strong>IDR 3.000 per 1 komentar</strong>. Berikut contoh paket populer sebagai estimasi.
    </p>

    <div class="mt-8 grid gap-6 md:grid-cols-3">
      {[
        { n: '100 Komentar',  price: 'IDR 300.000',   note: 'Cocok untuk memulai diskusi & uji performa.' },
        { n: '500 Komentar',  price: 'IDR 1.500.000', note: 'Bangun thread aktif & tingkatkan kepercayaan.' },
        { n: '1.000 Komentar', price: 'IDR 3.000.000', note: 'Dorong percakapan masif untuk kampanye besar.' },
      ].map((p) => (
        <article class="rounded-2xl border border-neutral-200/70 dark:border-neutral-800/70 bg-white/70 dark:bg-neutral-900/60 shadow-sm p-6">
          <h3 class="text-xl font-semibold">{p.n}</h3>
          <p class="mt-1 text-2xl font-extrabold tracking-tight">{p.price}</p>
          <p class="mt-3 opacity-80">{p.note}</p>

          <div class="mt-5 grid grid-cols-2 gap-3">
            <!-- Tombol WhatsApp: hubungi admin -->
            <a href="https://wa.me/6289634740308?text=Halo%20admin%2C%20saya%20ingin%20konsultasi%20layanan%20Komentar%20Instagram."
               target="_blank" rel="noopener"
               class="inline-flex items-center justify-center rounded-xl px-4 py-2 font-semibold bg-green-500 text-white hover:bg-green-600 transition">
              Hubungi Admin
            </a>

            <!-- Tombol ke halaman layanan lain -->
            <a href="/layanan/"
               class="inline-flex items-center justify-center rounded-xl px-4 py-2 font-semibold bg-pink-200 text-pink-900 hover:bg-pink-300 dark:bg-pink-500/20 dark:text-pink-200 transition">
              Lihat Layanan Lain
            </a>
          </div>
        </article>
      ))}
    </div>

    <p class="mt-4 text-sm opacity-70">
      *Harga dapat menyesuaikan kondisi, target audiens, dan parameter kampanye.
    </p>
  </section>

       <!-- ============== PERTANYAAN UMUM (ACCORDION) ============== -->
  <section class="container my-16">
    <h2 class="text-3xl md:text-4xl font-semibold">Pertanyaan Umum</h2>

    <div class="mt-6 grid gap-4 md:grid-cols-2">
      <details class="group rounded-2xl border bg-white/70 dark:bg-neutral-900/60 p-4 open:shadow-sm">
        <summary class="cursor-pointer list-none text-base font-semibold flex justify-between items-center">
          Apakah aman untuk akun?
          <span class="ml-4 transition-transform group-open:rotate-180">▾</span>
        </summary>
        <p class="mt-2 opacity-80">
          Ya. Komentar didistribusikan bertahap dengan ritme yang natural dan mematuhi batas aman
          agar tidak mencolok di sistem. Kami juga menjaga tone tetap positif dan relevan.
        </p>
      </details>

      <details class="group rounded-2xl border bg-white/70 dark:bg-neutral-900/60 p-4 open:shadow-sm">
        <summary class="cursor-pointer list-none text-base font-semibold flex justify-between items-center">
          Berapa lama prosesnya?
          <span class="ml-4 transition-transform group-open:rotate-180">▾</span>
        </summary>
        <p class="mt-2 opacity-80">
          Umumnya mulai 1–24 jam setelah konfirmasi. Kecepatan berjalan bertahap sesuai paket dan
          antrean. Kamu bisa minta tempo lebih pelan/cepat sesuai kebutuhan.
        </p>
      </details>

      <details class="group rounded-2xl border bg-white/70 dark:bg-neutral-900/60 p-4 open:shadow-sm">
        <summary class="cursor-pointer list-none text-base font-semibold flex justify-between items-center">
          Apakah bisa kustom topik/skrip komentar?
          <span class="ml-4 transition-transform group-open:rotate-180">▾</span>
        </summary>
        <p class="mt-2 opacity-80">
          Bisa. Kirimkan contoh gaya, poin utama, atau daftar pertanyaan. Tim akan kurasi agar
          tetap natural dan tidak spammy.
        </p>
      </details>

      <details class="group rounded-2xl border bg-white/70 dark:bg-neutral-900/60 p-4 open:shadow-sm">
        <summary class="cursor-pointer list-none text-base font-semibold flex justify-between items-center">
          Perlu akses akun?
          <span class="ml-4 transition-transform group-open:rotate-180">▾</span>
        </summary>
        <p class="mt-2 opacity-80">
          Tidak. Kamu cukup kirimkan URL konten yang ingin didorong komentarnya serta preferensi
          tone/topik. Akses akun tidak diperlukan.
        </p>
      </details>
    </div>
  </section>

  <!-- ============== TESTIMONI (SLIDER OTOMATIS) ============== -->
  <section class="container my-16">
    <h2 class="text-3xl md:text-4xl font-semibold">Testimoni Klien</h2>
    <div class="mt-6 overflow-hidden rounded-2xl border">
      <!-- Slider sederhana tanpa dependensi: auto-scroll horizontal -->
      <div class="flex gap-6 p-6 animate-[scrollX_24s_linear_infinite]">
        {[
          { name: 'Toko Aksesoris', text: 'Komentar relevan bikin diskusi rame. Reach naik, DM masuk makin banyak.' },
          { name: 'Kursus Online', text: 'Thread Q&A memancing minat. Conversion dari bio link ikut naik.' },
          { name: 'Brand Skincare', text: 'Natural dan positif, membantu branding serta trust di posting review.' },
          { name: 'Creator Reels', text: 'Engagement ratio membaik. Reels lebih sering mendapatkan rekomendasi.' },
        ].map(t => (
          <blockquote class="min-w-[280px] max-w-sm shrink-0 rounded-xl border bg-white/70 dark:bg-neutral-900/60 p-5">
            <p class="opacity-90">“{t.text}”</p>
            <footer class="mt-3 font-semibold">— {t.name}</footer>
          </blockquote>
        ))}
        <!-- duplikasi untuk efek loop -->
        {[
          { name: 'Toko Aksesoris', text: 'Komentar relevan bikin diskusi rame. Reach naik, DM masuk makin banyak.' },
          { name: 'Kursus Online', text: 'Thread Q&A memancing minat. Conversion dari bio link ikut naik.' },
          { name: 'Brand Skincare', text: 'Natural dan positif, membantu branding serta trust di posting review.' },
          { name: 'Creator Reels', text: 'Engagement ratio membaik. Reels lebih sering mendapatkan rekomendasi.' },
        ].map(t => (
          <blockquote class="min-w-[280px] max-w-sm shrink-0 rounded-xl border bg-white/70 dark:bg-neutral-900/60 p-5">
            <p class="opacity-90">“{t.text}”</p>
            <footer class="mt-3 font-semibold">— {t.name}</footer>
          </blockquote>
        ))}
      </div>
    </div>

    <style is:global>
      @keyframes scrollX {
        from { transform: translateX(0); }
        to   { transform: translateX(-50%); }
      }
    </style>
  </section>

  <!-- ============== AJAKAN FOLLOW IG (TEKS LINK SAJA) ============== -->
  <section class="container my-16">
    <h2 class="text-3xl md:text-4xl font-semibold">Ikuti Instagram Kami</h2>
    <p class="mt-3 text-lg opacity-80 max-w-3xl">
      Untuk info terbaru, tips optimasi, dan update layanan, silakan ikuti Instagram kami di
      <a href="https://instagram.com/auradigitalid" target="_blank" rel="noopener" class="underline decoration-2 decoration-pink-400 hover:decoration-pink-500">
        @auradigitalid
      </a>.
    </p>
  </section>

</DefaultLayout>
