---

<DefaultLayout title={title} description={description} keywords={keywords}>

<Fragment slot="head">
<script type="application/ld+json">
[
  {
    "@context": "https://schema.org/",
    "@type": "Product",
    "name": "Jasa Like LinkedIn Profesional",
    "image": "https://jasalike.com/image/jasa-like-linkedin-organik-100like.png",
    "description": "Optimalkan engagement LinkedIn lewat jasa like LinkedIn premium. Hasil natural, tanpa akses akun, garansi refill, dan dukungan akun profesional.",
    "brand": {
      "@type": "Brand",
      "name": "JasaLike"
    },
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "4.9",
      "bestRating": "5",
      "worstRating": "1",
      "ratingCount": "1250"
    },
    "offers": {
      "@type": "AggregateOffer",
      "lowPrice": "25000",
      "highPrice": "2500000",
      "priceCurrency": "IDR",
      "offerCount": "2"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Beranda",
        "item": "https://jasalike.com/"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": "Layanan",
