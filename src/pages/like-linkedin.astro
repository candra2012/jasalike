      },
      {
        "@type": "ListItem",
        "position": 3,
        "name": "Like LinkedIn"
      }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Apakah like LinkedIn ini dikirim dari akun manusia nyata?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Tentu. Setiap apresiasi dikirim oleh akun profesional yang melalui proses kurasi tim kami, sehingga profil yang berinteraksi tetap kredibel di mata audiens Anda."
        }
      },
      {
        "@type": "Question",
        "name": "Apakah postingan saya aman dari penalti atau pemblokiran LinkedIn?",
