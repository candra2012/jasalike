<DefaultLayout title={title} description={description} keywords={keywords}>

<Fragment slot="head">
<script type="application/ld+json">
[
  {
    "@context": "https://schema.org/",
    "@type": "Product",
    "name": "Jual Jasa Produk Terjual di Toko Online",
    "image": "https://jasalike.com/image/harga-fakeshopee.png",
    "description": "Tingkatkan penjualan produk di toko online Anda dengan layanan jasa produk terjual. Proses profesional, privasi terjaga, dan hasil yang memuaskan.",
    "brand": {
      "@type": "Brand",
      "name": "JasaLike"
    },
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": 4.9,
      "bestRating": 5,
      "worstRating": 1,
      "ratingCount": 855
    },
    "offers": {
      "@type": "AggregateOffer",
      "lowPrice": 200000,
      "highPrice": 2000000,
      "priceCurrency": "IDR",
      "offerCount": 2
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Beranda",
        "item": "https://jasalike.com/"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": "Layanan",
        "item": "https://jasalike.com/direktori-layanan/"
      },
      {
        "@type": "ListItem",
        "position": 3,
        "name": "Jasa Produk Terjual"
      }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Apakah aman menggunakan jasa produk terjual ini?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Sangat aman. Kami memproses peningkatan penjualan dengan kecepatan yang wajar dan metode profesional, sehingga sepenuhnya mematuhi standar keamanan."
        }
      },
      {
        "@type": "Question",
        "name": "Apakah saya harus memberikan data rahasia?",
