---
import DefaultLayout from '@layouts/DefaultLayout.astro'
import { Icon } from 'astro-icon/components'
---

<DefaultLayout title="Hubungi Kami | Jasalike - Layanan Pelanggan">
  
  <script type="application/ld+json" slot="head">
    {
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "ContactPage",
          "@id": "https://jasalike.com/kontak/#webpage",
          "url": "https://jasalike.com/kontak/",
          "name": "Hubungi Kami | Konsultasi Optimasi Media Sosial - Aura Digital",
          "description": "Hubungi tim dukungan Aura Digital untuk konsultasi strategi optimasi metrik sosial media. Kami siap membantu pertumbuhan Instagram, TikTok, Facebook, dan platform lainnya.",
          "isPartOf": {
            "@id": "https://jasalike.com/#website"
          },
          "inLanguage": "id-ID"
        },
        {
          "@type": "Organization",
          "@id": "https://jasalike.com/#organization",
          "name": "Aura Digital",
          "url": "https://jasalike.com/",
          "contactPoint": {
            "@type": "ContactPoint",
            "telephone": "+62-896-3474-0308",
            "contactType": "Customer Service",
            "areaServed": "ID",
            "availableLanguage": "Indonesian",
            "hoursAvailable": {
              "@type": "OpeningHoursSpecification",
              "dayOfWeek": [
                "Monday",
                "Tuesday",
                "Wednesday",
                "Thursday",
                "Friday",
                "Saturday",
                "Sunday"
              ],
              "opens": "08:00",
              "closes": "22:00"
            }
          }
        },
        {
          "@type": "BreadcrumbList",
          "@id": "https://jasalike.com/kontak/#breadcrumb",
          "itemListElement": [
            {
              "@type": "ListItem",
              "position": 1,
              "name": "Beranda",
              "item": "https://jasalike.com/"
            },
            {
              "@type": "ListItem",
              "position": 2,
              "name": "Hubungi Kami",
              "item": "https://jasalike.com/kontak/"
            }
          ]
        }
      ]
    }
  </script>

  <!-- ============== ISI KONTEN HALAMAN ============== -->
  <section class="container my-24">
    <div class="max-w-4xl mx-auto text-center mb-16">
      <h1 class="text-5xl md:text-7xl font-bold tracking-tight mb-6">Hubungi <span class="text-primary-500">Kami</span></h1>
      <p class="text-2xl opacity-80 leading-relaxed">
        Punya pertanyaan seputar layanan kami atau ingin konsultasi paket mana yang cocok untuk akun Anda? Tim kami siap membantu!
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-8 max-w-5xl mx-auto">
      <!-- Kartu WhatsApp -->
      <article class="p-8 rounded-3xl border border-green-200 dark:border-green-900 bg-green-50 dark:bg-green-900/10 text-center shadow-sm hover:shadow-md transition-shadow">
        <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-green-100 dark:bg-green-800 text-green-600 dark:text-green-300 mb-6">
          <Icon name="lucide:message-circle" size="32" />
        </div>
        <h3 class="text-2xl font-semibold mb-3">WhatsApp</h3>
        <p class="opacity-80 mb-6">Respon paling cepat untuk pemesanan dan konsultasi.</p>
        <a href="https://wa.me/6289634740308?text=Halo%20Admin%20Jasalike,%20saya%20ingin%20bertanya%20seputar%20layanan." target="_blank" rel="noopener" class="inline-block px-6 py-3 font-semibold rounded-xl bg-green-500 hover:bg-green-600 text-white transition-colors w-full">
          Chat Admin
        </a>
      </article>

      <!-- Kartu Jam Operasional -->
      <article class="p-8 rounded-3xl border border-neutral-200 dark:border-neutral-800 bg-white dark:bg-neutral-900 text-center shadow-sm">
        <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-neutral-100 dark:bg-neutral-800 text-neutral-600 dark:text-neutral-300 mb-6">
          <Icon name="lucide:clock" size="32" />
        </div>
        <h3 class="text-2xl font-semibold mb-3">Jam Operasional</h3>
        <p class="opacity-80 mb-2"><strong>Senin - Minggu</strong></p>
        <p class="opacity-80">08:00 - 22:00 WIB</p>
        <p class="text-sm opacity-60 mt-4">*Sistem kami tetap memproses order 24 jam</p>
      </article>

      <!-- Kartu Area Layanan -->
      <article class="p-8 rounded-3xl border border-neutral-200 dark:border-neutral-800 bg-white dark:bg-neutral-900 text-center shadow-sm">
        <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-neutral-100 dark:bg-neutral-800 text-neutral-600 dark:text-neutral-300 mb-6">
          <Icon name="lucide:map-pin" size="32" />
        </div>
        <h3 class="text-2xl font-semibold mb-3">Area Layanan</h3>
        <p class="opacity-80 mb-2"><strong>Seluruh Indonesia</strong></p>
        <p class="opacity-80">Layanan digital tanpa batas wilayah.</p>
      </article>
    </div>
  </section>

  <section class="container my-24 max-w-4xl mx-auto">
    <div class="bg-gradient-to-br from-primary-50 to-secondary-50 dark:from-primary-900/20 dark:to-secondary-900/20 rounded-3xl p-10 border border-primary-100 dark:border-primary-800/50 text-center">
      <h2 class="text-3xl font-semibold mb-4">Peringatan Keamanan</h2>
      <p class="text-lg opacity-80 leading-relaxed mb-0">
        Admin Jasalike yang resmi <strong>hanya membalas melalui nomor WhatsApp +62-896-3474-0308 dan +62-813-1045-778</strong>. Kami tidak pernah menghungi anda duluan admin kami atau CS kami dan meminta dana tanpa ada kerjasama dan kesepakatan dalam situasi apa pun.
      </p>
    </div>
  </section>

</DefaultLayout>
