---

<DefaultLayout title={title} description={description} keywords={keywords}>

  <Fragment slot="head">
    <script type="application/ld+json">
      [
        {
          "@context": "https://schema.org/",
          "@type": "Product",
          "name": "Jasa Save Instagram Terpercaya Murah Dan Cepat",
          "image": "https://jasalike.com/image/harga-sharefb.png",
          "description": "Layanan optimasi penambah save Instagram secara natural, aman, dan tanpa meminta kredensial. Bergaransi penuh untuk meningkatkan retensi dan nilai konten.",
          "brand": {
            "@type": "Brand",
            "name": "JasaLike"
          },
          "aggregateRating": {
            "@type": "AggregateRating",
            "ratingValue": "4.9",
            "bestRating": "5",
            "worstRating": "1",
            "ratingCount": "1180"
          },
          "offers": {
            "@type": "AggregateOffer",
            "lowPrice": "70000",
            "highPrice": "2000000",
            "priceCurrency": "IDR",
            "offerCount": "4"
          }
        },
        {
          "@context": "https://schema.org",
          "@type": "BreadcrumbList",
          "itemListElement": [
            {
              "@type": "ListItem",
              "position": 1,
              "name": "Beranda",
              "item": "https://jasalike.com/"
            },
            {
