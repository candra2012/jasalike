            "@type": "Brand",
            "name": "JasaLike"
          },
          "aggregateRating": {
            "@type": "AggregateRating",
            "ratingValue": "4.9",
            "bestRating": "5",
            "worstRating": "1",
            "ratingCount": "1180"
          },
          "offers": {
            "@type": "AggregateOffer",
            "lowPrice": "70000",
            "highPrice": "2000000",
            "priceCurrency": "IDR",
            "offerCount": "4"
          }
        },
        {
          "@context": "https://schema.org",
          "@type": "BreadcrumbList",
          "itemListElement": [
            {
              "@type": "ListItem",
              "position": 1,
              "name": "Beranda",
              "item": "https://jasalike.com/"
            },
            {
              "@type": "ListItem",
              "position": 2,
              "name": "Layanan",
              "item": "https://jasalike.com/layanan/"
            },
            {
              "@type": "ListItem",
              "position": 3,
              "name": "Save Instagram"
            }
          ]
        },
        {
          "@context": "https://schema.org",
          "@type": "FAQPage",
          "mainEntity": [
            {
              "@type": "Question",
              "name": "Apakah jasa save Instagram ini aman?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Sangat aman. Kami menggunakan teknik optimasi organik yang dirancang khusus untuk mematuhi kebijakan Instagram sehingga akun Anda tetap terjaga keamanannya."
              }
            },
            {
              "@type": "Question",
              "name": "Berapa lama proses pengerjaannya?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Proses dimulai secara instan setelah pembayaran terkonfirmasi. Estimasi pengerjaan selesai antara 1 hingga 24 jam tergantung pada jumlah paket yang Anda pilih."
