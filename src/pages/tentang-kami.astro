---
// Import disesuaikan dengan struktur terbaru
import DefaultLayout from '../layouts/DefaultLayout.astro'
import { Icon } from 'astro-icon/components'

const keywords = "tentang jasalike, tentang auradigital, perusahaan jasa like indonesia, sejarah jasalike";
const description = "Kenali JasaLike, mitra optimasi media sosial di Indonesia. Kami membantu brand membangun otoritas digital, engagement berkualitas, dan konversi berkelanjutan.";
---

<DefaultLayout title="Tentang Kami | JasaLike by AuraDigital - Agensi Eskalasi Digital" description={description} keywords={keywords}>
  
  <Fragment slot="head">
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "AboutPage",
          "@id": "https://jasalike.com/tentang-kami/#webpage",
          "url": "https://jasalike.com/tentang-kami/",
          "name": "Tentang Kami | Profil Agensi Optimasi Aura Digital",
          "description": "Pelajari dedikasi dan infrastruktur JasaLike (Aura Digital) sebagai agensi manajemen metrik sosial media profesional yang berfokus pada dominasi algoritma dan konversi brand Anda.",
          "isPartOf": {
            "@id": "https://jasalike.com/#website"
          },
          "inLanguage": "id-ID"
        },
        {
          "@type": "Organization",
          "@id": "https://jasalike.com/#organization",
          "name": "Aura Digital",
          "alternateName": "JasaLike",
          "url": "https://jasalike.com/",
          "logo": {
            "@type": "ImageObject",
            "url": "https://jasalike.com/image/logo-sosmed.jpg",
            "width": 512,
            "height": 512
          },
          "description": "Aura Digital adalah agensi penyedia layanan optimasi media sosial, e-commerce, dan manajemen interaksi digital premium untuk korporat dan kreator di Indonesia.",
          "contactPoint": {
            "@type": "ContactPoint",
            "telephone": "+62-896-3474-0308",
            "contactType": "Customer Service",
            "areaServed": "ID",
            "availableLanguage": "Indonesian"
          },
          "address": {
            "@type": "PostalAddress",
            "streetAddress": "Jl. Palabuan subang No. 15",
            "addressLocality": "Subang Kota, Subang",
            "addressRegion": "Jawa Barat",
            "postalCode": "41211",
            "addressCountry": "ID"
          }
        },
        {
          "@type": "BreadcrumbList",
          "@id": "https://jasalike.com/tentang-kami/#breadcrumb",
          "itemListElement": [
            {
              "@type": "ListItem",
              "position": 1,
              "name": "Beranda",
              "item": "https://jasalike.com/"
            },
            {
              "@type": "ListItem",
              "position": 2,
              "name": "Tentang Kami",
              "item": "https://jasalike.com/tentang-kami/"
            }
          ]
        }
      ]
    }
  </script>
  </Fragment>

  <section class="py-20 md:py-32 bg-slate-900 border-b border-slate-800 relative overflow-hidden">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full max-w-3xl h-64 bg-cyan-600/20 blur-[100px] rounded-full pointer-events-none"></div>
    
    <div class="container mx-auto px-6 max-w-4xl text-center relative z-10">
      <h1 class="text-4xl md:text-6xl font-bold text-white mb-6 tracking-tight">
        Di Balik <span class="bg-gradient-to-r from-cyan-400 to-blue-500 bg-clip-text text-transparent">JasaLike</span>
      </h1>
      <p class="text-lg md:text-xl text-slate-300 leading-relaxed max-w-2xl mx-auto">
        Kami adalah bagian dari jaringan agensi <strong>AuraDigital</strong> yang berdedikasi membangun otoritas digital, kredibilitas brand, dan dominasi algoritma untuk bisnis Anda.
      </p>
    </div>
  </section>

  <section class="py-16 md:py-24 bg-slate-50 dark:bg-[#0B1121]">
    <div class="container mx-auto px-6 max-w-6xl">
      <div class="grid md:grid-cols-2 gap-16 items-center">
        
        <div class="p-10 md:p-12 rounded-3xl bg-white dark:bg-slate-900/50 border border-slate-200 dark:border-slate-800 shadow-xl relative overflow-hidden group">
          <div class="absolute top-0 right-0 p-6 opacity-10 dark:opacity-20 transform translate-x-4 -translate-y-4 group-hover:scale-110 transition-transform duration-500">
            <Icon name="lucide:target" class="w-32 h-32 text-blue-600" />
          </div>
          <div class="relative z-10">
            <h2 class="text-3xl font-bold text-slate-900 dark:text-white mb-6">Visi Utama Kami</h2>
            <p class="text-lg text-slate-600 dark:text-slate-400 leading-relaxed">
              Menjadi infrastruktur eskalasi metrik digital terdepan di Indonesia yang memberikan solusi peningkatan engagement paling aman, organik, dan berdampak langsung pada tingkat konversi bisnis klien kami.
            </p>
          </div>
        </div>

        <div>
          <h2 class="text-3xl md:text-4xl font-bold text-slate-900 dark:text-white mb-6">
            Eskalasi Strategis, Bukan Sekadar Angka
          </h2>
          <div class="space-y-6 text-lg text-slate-600 dark:text-slate-400 leading-relaxed">
            <p>
              Di era kompetisi digital yang agresif, kualitas produk saja tidak cukup. Calon pembeli dan audiens membutuhkan validasi awal (Social Proof) sebelum mereka memberikan kepercayaan.
            </p>
            <p>
              JasaLike merancang sistem rekayasa interaksi yang selaras dengan cara kerja algoritma modern (TikTok, Instagram, hingga Marketplace). Kami membantu brand Anda melewati rintangan algoritma awal (cold start), menenggelamkan sentimen negatif, dan mempercepat pertumbuhan organik tanpa membahayakan aset digital Anda.
            </p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <section class="py-16 md:py-24 bg-white dark:bg-slate-900/20 border-y border-slate-200 dark:border-slate-800/50">
    <div class="container mx-auto px-6 max-w-6xl">
      <h2 class="text-3xl md:text-4xl font-bold mb-16 text-center text-slate-900 dark:text-white">Infrastruktur Premium Kami</h2>
      
      <div class="grid sm:grid-cols-3 gap-8">
        <article class="p-8 md:p-10 rounded-3xl border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-slate-900/50 shadow-sm hover:shadow-lg transition-shadow text-center">
          <div class="mx-auto w-16 h-16 rounded-2xl bg-blue-100 dark:bg-blue-900/50 text-blue-600 dark:text-blue-400 flex items-center justify-center mb-6">
            <Icon name="lucide:shield-check" class="w-8 h-8" />
          </div>
          <h3 class="text-2xl font-bold text-slate-900 dark:text-white mb-4">Privasi Absolut</h3>
          <p class="text-slate-600 dark:text-slate-400 leading-relaxed">
            Beroperasi 100% secara eksternal. Kami tidak akan pernah meminta kata sandi, email, atau kredensial login sistem klien kami.
          </p>
        </article>

        <article class="p-8 md:p-10 rounded-3xl border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-slate-900/50 shadow-sm hover:shadow-lg transition-shadow text-center">
          <div class="mx-auto w-16 h-16 rounded-2xl bg-cyan-100 dark:bg-cyan-900/50 text-cyan-600 dark:text-cyan-400 flex items-center justify-center mb-6">
            <Icon name="lucide:zap" class="w-8 h-8" />
          </div>
          <h3 class="text-2xl font-bold text-slate-900 dark:text-white mb-4">Distribusi Logis</h3>
          <p class="text-slate-600 dark:text-slate-400 leading-relaxed">
            Sistem eksekusi yang dijadwalkan secara sistematis (drip-feed) agar laju interaksi terbaca natural oleh mesin moderasi platform.
          </p>
        </article>

        <article class="p-8 md:p-10 rounded-3xl border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-slate-900/50 shadow-sm hover:shadow-lg transition-shadow text-center">
          <div class="mx-auto w-16 h-16 rounded-2xl bg-indigo-100 dark:bg-indigo-900/50 text-indigo-600 dark:text-indigo-400 flex items-center justify-center mb-6">
            <Icon name="lucide:users" class="w-8 h-8" />
          </div>
          <h3 class="text-2xl font-bold text-slate-900 dark:text-white mb-4">Layanan Eksekutif</h3>
          <p class="text-slate-600 dark:text-slate-400 leading-relaxed">
            Tim analis kami senantiasa siap memberikan konsultasi strategis dan pendampingan pasca-pembelian secara responsif.
          </p>
        </article>
      </div>
    </div>
  </section>

  <section class="py-16 md:py-24 bg-slate-50 dark:bg-[#0B1121]">
    <div class="container mx-auto px-6 max-w-5xl">
      <div class="bg-gradient-to-br from-blue-600 to-cyan-600 rounded-3xl p-10 md:p-16 text-center shadow-2xl relative overflow-hidden">
        <div class="absolute inset-0 bg-[radial-gradient(#ffffff_1px,transparent_1px)] [background-size:24px_24px] opacity-10"></div>
        
        <div class="relative z-10">
          <h2 class="text-3xl md:text-5xl font-bold text-white mb-6">Amankan Pangsa Pasar Anda Hari Ini</h2>
          <p class="text-lg md:text-xl text-blue-100 mb-10 max-w-2xl mx-auto leading-relaxed">
            Jangan biarkan penawaran brilian Anda terabaikan hanya karena kalah validasi sosial dari kompetitor. Mari bangun dominasi bersama kami.
          </p>
          
                              <div class="flex flex-col sm:flex-row justify-center gap-4">
            <a href="/layanan/" class="inline-flex items-center justify-center px-8 py-4 text-lg font-bold rounded-xl !bg-transparent !text-white border-2 !border-white/50 hover:!bg-white hover:!text-blue-600 transition-colors shadow-lg shadow-blue-900/20 !no-underline">
              Jelajahi Solusi Kami
            </a>
            
            <a href="https://wa.me/6289634740308" target="_blank" rel="noopener" class="inline-flex items-center justify-center px-8 py-4 text-lg font-bold rounded-xl !bg-white/10 !text-white hover:!bg-white hover:!text-blue-800 transition-colors border-2 !border-white/20 backdrop-blur-sm !no-underline">
              Mulai Konsultasi Gratis
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

</DefaultLayout>

