---
import DefaultLayout from '../layouts/DefaultLayout.astro'
import Hero from '../components/Hero.astro'
import DashboardArea from '../components/DashboardArea.astro' // Komponen baru kita

const title = "Dashboard Affiliate JasaLike";
const description = "Pantau komisi, riwayat transaksi, dan cairkan pendapatan Anda.";
const keywords = "dashboard affiliate, komisi jasalike, referral jasalike";

const dataHero = {
  tipe: "service",
  labelTeks: "Dashboard Affiliate",
  labelIcon: "lucide:layout-dashboard",
  judulUtama: 'Pantau <span class="text-blue-500">Komisi</span> dan Hasil Referral Anda',
  deskripsi: "Masukkan kode afiliasi Anda untuk melihat ringkasan transaksi, total komisi, dan mengajukan pencairan dana dengan mudah. <br class='hidden md:block mt-2' /> <span class='text-blue-400 font-semibold block mt-4'>✓ Data Komisi Real-Time &nbsp; ✓ Riwayat Transaksi Lengkap &nbsp; ✓ Pencairan Mudah</span>",
  teksTombol1: "Masuk Dashboard",
  linkTombol1: "#area-dashboard",
  teksTombol2: "Bantuan Dashboard",
  linkTombol2: "https://wa.me/6282120567299",
  gambarHero: "/image/Affiliate-Marketing.png"
};
---

<DefaultLayout
  title={title}
  description={description}
  keywords={keywords}
  image="/og/default/og-home.webp"
>
  <Hero {...dataHero} />

  <!-- Memanggil komponen interaktif dashboard -->
  <DashboardArea />

</DefaultLayout>
