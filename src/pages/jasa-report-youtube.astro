    "brand": {
      "@type": "Brand",
      "name": "JasaLike"
    },
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": 4.8,
      "bestRating": 5,
      "worstRating": 1,
      "ratingCount": 425
    },
    "offers": {
      "@type": "AggregateOffer",
      "lowPrice": 200000,
      "highPrice": 2000000,
      "priceCurrency": "IDR",
      "offerCount": 2
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Beranda",
        "item": "https://jasalike.com/"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": "Layanan",
        "item": "https://jasalike.com/direktori-layanan/"
      },
      {
        "@type": "ListItem",
        "position": 3,
        "name": "Jasa Report YouTube"
      }
    ]
  },
  {
