      }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Bagaimana teknis kerja jasa report YouTube dari JasaLike?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Kami menerima URL target, menganalisa jenis pelanggaran, lalu meluncurkan ribuan laporan dari jalur kredibel dengan kategori yang sesuai panduan komunitas YouTube. Tujuannya agar sistem memberi nilai lebih tinggi dan mempercepat proses peninjauan manual."
