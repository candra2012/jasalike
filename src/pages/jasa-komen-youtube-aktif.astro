      "@type": "AggregateRating",
      "ratingValue": 4.9,
      "bestRating": 5,
      "worstRating": 1,
      "ratingCount": 680
    },
    "offers": {
      "@type": "AggregateOffer",
      "lowPrice": 20000,
      "highPrice": 2000000,
      "priceCurrency": "IDR",
      "offerCount": 2
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Beranda",
