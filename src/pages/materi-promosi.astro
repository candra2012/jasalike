---
import DefaultLayout from "../layouts/DefaultLayout.astro";

import Hero from "../components/Hero.astro";
import MateriPromosi from "../components/MateriPromosi.astro";

// ==========================================
// SEO
// ==========================================

const title =
"Materi Promosi Affiliate JasaLike";

const description =
"Download seluruh materi promosi resmi Affiliate JasaLike mulai dari template Instagram, TikTok, Facebook, caption, hashtag, dan materi terbaru.";

const keywords =
"materi promosi affiliate, template promosi, affiliate jasalike, caption promosi, hashtag promosi";

// ==========================================
// HERO
// ==========================================

const dataHero = {

tipe:"service",

labelTeks:"Affiliate Center",

labelIcon:"lucide:folder-open",

judulUtama:
'Materi Promosi <span class="text-blue-500">Affiliate</span> <br class="hidden md:block"/> Siap Pakai',

deskripsi:
"Akses kumpulan materi promosi resmi JasaLike dalam satu tempat. Gunakan template, caption, dan hashtag yang telah disusun untuk memudahkan kampanye Anda. <br class='hidden md:block mt-2' /> <span class='text-blue-400 font-semibold block mt-4'>✓ Template Siap Pakai &nbsp; ✓ Caption & Hashtag Optimal &nbsp; ✓ Diperbarui Secara Berkala</span>",

teksTombol1:"Lihat Materi Promosi",

linkTombol1:"#materi",

teksTombol2:"Dashboard Affiliate",

linkTombol2:"/dashboard",

gambarHero:"/image/logo-hero-jasalike.png"

};
---

<DefaultLayout
title={title}
description={description}
keywords={keywords}
>

<Hero {...dataHero} />

<MateriPromosi />

</DefaultLayout>
