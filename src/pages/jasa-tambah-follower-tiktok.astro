    "description": "Layanan jasa tambah follower TikTok Indonesia untuk membantu meningkatkan kredibilitas akun, engagement, dan memperkuat branding bisnis.",
    "brand": {
      "@type": "Brand",
      "name": "JasaLike"
    },
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "4.9",
      "bestRating": "5",
      "worstRating": "1",
      "ratingCount": "1840"
    },
    "offers": {
      "@type": "AggregateOffer",
      "lowPrice": "200000",
      "highPrice": "2000000",
      "priceCurrency": "IDR",
      "offerCount": "4"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Beranda",
        "item": "https://jasalike.com/"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": "Layanan",
        "item": "https://jasalike.com/layanan/"
      },
      {
        "@type": "ListItem",
        "position": 3,
        "name": "Tambah Follower TikTok"
      }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Apakah layanan follower TikTok ini cocok untuk akun baru?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Ya, layanan ini sangat cocok digunakan untuk akun baru maupun akun yang sedang berkembang agar terlihat kredibel."
        }
      },
      {
        "@type": "Question",
