  ms3Teks: 'Sudah capek membuat konten dan rajin upload, tapi <strong class="text-blue-600 font-bold">postingan selalu sepi</strong> pengunjung.',
  ms4Teks: 'Susah membangun <strong class="text-blue-600 font-bold">otoritas brand</strong> yang berujung pada lambatnya konversi penjualan.'
};

const dataApaItu = {
  judulUtama: 'Lebih dari Sekadar <span class="text-blue-500">Angka di Layar</span>',
  deskripsiUtama: "JasaLike bukan sekadar penambah metrik pasif. Kami adalah pendorong awal agar akun Anda terlihat profesional, aktif, dan siap bersaing di sistem algoritma.",
  k1Judul: "Mata Uang Kepercayaan",
  k1Teks: "Secara psikologis, saat seseorang melihat postingan dengan ribuan <em>like</em>, otak mereka otomatis berasumsi bahwa konten atau produk tersebut bernilai, aman, dan telah disukai banyak orang (<strong class='text-blue-600'>Social Proof</strong>).",
  k2Judul: "Katalis Algoritma",
  k2Teks: "Seringkali konten yang bagus tenggelam karena akun masih baru. Kami hadir menyuntikkan interaksi awal agar sistem algoritma platform <strong class='text-blue-600'>terpancing menyebarkan konten</strong> Anda lebih luas."
};

const dataManfaat = {
  judulUtama: 'Manfaat Nyata yang <span class="text-blue-600">Anda Dapatkan</span>',
  deskripsiUtama: "Bukan sekadar kosmetik digital. Optimasi interaksi yang tepat akan membuka keran potensi organik akun media sosial Anda secara masif.",
  m1Judul: "Algoritma Membaik",
  m1Teks: "Sinyal interaksi yang tinggi memicu algoritma platform untuk merekomendasikan konten Anda ke audiens yang lebih luas secara organik.",
  m2Judul: "Meningkatkan Closing",
  m2Teks: "Akun jualan yang ramai interaksi secara psikologis menurunkan keraguan calon pembeli, sehingga konversi penjualan Anda meningkat.",
  m3Judul: "Efisiensi Waktu",
  m3Teks: "Anda tidak perlu stres menunggu interaksi pertama berhari-hari. Biarkan kami yang memicu keramaian di awal postingan Anda.",
  m4Judul: "Brand Authority",
  m4Teks: "Membangun citra bahwa brand atau diri Anda adalah pemain besar yang diminati dan diperhatikan oleh banyak netizen."
};

const dataMengapaMemilih = {
  judulUtama: 'Mengapa Memilih <span class="text-blue-400">JasaLike?</span>',
  deskripsiUtama: "Kami fokus melayani satu hal dengan sempurna. Ini alasan mengapa kreator dan pebisnis mempercayakan akunnya pada kami.",
  
  mk1Judul: "Sangat Fokus",
  mk1Teks: "Server kami khusus didedikasikan untuk memproses Like, menjamin stabilitas tanpa gangguan sistem lain.",
  
  mk2Judul: "Super Cepat",
  mk2Teks: "Pesanan masuk langsung dieksekusi instan oleh sistem. Tidak perlu menunggu antrean berhari-hari.",
  
  mk3Judul: "Privasi Terjaga",
  mk3Teks: "100% aman. Kami hanya membutuhkan link URL postingan, tanpa pernah meminta password akun Anda.",
  
  mk4Judul: "Harga Spesial",
  mk4Teks: "Sebagai penyedia layanan tangan pertama berskala besar, kami memberikan jaminan harga termurah.",
  
