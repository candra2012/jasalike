---
import DefaultLayout from '@layouts/DefaultLayout.astro'
import HomeSchemas from '@components/HomeSchemas.astro'
import OrganizationSchema from '@components/OrganizationSchema.astro'

import Hero from '@components/Hero.astro'
// 👇 INI DIA JAHITAN BARUNYA: Kita memanggil komponen PainPoints
import PainPoints from '@components/PainPoints.astro'
import Pengertian from '@components/Pengertian.astro'
import ApaItuJasaLike from '@components/ApaItuJasaLike.astro'
import Manfaat from '@components/Manfaat.astro'
import MengapaKami from '@components/MengapaKami.astro' 
import Testimonials from '@components/Testimonials.astro'
import MetodePembayaran from '@components/MetodePembayaran.astro'
import DaftarHarga from '@components/DaftarHarga.astro' 
import Feature from '@components/Feature.astro'
import Counter from '@components/Counter.astro'
import ContentMedia from '@components/ContentMedia.astro'
import { Accordion, AccordionItem } from 'accessible-astro-components'
import { Icon } from 'astro-icon/components'

// Data SEO murni spesialis Jasa Like (Halaman Utama)
const title = "Jasa Like Terpercaya | Tambah Like Media Sosial Cepat & Aman";
const description = "Jasa like media sosial terlengkap. Tingkatkan interaksi postingan dan video Anda di TikTok, Instagram, dan Facebook secara instan, aman, dan terpercaya.";
const keywords = "jasa like, beli like instagram, jasa like tiktok, jasa like facebook, jasalike, jasa like youtube, jasa like twitter, jasa like linkedin, jasa like asli, jasa like murah, tambah like";
---

<DefaultLayout title={title} description={description} keywords={keywords}>
  
  <script type="application/ld+json" slot="head">
    {
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "WebSite",
          "@id": "https://jasalike.com/#website",
          "url": "https://jasalike.com",
          "name": "Jasalike",
          "description": "Spesialis Jasa Like Sosial Media Terpercaya No. 1",
          "inLanguage": "id-ID"
        },
        {
          "@type": "LocalBusiness",
          "@id": "https://jasalike.com/#organization",
          "name": "Jasalike",
          "url": "https://jasalike.com",
          "logo": "https://jasalike.com/og-home.png",
          "image": "https://jasalike.com/og-home.png",
          "description": "Layanan spesialis jasa like sosial media terbaik dan terpercaya untuk Instagram, TikTok, Facebook, dan Twitter. Proses cepat, aman tanpa password, murah, dan bergaransi penuh.",
          "telephone": "+6289634740308",
          "priceRange": "RP",
          "address": {
            "@type": "PostalAddress",
            "addressCountry": "ID"
          },
          "knowsAbout": [
            "Jasa Like Instagram",
            "Jasa Like TikTok",
            "Jasa Like Facebook",
            "Jasa Like Twitter"
          ]
        }
      ]
    }
  </script>

  <Hero />

  <PainPoints />
   <Pengertian />
     <ApaItu />
    <Manfaat />
   <MengapaKami />
  <Testimonials />
  <MetodePembayaran />
  <DaftarHarga />

   <section id="faq" class="py-24 bg-slate-50 border-t border-slate-200">
    <div class="max-w-6xl mx-auto px-6">
      
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
        
        <div class="flex flex-col gap-6 lg:sticky lg:top-32">
          <h2 class="text-3xl md:text-4xl font-extrabold text-slate-900 tracking-tight">
            Pertanyaan Seputar <br/>
            <span class="text-blue-600">Layanan JasaLike</span>
          </h2>
          <p class="text-lg text-slate-600 leading-relaxed">
            Menemukan kendala atau butuh informasi lebih lanjut? Berikut adalah hal-hal yang paling sering ditanyakan oleh klien kami sebelum menggunakan layanan.
          </p>
          <div class="mt-4">
            <a
              class="inline-flex items-center gap-2 bg-green-500 hover:bg-green-600 text-white font-bold px-6 py-3.5 rounded-full shadow-lg shadow-green-500/30 hover:shadow-green-500/50 hover:-translate-y-1 transition-all duration-300"
              href="https://wa.me/6289634740308?text=Halo%20Admin,%20saya%20punya%20pertanyaan%20tentang%20JasaLike..."
              target="_blank"
              rel="noopener noreferrer"
            >
              <Icon name="lucide:message-circle" class="w-5 h-5" />
              Tanya Admin via WhatsApp
            </a>
          </div>
        </div>

        <div class="bg-white p-6 md:p-8 rounded-3xl shadow-sm border border-slate-100">
          <Accordion>
            <AccordionItem name="faq1" title="Apakah layanan optimasi media sosial ini terjamin keamanannya?" open>
              <p class="text-slate-600 leading-relaxed pt-2">
                Privasi Anda adalah prioritas absolut kami. Sistem kerja kami murni beroperasi dari luar menggunakan metode <strong>injeksi URL spesifik</strong> atau sekadar <em>drop link</em>. Kami sama sekali tidak membutuhkan akses internal kredensial login Anda, sehingga profil Anda bebas dari risiko <em>shadowban</em>. Seluruh histori kampanye klien juga dijaga kerahasiaannya dengan protokol ketat.
              </p>
            </AccordionItem>

            <AccordionItem name="faq2" title="Apakah suntikan interaksi yang masuk bersifat permanen (anti-drop)?">
              <p class="text-slate-600 leading-relaxed pt-2">
                Sistem distribusi <em>likes</em> kami dirancang semulus mungkin meniru jejak audiens organik, menjadikannya sangat stabil dan menempel kuat di konten Anda. Namun, jika sewaktu-waktu terjadi pembaruan ketat dari <em>bot algoritma</em> platform yang memicu fluktuasi, Anda sepenuhnya terlindungi oleh fasilitas <strong>Klaim Garansi Refill (Suntik Ulang)</strong> sesuai dengan ketentuan paket perlindungan yang dipilih.
              </p>
            </AccordionItem>

            <AccordionItem name="faq3" title="Berapa estimasi waktu pengerjaan untuk boost engagement konten?">
              <p class="text-slate-600 leading-relaxed pt-2">
                Sebagai spesialis di bidang eskalasi digital, infrastruktur kami disetting untuk merespons secara kilat. Begitu konfirmasi transaksi divalidasi, manuver eksekusi langsung dikerahkan. Normalnya, Anda sudah bisa menikmati lonjakan metrik notifikasi di perangkat Anda dalam rentang waktu <strong>1 sampai 5 jam</strong> kerja saja.
              </p>
            </AccordionItem>

            <AccordionItem name="faq4" title="Adakah batasan kuota minimal saat membeli jasa tambah like?">
              <p class="text-slate-600 leading-relaxed pt-2">
                Kami sangat adaptif dalam mengakomodasi berbagai level strategi digital Anda, mulai dari pancingan awal kreator pemula hingga dominasi <em>brand awareness</em> berskala masif. Anda bisa mengamankan <em>order</em> mulai dari <strong>100 impresi</strong> hingga pesanan puluhan ribu reaksi per tautan. Rincian kapasitas maksimum tiap platform dapat Anda telusuri langsung pada katalog harga resmi kami.
              </p>
            </AccordionItem>

            <AccordionItem name="faq5" title="Bisakah saya memecah paket interaksi untuk beberapa postingan sekaligus?">
              <p class="text-slate-600 leading-relaxed pt-2">
                Sangat memungkinkan! Layanan optimasi kami memberikan Anda kendali penuh. Sebagai ilustrasi, jika Anda meminang paket 1.000 reaksi, Anda berhak membaginya secara merata ke 10 video, <em>reels</em>, atau foto yang berbeda. Cukup setorkan daftar URL konten secara spesifik kepada tim admin kami saat tahap finalisasi pesanan.
              </p>
            </AccordionItem>
          </Accordion>
        </div>
      </div>
    </div>
  </section>
</DefaultLayout>
