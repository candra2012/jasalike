  judulUtama: 'Bangun Engagement Media Sosial yang <span class="text-blue-500">Lebih Kuat dan Berdampak</span>',
  deskripsi: "JasaLike hadir sebagai mitra strategis untuk mempercepat interaksi awal, membangun social proof, dan membuka peluang organik yang lebih luas di berbagai platform.<br class='hidden md:block mt-2' /> <span class='text-blue-400 font-semibold block mt-4'>✓ Interaksi Awal yang Stabil &nbsp; ✓ Tanpa Akses Akun &nbsp; ✓ Garansi Refill Tersedia</span>",
  teksTombol1: "Lihat Daftar Harga",
