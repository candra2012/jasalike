---
import DefaultLayout from '@layouts/DefaultLayout.astro'
import HomeSchemas from '@components/HomeSchemas.astro'
import OrganizationSchema from '@components/OrganizationSchema.astro'

import Hero from '@components/Hero.astro'
// 👇 INI DIA JAHITAN BARUNYA: Kita memanggil komponen PainPoints
import PainPoints from '@components/PainPoints.astro'
import Pengertian from '@components/Pengertian.astro'
import ApaItu from '@components/ApaItu.astro'
import Manfaat from '@components/Manfaat.astro'
import MengapaKami from '@components/MengapaKami.astro' 
import Testimonials from '@components/Testimonials.astro'
import MetodePembayaran from '@components/MetodePembayaran.astro'
import DaftarHarga from '@components/DaftarHarga.astro' 
import Feature from '@components/Feature.astro'
import Counter from '@components/Counter.astro'
import ContentMedia from '@components/ContentMedia.astro'
import { Accordion, AccordionItem } from 'accessible-astro-components'
import { Icon } from 'astro-icon/components'

// Data SEO murni spesialis Jasa Like (Halaman Utama)
const title = "Jasa Like Terpercaya | Tambah Like Media Sosial Cepat & Aman";
const description = "Jasa like media sosial terlengkap. Tingkatkan interaksi postingan dan video Anda di TikTok, Instagram, dan Facebook secara instan, aman, dan terpercaya.";
const keywords = "jasa like, beli like instagram, jasa like tiktok, jasa like facebook, jasalike, jasa like youtube, jasa like twitter, jasa like linkedin, jasa like asli, jasa like murah, tambah like";
---

<DefaultLayout title={title} description={description} keywords={keywords}>
  
  <script type="application/ld+json" slot="head">
    {
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "WebSite",
          "@id": "https://jasalike.com/#website",
          "url": "https://jasalike.com",
          "name": "Jasalike",
          "description": "Spesialis Jasa Like Sosial Media Terpercaya No. 1",
          "inLanguage": "id-ID"
        },
        {
          "@type": "LocalBusiness",
          "@id": "https://jasalike.com/#organization",
          "name": "Jasalike",
          "url": "https://jasalike.com",
          "logo": "https://jasalike.com/logo-jasalike.png",
          "image": "https://jasalike.com/images/og-image.png",
          "description": "Layanan spesialis jasa like sosial media terbaik dan terpercaya untuk Instagram, TikTok, Facebook, dan Twitter. Proses cepat, aman tanpa password, murah, dan bergaransi penuh.",
          "telephone": "+6289634740308",
          "priceRange": "RP",
          "address": {
            "@type": "PostalAddress",
            "addressCountry": "ID"
          },
          "knowsAbout": [
            "Jasa Like Instagram",
            "Jasa Like TikTok",
            "Jasa Like Facebook",
            "Jasa Like Twitter"
          ]
        }
      ]
    }
  </script>

  <Hero />

  <PainPoints />
   <Pengertian />
     <ApaItu />
    <Manfaat />
   <MengapaKami />
  <Testimonials />
  <MetodePembayaran />
  <DaftarHarga />

   <section id="faq" class="py-24 bg-slate-50 border-t border-slate-200">
    <div class="max-w-6xl mx-auto px-6">
      
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
        
        <div class="flex flex-col gap-6 lg:sticky lg:top-32">
          <h2 class="text-3xl md:text-4xl font-extrabold text-slate-900 tracking-tight">
            Pertanyaan Seputar <br/>
            <span class="text-blue-600">Layanan JasaLike</span>
          </h2>
          <p class="text-lg text-slate-600 leading-relaxed">
            Menemukan kendala atau butuh informasi lebih lanjut? Berikut adalah hal-hal yang paling sering ditanyakan oleh klien kami sebelum menggunakan layanan.
          </p>
          <div class="mt-4">
            <a
              class="inline-flex items-center gap-2 bg-green-500 hover:bg-green-600 text-white font-bold px-6 py-3.5 rounded-full shadow-lg shadow-green-500/30 hover:shadow-green-500/50 hover:-translate-y-1 transition-all duration-300"
              href="https://wa.me/6289634740308?text=Halo%20Admin,%20saya%20punya%20pertanyaan%20tentang%20JasaLike..."
              target="_blank"
              rel="noopener noreferrer"
            >
              <Icon name="lucide:message-circle" class="w-5 h-5" />
              Tanya Admin via WhatsApp
            </a>
          </div>
        </div>

        <div class="bg-white p-6 md:p-8 rounded-3xl shadow-sm border border-slate-100">
          <Accordion>
            <AccordionItem name="faq1" title="Apakah aman? Bagaimana privasi data saya?" open>
              <p class="text-slate-600 leading-relaxed pt-2">
                100% Aman. Kami <strong>tidak pernah meminta password</strong> akun media sosial Anda. Pengerjaan murni menggunakan tautan (URL) postingan Anda. Selain itu, riwayat pesanan dan identitas klien kami jaga kerahasiaannya dengan ketat.
              </p>
            </AccordionItem>

            <AccordionItem name="faq2" title="Apakah like-nya bisa hilang (drop)?">
              <p class="text-slate-600 leading-relaxed pt-2">
                Layanan organik kami sangat stabil dan permanen. Sedangkan untuk layanan bot kualitas tinggi, sangat jarang mengalami <em>drop</em> drastis. Kami juga memberikan <strong>Garansi Refill</strong> pada paket-paket tertentu jika sewaktu-waktu ada penurunan jumlah like.
              </p>
            </AccordionItem>

            <AccordionItem name="faq3" title="Berapa lama proses masuknya like?">
              <p class="text-slate-600 leading-relaxed pt-2">
                Karena kami adalah spesialis jasa like, server kami dirancang untuk eksekusi yang super cepat. Rata-rata orderan akan mulai diproses dan like masuk ke postingan Anda dalam estimasi waktu <strong>1 hingga 5 jam</strong> setelah order dikonfirmasi admin.
              </p>
            </AccordionItem>

            <AccordionItem name="faq4" title="Berapa minimal jumlah pesanan like?">
              <p class="text-slate-600 leading-relaxed pt-2">
                Kami siap melayani kebutuhan dari skala kecil hingga masif. Anda bisa memesan mulai dari <strong>100 like</strong> hingga puluhan ribu like per postingannya. Info detail kuota per platform bisa dicek pada spreadsheet daftar harga kami.
              </p>
            </AccordionItem>

            <AccordionItem name="faq5" title="Apakah bisa membagi order like ke beberapa foto?">
              <p class="text-slate-600 leading-relaxed pt-2">
                Tentu bisa! Kami punya fleksibilitas. Misalnya Anda order paket 100 Like, Anda bisa memintanya untuk disebar ke 10 foto berbeda (masing-masing mendapat 10 Like). Silakan infokan tautan lengkapnya ke admin saat pemesanan.
              </p>
            </AccordionItem>
          </Accordion>
        </div>

      </div>
    </div>
  </section>
</DefaultLayout>
