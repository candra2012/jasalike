---
import DefaultLayout from '@layouts/DefaultLayout.astro'
import HomeSchemas from '@components/HomeSchemas.astro'
import OrganizationSchema from '@components/OrganizationSchema.astro'

import Hero from '@components/Hero.astro'
import MasalahJasaLike from '@components/MasalahJasaLike.astro'
import ApaItuJasaLike from '@components/ApaItuJasaLike.astro'
import ManfaatJasaLike from '@components/ManfaatJasaLike.astro'
import MengapaMemilihJasaLike from '@components/MengapaMemilihJasaLike.astro' 
import Testimonials from '@components/Testimonials.astro'
import FaqJasaLike from '@components/FaqJasaLike.astro'
import MetodePembayaran from '@components/MetodePembayaran.astro'
import DaftarHarga from '@components/DaftarHarga.astro' 
import CaraOrder from '@components/CaraOrder.astro'


// ==========================================
// 1. DATA SEO
// ==========================================
const title = "Jasa Like Terpercaya | Tambah Like Media Sosial Cepat & Aman";
const description = "Jasa like media sosial terlengkap. Tingkatkan interaksi postingan dan video Anda di TikTok, Instagram, dan Facebook secara instan, aman, dan terpercaya.";
const keywords = "jasa like, jasa buzzer, jasa like indonesia, jasa tambah like, jasa like terpercaya";

// ==========================================
// 2. DATA KONTEN HALAMAN (FRONTMATTER)
// ==========================================

const dataHero = {
