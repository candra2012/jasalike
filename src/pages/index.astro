---

<DefaultLayout title={title} description={description} keywords={keywords}>
  
  <script type="application/ld+json" slot="head">
    {
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "WebSite",
          "@id": "https://jasalike.com/#website",
          "url": "https://jasalike.com",
          "name": "Jasalike",
          "description": "Spesialis Jasa Like Sosial Media Terpercaya No. 1",
          "inLanguage": "id-ID"
        }
      ]
    }
  </script>

  <Hero {...dataHero} />
  
  <MasalahJasaLike {...dataMasalah} />
  
  <ApaItuJasaLike {...dataApaItu} />

  <ManfaatJasaLike {...dataManfaat} />

  <MengapaMemilihJasaLike {...dataMengapaMemilih} />
  
  <Testimonials />
  
  <MetodePembayaran />
  
  <DaftarHarga />

  <CaraOrder />
  
  <FaqJasaLike {...dataFaq} />

</DefaultLayout>

