  mk5Judul: "Bergaransi",
  mk5Teks: "Layanan kami dilengkapi garansi isi ulang (refill) otomatis apabila terjadi penurunan jumlah (drop).",
  
  mk6Judul: "Support 24/7",
  mk6Teks: "Tim layanan pelanggan kami selalu siap sedia merespons dan membantu Anda kapan pun dibutuhkan."
};


const dataFaq = {
  judulUtama: 'Pertanyaan Seputar <br/> <span class="text-blue-600">Layanan JasaLike</span>',
  deskripsiUtama: "Menemukan kendala atau butuh informasi lebih lanjut? Berikut adalah hal-hal yang paling sering ditanyakan oleh klien kami sebelum menggunakan layanan.",
  linkWhatsapp: "https://wa.me/6289634740308?text=Halo%20Admin,%20saya%20punya%20pertanyaan%20tentang%20JasaLike...",
  faq1Judul: "Apakah layanan optimasi media sosial ini terjamin keamanannya?",
