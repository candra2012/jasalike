      "worstRating": "1",
      "reviewCount": 1112
    },
    "offers": {
      "@type": "AggregateOffer",
      "lowPrice": 20000,
      "highPrice": 2000000,
      "priceCurrency": "IDR",
      "offerCount": 4
    },
    "image": "https://jasalike.com/image/jasa-like-facebook-organik-100like.png",
    "brand": {
      "@type": "Brand",
      "name": "JasaLike"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
