---

<DefaultLayout title={title} description={description} keywords={keywords}>

  <Fragment slot="head">
    <script type="application/ld+json">
      [
        {
          "@context": "https://schema.org/",
          "@type": "Product",
          "name": "Jasa Like YouTube Terpercaya",
          "image": "https://jasalike.com/image/harga-paket-100like-youtube.png",
          "description": "Layanan optimasi SEO video YouTube dengan distribusi interaksi natural. Membantu meningkatkan peringkat penelusuran, membangun otoritas channel, dan mempercepat pertumbuhan metrik secara aman.",
          "brand": {
            "@type": "Brand",
            "name": "JasaLike"
          },
          "aggregateRating": {
            "@type": "AggregateRating",
            "ratingValue": "4.9",
            "bestRating": "5",
            "worstRating": "1",
            "ratingCount": "1350"
          },
          "offers": {
            "@type": "AggregateOffer",
            "lowPrice": "200000",
            "highPrice": "2000000",
            "priceCurrency": "IDR",
            "offerCount": "4"
          }
        },
        {
          "@context": "https://schema.org",
          "@type": "BreadcrumbList",
          "itemListElement": [
            {
              "@type": "ListItem",
              "position": 1,
              "name": "Beranda",
              "item": "https://jasalike.com/"
            },
            {
              "@type": "ListItem",
              "position": 2,
              "name": "Layanan",
              "item": "https://jasalike.com/layanan/"
            },
            {
              "@type": "ListItem",
              "position": 3,
              "name": "Like YouTube"
            }
          ]
        },
        {
          "@context": "https://schema.org",
          "@type": "FAQPage",
          "mainEntity": [
            {
              "@type": "Question",
              "name": "Apakah aman untuk monetisasi channel YouTube?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Sangat aman. Sistem kami mendistribusikan interaksi secara natural sehingga tidak bertentangan dengan pedoman komunitas maupun syarat monetisasi YouTube Partner Program."
              }
            },
            {
              "@type": "Question",
              "name": "Berapa lama estimasi penyelesaiannya?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Kecepatan distribusi bergantung pada besaran paket. Umumnya berjalan secara bertahap (drip-feed) dalam hitungan jam hingga beberapa hari demi menjaga pola organik."
              }
            },
            {
              "@type": "Question",
              "name": "Apakah video YouTube Shorts juga bisa diproses?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Tentu bisa. Layanan kami mendukung semua format tayangan, baik video durasi panjang (reguler), podcast, maupun YouTube Shorts."
              }
            },
            {
              "@type": "Question",
              "name": "Data apa saja yang perlu saya siapkan?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Kami mengutamakan privasi Anda. Cukup lampirkan tautan (URL) publik dari video yang ingin dioptimasi. Seluruh prosedur berjalan secara eksternal."
              }
            },
            {
              "@type": "Question",
              "name": "Bagaimana jika jumlah apresiasinya menurun setelah proses selesai?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Anda mendapatkan jaminan proteksi penuh. Kami menyediakan asuransi pengisian kembali (refill) gratis untuk memastikan metrik video Anda tetap stabil."
              }
            },
            {
              "@type": "Question",
              "name": "Apakah layanan ini membantu algoritma rekomendasi YouTube?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Sangat membantu. Akumulasi interaksi yang positif di awal penayangan adalah salah satu indikator kuat bagi algoritma untuk mempromosikan video Anda ke audiens yang lebih luas."
              }
            }
          ]
        }
      ]
    </script>
  </Fragment>

  <Hero {...dataHero} />
  <MasalahJasaLike {...dataMasalah} />
  <ApaItuJasaLike {...dataApaItu} />
  <ManfaatJasaLike {...dataManfaat} />
  <MengapaMemilihJasaLike {...dataMengapaMemilih} />
  <Solusi {...dataSolusi} />
  <CaraOrder {...dataCaraOrder} />
  
  <DaftarHarga />
  <HargaPaket {...dataHargaPaket} />
  <Testimonials />
  <MetodePembayaran />
  
  <FaqJasaLike {...dataFaq} />

</DefaultLayout>

