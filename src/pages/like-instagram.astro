<DefaultLayout title={title} description={description} keywords={keywords}>

  <Fragment slot="head">
    <script type="application/ld+json">
      [
        {
          "@context": "https://schema.org/",
          "@type": "Product",
          "name": "Jasa Like Instagram Terpercaya Murah Dan Cepat",
          "image": "https://jasalike.com/image/jasa-like-instagram-organik-100like.png",
          "description": "Layanan optimasi penambah like Instagram secara instan, aman, dan tanpa password. Bergaransi penuh untuk meningkatkan interaksi dan masuk Explore.",
          "brand": {
            "@type": "Brand",
            "name": "JasaLike"
          },
          "aggregateRating": {
            "@type": "AggregateRating",
            "ratingValue": "4.9",
            "bestRating": "5",
            "worstRating": "1",
            "ratingCount": "1250"
          },
          "offers": {
            "@type": "AggregateOffer",
            "lowPrice": "200000",
            "highPrice": "2000000",
            "priceCurrency": "IDR",
            "offerCount": "4"
          }
        },
        {
          "@context": "https://schema.org",
          "@type": "BreadcrumbList",
          "itemListElement": [
            {
              "@type": "ListItem",
              "position": 1,
              "name": "Beranda",
              "item": "https://jasalike.com/"
            },
            {
              "@type": "ListItem",
              "position": 2,
              "name": "Layanan",
              "item": "https://jasalike.com/layanan/"
            },
            {
              "@type": "ListItem",
              "position": 3,
              "name": "Like Instagram"
            }
          ]
        }
      ]
    </script>
