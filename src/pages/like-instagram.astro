---
// src/pages/like-instagram.astro
import DefaultLayout from '../layouts/DefaultLayout.astro'
import { Icon } from 'astro-icon/components'
import Testimonials from '../components/Testimonials.astro'
import DaftarHarga from '../components/DaftarHarga.astro'
import MetodePembayaran from '../components/MetodePembayaran.astro'
---

<DefaultLayout title="Jasa Like Instagram Terpercaya & Aman - JasaLike">
  
  <section class="relative pt-32 pb-24 lg:pt-0 lg:pb-0 bg-slate-950 overflow-hidden min-h-[90vh] flex items-center">
    <div class="absolute inset-0 z-0">
      <img src="/image/hero-jasalike.png" alt="Background Jasa Like Instagram" class="w-full h-full object-cover opacity-50 block" />
      <div class="absolute inset-0 bg-gradient-to-b from-slate-950 via-transparent to-slate-950/90"></div>
      <div class="absolute top-1/4 left-0 w-96 h-96 bg-blue-600 rounded-full blur-[150px] opacity-20"></div>
    </div>

    <div class="relative z-10 container mx-auto px-6 text-center max-w-5xl animate-fade-in-up mt-20 lg:mt-0">
      <span class="inline-flex items-center gap-2 bg-blue-900/40 border border-blue-700/50 text-blue-300 px-4 py-1.5 rounded-full text-sm font-medium mb-8">
        <Icon name="lucide:instagram" class="w-4 h-4" />
        Layanan Instagram Premium
      </span>
      <h1 class="text-4xl md:text-6xl lg:text-7xl font-extrabold !text-white leading-[1.1] mb-8 tracking-tight">
        Jasa Like Instagram <br class="hidden md:block" /> <span class="text-blue-500">Terpercaya & Instan</span>
      </h1>
      <p class="text-lg md:text-xl text-slate-200 max-w-3xl mx-auto leading-relaxed">
        Tingkatkan kredibilitas dan visibilitas profil Instagram Anda seketika. Layanan optimasi kami dirancang khusus untuk memicu algoritma <strong class="text-white">Explore</strong>, membangun kepercayaan audiens <em class="text-blue-300 not-italic">(Social Proof)</em>, dan memperkuat pesona bisnis Anda di dunia digital. <br class="hidden md:block mt-2" />
        <span class="text-blue-400 font-semibold block mt-4">✓ 100% Aman & Natural &nbsp; ✓ Tanpa Perlu Password &nbsp; ✓ Bergaransi Penuh</span>
      </p>
    </div>
  </section>

  <section class="py-24 bg-slate-900 border-t border-slate-800 overflow-hidden">
    <div class="max-w-6xl mx-auto px-6 grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
      <div class="order-2 lg:order-1 reveal-left">
        <div class="relative rounded-3xl overflow-hidden border border-slate-700 shadow-2xl">
          <img src="/image/hero-jasalike.png" alt="Ilustrasi Jasa Like" class="w-full h-auto object-cover opacity-80 hover:opacity-100 transition-opacity" />
        </div>
      </div>
      <div class="order-1 lg:order-2 reveal-right">
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-6">Apa Itu Jasa Like Instagram?</h2>
        <p class="text-slate-400 text-lg leading-relaxed mb-6">
          Layanan ini adalah solusi cerdas untuk memberikan <strong>dorongan interaksi (engagement)</strong> pada postingan feed maupun reels Anda. Di tengah ketatnya algoritma Instagram, postingan dengan like tinggi akan lebih mudah direkomendasikan.
        </p>
        <ul class="space-y-4">
          <li class="flex items-center gap-3 text-slate-300 font-medium">
            <Icon name="lucide:check-circle-2" class="w-6 h-6 text-blue-500 shrink-0" />
            Meningkatkan peluang masuk Explore Page
          </li>
          <li class="flex items-center gap-3 text-slate-300 font-medium">
            <Icon name="lucide:check-circle-2" class="w-6 h-6 text-blue-500 shrink-0" />
            Membangun Social Proof untuk bisnis online
          </li>
          <li class="flex items-center gap-3 text-slate-300 font-medium">
            <Icon name="lucide:check-circle-2" class="w-6 h-6 text-blue-500 shrink-0" />
            Interaksi berkualitas dan terlihat natural
          </li>
        </ul>
      </div>
    </div>
  </section>

  <section class="py-24 bg-slate-950 overflow-hidden">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-16 reveal-up">
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">Masalah Kreator & Pebisnis</h2>
        <p class="text-slate-400 text-lg">Hambatan yang sering membuat akun sulit berkembang.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="bg-slate-900 p-8 rounded-3xl border border-slate-800 hover:border-blue-500/50 transition-colors reveal-up">
          <div class="w-14 h-14 bg-red-500/10 text-red-500 rounded-2xl flex items-center justify-center mb-6">
            <Icon name="lucide:trending-down" class="w-7 h-7" />
          </div>
          <h3 class="text-xl font-bold text-white mb-3">Sepi Interaksi</h3>
          <p class="text-slate-400 leading-relaxed">Konten bagus tapi tidak ada yang merespons karena belum punya audiens awal.</p>
        </div>
        <div class="bg-slate-900 p-8 rounded-3xl border border-slate-800 hover:border-blue-500/50 transition-colors reveal-up delay-100">
          <div class="w-14 h-14 bg-orange-500/10 text-orange-500 rounded-2xl flex items-center justify-center mb-6">
            <Icon name="lucide:user-x" class="w-7 h-7" />
          </div>
          <h3 class="text-xl font-bold text-white mb-3">Krisis Kepercayaan</h3>
          <p class="text-slate-400 leading-relaxed">Calon pembeli ragu bertransaksi karena postingan produk minim like.</p>
        </div>
        <div class="bg-slate-900 p-8 rounded-3xl border border-slate-800 hover:border-blue-500/50 transition-colors reveal-up delay-200">
          <div class="w-14 h-14 bg-purple-500/10 text-purple-500 rounded-2xl flex items-center justify-center mb-6">
            <Icon name="lucide:compass" class="w-7 h-7" />
          </div>
          <h3 class="text-xl font-bold text-white mb-3">Gagal Explore</h3>
          <p class="text-slate-400 leading-relaxed">Algoritma mengabaikan postingan karena kurang momentum interaksi di awal.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-24 bg-blue-900 text-white overflow-hidden relative">
    <div class="absolute inset-0 bg-[url('/image/hero-jasalike.png')] opacity-10 bg-cover bg-center mix-blend-overlay"></div>
    <div class="max-w-6xl mx-auto px-6 relative z-10 text-center">
      <h2 class="text-3xl md:text-4xl font-bold mb-16 reveal-up">Manfaat Menggunakan Jasa Kami</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
        <div class="reveal-up">
          <Icon name="lucide:shield-check" class="w-12 h-12 text-blue-300 mx-auto mb-4" />
          <h4 class="text-xl font-bold mb-2">Social Proof</h4>
          <p class="text-blue-200 text-sm">Akun terlihat jauh lebih kredibel & profesional.</p>
        </div>
        <div class="reveal-up delay-100">
          <Icon name="lucide:zap" class="w-12 h-12 text-blue-300 mx-auto mb-4" />
          <h4 class="text-xl font-bold mb-2">Algoritma Aktif</h4>
          <p class="text-blue-200 text-sm">Memicu Instagram untuk menyebarkan konten Anda.</p>
        </div>
        <div class="reveal-up delay-200">
          <Icon name="lucide:users" class="w-12 h-12 text-blue-300 mx-auto mb-4" />
          <h4 class="text-xl font-bold mb-2">Pancingan Organik</h4>
          <p class="text-blue-200 text-sm">Orang lebih suka nge-like post yang sudah banyak like-nya.</p>
        </div>
        <div class="reveal-up delay-300">
          <Icon name="lucide:briefcase" class="w-12 h-12 text-blue-300 mx-auto mb-4" />
          <h4 class="text-xl font-bold mb-2">Brand Awareness</h4>
          <p class="text-blue-200 text-sm">Memperkuat identitas brand di mata kompetitor.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-24 bg-slate-900 border-b border-slate-800 overflow-hidden">
    <div class="max-w-6xl mx-auto px-6 text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-16 reveal-up">Mengapa Memilih JasaLike.com?</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
        <div class="reveal-up">
          <div class="bg-slate-800 w-20 h-20 mx-auto rounded-full flex items-center justify-center mb-6">
            <Icon name="lucide:lock" class="w-10 h-10 text-emerald-400" />
          </div>
          <h3 class="text-xl font-bold text-white mb-3">100% Aman</h3>
          <p class="text-slate-400">Pengerjaan hanya butuh link / URL postingan. Kami tidak pernah meminta password Anda.</p>
        </div>
        <div class="reveal-up delay-100">
          <div class="bg-slate-800 w-20 h-20 mx-auto rounded-full flex items-center justify-center mb-6">
            <Icon name="lucide:timer" class="w-10 h-10 text-blue-400" />
          </div>
          <h3 class="text-xl font-bold text-white mb-3">Proses Super Cepat</h3>
          <p class="text-slate-400">Orderan langsung dieksekusi oleh server segera setelah pembayaran dikonfirmasi.</p>
        </div>
        <div class="reveal-up delay-200">
          <div class="bg-slate-800 w-20 h-20 mx-auto rounded-full flex items-center justify-center mb-6">
            <Icon name="lucide:refresh-cw" class="w-10 h-10 text-purple-400" />
          </div>
          <h3 class="text-xl font-bold text-white mb-3">Garansi Layanan</h3>
          <p class="text-slate-400">Beberapa paket kami dilengkapi dengan fitur garansi isi ulang (refill) jika terjadi drop.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-24 bg-slate-950 overflow-hidden">
    <div class="max-w-5xl mx-auto px-6">
      <div class="text-center mb-16 reveal-up">
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">Cara Kerja Kami</h2>
        <p class="text-slate-400">Proses sederhana untuk hasil yang maksimal.</p>
      </div>
      <div class="flex flex-col md:flex-row justify-between gap-8 relative">
        <div class="hidden md:block absolute top-12 left-[10%] right-[10%] h-0.5 bg-slate-800 reveal-up"></div>
        
        <div class="relative z-10 bg-slate-900 p-8 rounded-3xl border border-slate-800 flex-1 text-center reveal-up">
          <div class="w-12 h-12 bg-blue-600 text-white font-bold text-xl rounded-full flex items-center justify-center mx-auto mb-6 ring-8 ring-slate-950">1</div>
          <h4 class="text-lg font-bold text-white mb-2">Pilih Paket</h4>
          <p class="text-slate-400 text-sm">Sesuaikan jumlah like dengan target strategi konten Anda.</p>
        </div>
        
        <div class="relative z-10 bg-slate-900 p-8 rounded-3xl border border-slate-800 flex-1 text-center reveal-up delay-100">
          <div class="w-12 h-12 bg-blue-600 text-white font-bold text-xl rounded-full flex items-center justify-center mx-auto mb-6 ring-8 ring-slate-950">2</div>
          <h4 class="text-lg font-bold text-white mb-2">Kirim Tautan & Bayar</h4>
          <p class="text-slate-400 text-sm">Berikan link foto/video, lalu selesaikan pembayaran via bank/e-wallet.</p>
        </div>

        <div class="relative z-10 bg-slate-900 p-8 rounded-3xl border border-slate-800 flex-1 text-center reveal-up delay-200">
          <div class="w-12 h-12 bg-blue-600 text-white font-bold text-xl rounded-full flex items-center justify-center mx-auto mb-6 ring-8 ring-slate-950">3</div>
          <h4 class="text-lg font-bold text-white mb-2">Proses & Selesai</h4>
          <p class="text-slate-400 text-sm">Santai dan lihat notifikasi like di aplikasi Instagram mulai berdatangan.</p>
        </div>
      </div>
    </div>
  </section>

  <section id="harga" class="py-24 bg-slate-900 border-y border-slate-800 overflow-hidden">
    <div class="max-w-4xl mx-auto px-6">
      <div class="text-center mb-16 reveal-up">
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">Pilihan Paket Favorit</h2>
        <p class="text-slate-400">Mulai tingkatkan engagement Instagram Anda hari ini.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div class="reveal-up bg-slate-950 rounded-[2rem] border border-slate-800 overflow-hidden flex flex-col hover:border-blue-500/50 transition-colors shadow-xl">
          <div class="h-48 bg-slate-800 relative">
            <img src="/image/hero-jasalike.png" alt="Paket 100 Like" class="w-full h-full object-cover opacity-60" />
            <div class="absolute inset-0 bg-gradient-to-t from-slate-950 to-transparent"></div>
          </div>
          <div class="p-8 pt-0 flex-1 flex flex-col">
            <h3 class="text-2xl font-bold text-white mb-6">Paket 100 Like Instagram</h3>
            <ul class="space-y-4 mb-8 flex-1">
              <li class="flex items-start gap-3 text-slate-300">
                <span class="text-blue-500 text-xl leading-none mt-1">●</span>
                <span class="text-lg">Proses Pengerjaan Cepat</span>
              </li>
              <li class="flex items-start gap-3 text-slate-300">
                <span class="text-blue-500 text-xl leading-none mt-1">●</span>
                <span class="text-lg">Aman 100% Tanpa Password</span>
              </li>
              <li class="flex items-start gap-3 text-slate-300">
                <span class="text-blue-500 text-xl leading-none mt-1">●</span>
                <span class="text-lg">Cocok untuk Akun Personal</span>
              </li>
            </ul>
            <a href="https://wa.me/6289634740308?text=Halo%20Admin%2C%20saya%20mau%20pesan%20Paket%20100%20Like%20Instagram" class="block w-full text-center bg-blue-600 hover:bg-blue-700 !text-white font-bold py-4 rounded-xl transition-colors">
              Pesan Sekarang
            </a>
          </div>
        </div>

        <div class="reveal-up delay-200 bg-slate-950 rounded-[2rem] border border-blue-500/30 overflow-hidden flex flex-col relative hover:border-blue-500 transition-colors shadow-2xl shadow-blue-900/20">
          <div class="absolute top-4 right-4 bg-blue-600 text-white text-xs font-bold px-3 py-1 rounded-full z-20">TERLARIS</div>
          <div class="h-48 bg-slate-800 relative">
            <img src="/image/hero-jasalike.png" alt="Paket 500 Like" class="w-full h-full object-cover opacity-60" />
            <div class="absolute inset-0 bg-gradient-to-t from-slate-950 to-transparent"></div>
          </div>
          <div class="p-8 pt-0 flex-1 flex flex-col">
            <h3 class="text-2xl font-bold text-white mb-6">Paket 500 Like Instagram</h3>
            <ul class="space-y-4 mb-8 flex-1">
              <li class="flex items-start gap-3 text-slate-300">
                <span class="text-blue-500 text-xl leading-none mt-1">●</span>
                <span class="text-lg">Masuk Secara Natural</span>
              </li>
              <li class="flex items-start gap-3 text-slate-300">
                <span class="text-blue-500 text-xl leading-none mt-1">●</span>
                <span class="text-lg">Aman 100% Tanpa Password</span>
              </li>
              <li class="flex items-start gap-3 text-slate-300">
                <span class="text-blue-500 text-xl leading-none mt-1">●</span>
                <span class="text-lg">Bagus Untuk Bisnis / Brand</span>
              </li>
            </ul>
            <a href="https://wa.me/6289634740308?text=Halo%20Admin%2C%20saya%20mau%20pesan%20Paket%20500%20Like%20Instagram" class="block w-full text-center bg-blue-600 hover:bg-blue-700 !text-white font-bold py-4 rounded-xl transition-colors">
              Pesan Sekarang
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="bg-white">
    <Testimonials />
  </div>
  <DaftarHarga />
  <MetodePembayaran />

</DefaultLayout>

<style>
  /* Hero Animasi Load */
  .animate-fade-in-up {
    animation: fadeInUp 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* Animasi Scroll: Sembunyi Dulu */
  .reveal-left { opacity: 0; transform: translateX(-50px); transition: all 0.8s ease-out; }
  .reveal-right { opacity: 0; transform: translateX(50px); transition: all 0.8s ease-out; }
  .reveal-up { opacity: 0; transform: translateY(50px); transition: all 0.8s ease-out; }
  
  /* Delay untuk efek berurutan */
  .delay-100 { transition-delay: 100ms; }
  .delay-200 { transition-delay: 200ms; }
  .delay-300 { transition-delay: 300ms; }

  /* Class aktif yang disuntikkan oleh JavaScript pas di-scroll */
  .reveal-left.is-visible,
  .reveal-right.is-visible,
  .reveal-up.is-visible {
    opacity: 1;
    transform: translate(0);
  }
</style>

<script>
  // Script untuk memantau kapan elemen masuk ke layar
  document.addEventListener('DOMContentLoaded', () => {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
        }
      });
    }, {
      threshold: 0.1 // Memicu animasi ketika 10% elemen sudah terlihat di layar
    });

    // Minta script untuk mengawasi semua elemen yang punya class reveal
    document.querySelectorAll('.reveal-up, .reveal-left, .reveal-right').forEach((el) => {
      observer.observe(el);
    });
  });
</script>
