---
// src/pages/like-instagram.astro
import DefaultLayout from '@layouts/DefaultLayout.astro'
---

<DefaultLayout title="Jasa Optimasi Like Instagram Profesional | Interaksi Real & Alami">

  <section class="container my-24 text-center">
    <div class="inline-flex items-center gap-2 rounded-full px-4 py-1 text-sm font-medium bg-gradient-to-r from-purple-100 to-pink-100 text-purple-800 dark:from-purple-900/40 dark:to-pink-900/40 dark:text-purple-100 border border-purple-200/60 dark:border-purple-800/60 mb-6">
      Edukasi & Strategi Instagram • Optimasi Real & Alami
    </div>

    <h1 class="text-6xl md:text-8xl font-bold tracking-tight mb-8">
      Optimasi Like Instagram untuk <br class="hidden md:block" />
      <span class="bg-gradient-to-r from-purple-600 to-pink-600 bg-clip-text text-transparent">Performa Maksimal, Aman & Natural</span>
    </h1>
    
    <p class="text-2xl opacity-80 max-w-4xl mx-auto leading-relaxed">
      Tingkatkan interaksi Feed, Reels, dan Carousel Anda melalui pendekatan manajemen interaksi yang terukur. Bangun otoritas akun, perkuat kredibilitas di mata audiens, dan optimalkan konten Anda agar selaras dengan algoritma halaman Explore menggunakan akun real berkualitas.
    </p>

    <div class="mt-12 flex justify-center gap-4">
        <a href="#layanan-spesifik" class="button px-8 py-4 text-lg">Pilihan Layanan Optimasi</a>
        <a href="https://wa.me/6289634740308?text=Halo%20Admin%20Jasalike,%20saya%20mau%20konsultasi%20mengenai%20strategi%20optimasi%20like%20Instagram." class="button color-secondary px-8 py-4 text-lg">Konsultasi Strategi</a>
    </div>
  </section>

  <section class="container my-32">
    <h2 class="text-4xl md:text-5xl font-semibold mb-12 text-center">Mengapa Metrik Like Instagram Sangat Penting bagi Algoritma?</h2>
    <div class="grid gap-8 sm:grid-cols-2">
      {[
        { title: 'Sinyal Distribusi Halaman Explore', desc: 'Dalam ekosistem Instagram, jumlah interaksi awal seperti like merupakan sinyal kuat bagi algoritma. Rasio interaksi yang sehat di menit-menit awal membantu mendistribusikan konten Anda ke audiens yang lebih luas lewat halaman Explore.' },
        { title: 'Validasi Sosial & Kepercayaan', desc: 'Secara psikologis pemasaran, audiens baru cenderung melakukan validasi instan berdasarkan interaksi yang terlihat (Social Proof). Akun bisnis dengan tingkat interaksi yang baik terbukti memiliki tingkat kepercayaan jauh lebih tinggi.' },
        { title: 'Mendukung Konversi Penjualan', desc: 'Bagi akun katalog produk atau pelaku bisnis digital, visual konten yang didukung interaksi stabil akan membangun keyakinan konsumen, meminimalkan keraguan, dan mempercepat keputusan pembelian.' },
        { title: 'Memicu Interaksi Organik Lanjutan', desc: 'Konten yang terlihat aktif secara statistik memancing minat audiens organik untuk berhenti scrolling, meluangkan waktu membaca informasi di caption, hingga ikut berkomentar dan membagikan ulang.' },
      ].map((b) => (
        <article class="p-8 rounded-3xl border bg-gradient-to-br from-purple-50 to-pink-50 dark:from-neutral-900/60 dark:to-neutral-900/20 border-purple-100 dark:border-neutral-800 shadow-sm">
          <h3 class="text-2xl font-semibold mb-3">{b.title}</h3>
          <p class="text-lg opacity-80">{b.desc}</p>
        </article>
      ))}
    </div>
  </section>

  <section id="layanan-spesifik" class="container my-32 py-16 bg-neutral-50 dark:bg-neutral-900/30 rounded-3xl">
    <div class="text-center mb-16">
      <h2 class="text-4xl md:text-5xl font-semibold mb-4">Jenis Layanan Optimasi Like Instagram</h2>
      <p class="text-xl opacity-80">Kami menyediakan manajemen distribusi interaksi yang terukur untuk berbagai format media di Instagram.</p>
    </div>

    <div class="grid gap-8 md:grid-cols-3">
      {[
        { 
          n: 'Optimasi Post & Carousel', 
          desc: 'Membantu meningkatkan interaksi pada publikasi foto tunggal maupun multi-slide (carousel). Format ini sangat krusial untuk menyampaikan informasi edukatif agar bisnis Anda terlihat matang.', 
          icon: '📸' 
        },
        { 
          n: 'Optimasi Instagram Reels', 
          desc: 'Didesain khusus untuk meningkatkan metrik interaksi pada konten video pendek. Penambahan interaksi secara berkala menjaga retensi dan membantu sistem rekomendasi video bekerja lebih optimal.', 
          icon: '🎬' 
        },
        { 
          n: 'Manajemen Auto Like Berkala', 
          desc: 'Solusi jangka panjang bagi kreator konten yang aktif. Setiap kali Anda mempublikasikan konten baru, sistem kami memantau dan mendistribusikan interaksi secara bertahap demi menjaga kesehatan grafik engagement akun Anda.', 
          icon: '🔄' 
        },
      ].map((p) => (
        <article class="rounded-3xl border border-neutral-200/70 dark:border-neutral-800/70 bg-white dark:bg-neutral-900 shadow-lg p-8 text-center hover:border-purple-500 transition-all duration-300 transform hover:-translate-y-2 flex flex-col justify-between">
          <div>
            <div class="text-5xl mb-4">{p.icon}</div>
            <h3 class="text-2xl font-bold mb-4 text-neutral-800 dark:text-neutral-100">{p.n}</h3>
            <p class="text-lg opacity-80 leading-relaxed mb-6">{p.desc}</p>
          </div>

          <div class="mt-auto">
            <a href={`https://wa.me/6289634740308?text=Halo%20Admin%20Jasalike,%20saya%20tertarik%20dan%20ingin%20tanya%20pricelist%20layanan%20${p.n}.`} target="_blank" rel="noopener"
               class="flex items-center justify-center w-full rounded-2xl px-6 py-4 font-bold bg-gradient-to-r from-green-500 to-emerald-600 text-white !text-white shadow-md hover:shadow-xl transition-all">
              Minta Pricelist di WA
            </a>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section id="faq" class="container my-32">
    <h2 class="text-4xl font-semibold mb-12 text-center">Informasi Tambahan & FAQ</h2>

    <div class="grid gap-6 md:grid-cols-2">
      <details class="rounded-2xl border border-neutral-200/70 dark:border-neutral-800/70 bg-white/60 dark:bg-neutral-900/60 p-6 group">
        <summary class="cursor-pointer text-xl font-semibold list-none flex justify-between items-center">
          Bagaimana kepatuhan sistem ini terhadap algoritma Instagram?
          <span class="text-purple-600 group-open:rotate-180 transition-transform">↓</span>
        </summary>
        <div class="mt-4 opacity-80 pt-4 border-t border-neutral-200 dark:border-neutral-700 leading-relaxed">
          Seluruh proses dilakukan menggunakan manajemen pengiriman yang terukur dan bertahap. Sistem kami mendistribusikan interaksi secara natural agar tetap selaras dengan kebijakan pembaruan algoritma platform, menjaga akun Anda tetap aman.
        </div>
      </details>

      <details class="rounded-2xl border border-neutral-200/70 dark:border-neutral-800/70 bg-white/60 dark:bg-neutral-900/60 p-6 group">
        <summary class="cursor-pointer text-xl font-semibold list-none flex justify-between items-center">
          Apakah distribusi interaksi bisa disesuaikan untuk beberapa konten sekaligus?
          <span class="text-purple-600 group-open:rotate-180 transition-transform">↓</span>
        </summary>
        <div class="mt-4 opacity-80 pt-4 border-t border-neutral-200 dark:border-neutral-700 leading-relaxed">
          Sangat bisa. Anda dapat mengalokasikan kuota manajemen interaksi ke beberapa tautan postingan yang berbeda secara fleksibel demi menjaga performa visual seluruh feed Anda tetap seimbang.
        </div>
      </details>
    </div>
  </section>
</DefaultLayout>
