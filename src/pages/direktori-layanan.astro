---
// src/pages/direktori-layanan.astro
import DefaultLayout from '../layouts/DefaultLayout.astro'
import Hero from '../components/Hero.astro'
import { Icon } from 'astro-icon/components'

// ==========================================
// 1. DATA SEO DIREKTORI GLOBAL
// ==========================================
const title = "Peta Direktori Semua Layanan JasaLike | Pusat Optimasi & Perlindungan Sosmed";
const description = "Pusat direktori resmi JasaLike. Temukan semua layanan optimasi: jasa komentar YouTube indonesia, jasa report & hapus akun tiktok, hingga jasa trending topik twitter terbaik.";
const keywords = "jasa komentar YouTube indonesia, jasa report akun tiktok, jasa hapus akun tiktok, jasa spam tiktok, jasa trending topik twitter, fyp tiktok, jasa tiktok bandung, jasa tiktok surabaya, beli komentar YouTube, trending 1 today, usaha jasa terbaik, jasa like akun private";

// ==========================================
// 2. DATA KOMPONEN HERO 
// ==========================================
const dataHero = {
  tipe: "service",
  labelTeks: "Pusat Direktori JasaLike",
  labelIcon: "lucide:layout-grid", 
  judulUtama: 'Pusat Layanan Optimasi <br class="hidden md:block"/> <span class="text-blue-500">Sosial Media Terlengkap</span>',
  deskripsi: "Selamat datang di pusat layanan digital JasaLike. Kami siap membantu memperkuat aset digital Anda lintas platform, mulai dari eksekusi <strong>jasa komentar YouTube indonesia</strong>, manajemen krisis <strong>jasa report akun tiktok</strong>, hingga <strong>jasa trending topik twitter</strong>.<br class='hidden md:block mt-2'/><span class='text-blue-500 font-semibold block mt-4'>✓ Lintas Platform ✓ Eksekusi Cepat ✓ Privasi Klien Terjamin</span>",
  teksTombol1: "Pilih Kategori Layanan",
  linkTombol1: "#daftar-layanan",
  teksTombol2: "Konsultasi Gratis",
  linkTombol2: "https://wa.me/6289634740308",
  gambarHero: "/image/hero-direktori.png" 
};

// ==========================================
// 3. DATA KONTEN DIREKTORI (Daftar Layanan Spesifik)
// ==========================================
const direktoriKategori = [
  // PLATFORM 1: TIKTOK
  {
    icon: "fa-brands:tiktok",
    colorClass: "text-slate-900", 
    namaKategori: "Optimasi & Perlindungan TikTok",
    deskripsi: "Solusi lengkap pendorong interaksi untuk <strong>fyp tiktok</strong>, manajemen krisis <strong>jasa report akun tiktok</strong>, hingga ekspansi <strong>jasa tiktok bandung</strong> dan <strong>jasa surabaya</strong>.",
    links: [
      { url: "/jasa-like-tiktok-permanen", label: "Jasa Like TikTok" },
      { url: "/jasa-tambah-follower-tiktok", label: "Jasa Follower TikTok" },
      { url: "/jasa-tambah-view-tiktok", label: "Jasa View TikTok" },
      { url: "/jasa-tambah-komentar-tiktok", label: "Jasa Komentar TikTok" },
      { url: "/jasa-share-tiktok", label: "Jasa Share & Save" },
      { url: "/jasa-report-tiktok", label: "Jasa Report Akun TikTok" },
      { url: "/jasa-hapus-tiktok", label: "Jasa Hapus Akun TikTok" },
      { url: "/jasa-spam-tiktok", label: "Jasa Spam TikTok" }
    ],
    catatan: "Butuh bantuan banding resmi? Hubungi email <strong>feedback@tiktok</strong> atau tim ahli kami."
  },
  // PLATFORM 2: YOUTUBE
  {
    icon: "fa-brands:youtube",
    colorClass: "text-red-600", 
    namaKategori: "Interaksi & Jam Tayang YouTube",
    deskripsi: "Tingkatkan kredibilitas channel Anda dengan <strong>jasa komentar YouTube indonesia</strong> real. Solusi instan bagi yang mencari <strong>cara beli komentar YouTube</strong> yang aman.",
    links: [
      { url: "/jasa-subscriber-youtube", label: "Jasa Subscriber" },
      { url: "/jasa-jam-tayang", label: "Jasa Jam Tayang" },
      { url: "/jasa-view-youtube", label: "Jasa View YouTube" },
      { url: "/jasa-komentar-youtube", label: "Jasa Komentar YouTube" },
      { url: "/jasa-like-youtube", label: "Jasa Like YouTube" },
      { url: "/jasa-live-youtube", label: "Penonton Live Stream" }
    ],
    catatan: "Kami menjamin keamanan akun dengan metode eksekusi dari PC admin."
  },
  // PLATFORM 3: INSTAGRAM
  {
    icon: "fa-brands:instagram",
    colorClass: "text-pink-600", 
    namaKategori: "Engagement & Estetika Instagram",
    deskripsi: "Layanan pendorong interaksi Feed, Reels, dan Story. Tersedia juga layanan <strong>jasa like akun private</strong> untuk privasi klien secara total.",
    links: [
      { url: "/jasa-like-instagram", label: "Jasa Like Instagram" },
      { url: "/jasa-follower-instagram", label: "Jasa Follower Aktif" },
      { url: "/jasa-view-reels", label: "Jasa View Reels/Story" },
      { url: "/jasa-komentar-instagram", label: "Jasa Komentar Custom" },
      { url: "/jasa-save-instagram", label: "Jasa Save & Share" },
      { url: "/jasa-vote-instagram", label: "Jasa Vote Polling Story" }
    ],
    catatan: "Cocok untuk optimasi akun bisnis dan brand personal."
  },
  // PLATFORM 4: TWITTER / X
  {
    icon: "fa-brands:twitter",
    colorClass: "text-blue-400", 
    namaKategori: "Viral Marketing & Trending Twitter",
    deskripsi: "Kuasai opini publik dengan layanan <strong>jasa trending topik twitter</strong> kami untuk mencapai target <strong>trending 1 today</strong> secara organik.",
    links: [
      { url: "/jasa-trending-twitter", label: "Jasa Trending Topik" },
      { url: "/jasa-retweet", label: "Jasa Retweet Premium" },
      { url: "/jasa-like-twitter", label: "Jasa Like Twitter" },
      { url: "/jasa-follower-twitter", label: "Jasa Follower Twitter" },
      { url: "/jasa-reply-twitter", label: "Jasa Reply / Komentar" },
      { url: "/jasa-vote-twitter", label: "Jasa Vote Polling" }
    ],
    catatan: "Optimalkan kampanye viral marketing Anda di platform X bersama kami."
  }
];
---

<DefaultLayout title={title} description={description} keywords={keywords}>

  <Fragment slot="head">
<script type="application/ld+json">
[
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": "Peta Direktori Semua Layanan JasaLike",
    "description": "Pusat direktori resmi JasaLike. Temukan semua layanan optimasi sosial media lintas platform secara lengkap, aman, dan terpercaya.",
    "url": "https://jasalike.com/direktori-layanan",
    "publisher": {
      "@type": "Organization",
      "name": "JasaLike",
      "url": "https://jasalike.com/",
      "logo": {
        "@type": "ImageObject",
        "url": "https://jasalike.com/image/hero-direktori.png"
      }
    },
    "mainEntity": {
      "@type": "ItemList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Optimasi & Perlindungan TikTok",
          "description": "Solusi pendorong interaksi untuk fyp tiktok, serta manajemen krisis meliputi jasa report akun tiktok, jasa hapus akun tiktok, dan jasa spam tiktok.",
          "url": "https://jasalike.com/direktori-layanan#tiktok"
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": "Interaksi & Jam Tayang YouTube",
          "description": "Layanan optimasi kredibilitas channel melalui jasa komentar YouTube indonesia, penambah subscriber, view, dan jam tayang aman.",
          "url": "https://jasalike.com/direktori-layanan#youtube"
        },
        {
          "@type": "ListItem",
          "position": 3,
          "name": "Engagement & Estetika Instagram",
          "description": "Layanan pendorong interaksi Feed, Reels, dan Story. Tersedia juga layanan jasa like akun private untuk privasi maksimal.",
          "url": "https://jasalike.com/direktori-layanan#instagram"
        },
        {
          "@type": "ListItem",
          "position": 4,
          "name": "Viral Marketing & Trending Twitter",
          "description": "Kuasai opini publik dengan layanan jasa trending topik twitter kami untuk mencapai target trending 1 today secara organik.",
          "url": "https://jasalike.com/direktori-layanan#twitter"
        }
      ]
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Beranda",
        "item": "https://jasalike.com/"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": "Direktori Layanan",
        "item": "https://jasalike.com/direktori-layanan"
      }
    ]
  }
]
</script>
</Fragment>

  <!-- BAGIAN 1: HERO -->
  <Hero {...dataHero} />

  <!-- BAGIAN 2: AREA GRID DENGAN BACKGROUND POLOS -->
  <div id="daftar-layanan" class="relative w-full bg-slate-50 overflow-hidden border-t border-gray-100">
    
    <main class="relative z-10 container mx-auto px-6 py-20 max-w-5xl min-h-screen">
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        
        {direktoriKategori.map((kategori) => (
          <section class="bg-white p-8 rounded-3xl shadow-sm hover:shadow-lg transition-all duration-300 border border-gray-200">
            
            <div class="flex items-center gap-4 mb-6 border-b border-gray-100 pb-5">
              <div class={`p-3 rounded-xl bg-gray-50 ${kategori.colorClass}`}>
                <Icon name={kategori.icon} class="text-4xl" />
              </div>
              <h2 class="text-2xl font-bold text-slate-800">{kategori.namaKategori}</h2>
            </div>
            
            <p class="text-sm text-slate-600 mb-8 leading-relaxed" set:html={kategori.deskripsi}></p>
            
            <!-- LIST LAYANAN (Diberi gaya paksa / Force Override) -->
            <ul class="grid grid-cols-1 sm:grid-cols-2 gap-y-4 gap-x-2 mb-8 list-none pl-0">
              {kategori.links.map((link) => (
                <li class="p-0 m-0">
                  <!-- !no-underline dan !text-slate-700 dipasang untuk membunuh CSS Global -->
                  <a 
                    href={link.url} 
                    class="flex items-start gap-2 group transition-colors !no-underline !text-slate-700 hover:!text-blue-600 !bg-transparent !shadow-none !border-none"
                    style="text-decoration: none !important; box-shadow: none !important;"
                  >
                    <!-- Icon panah/centang -->
                    <Icon name="lucide:chevron-right" class="w-4 h-4 mt-1 text-blue-400 group-hover:translate-x-1 transition-transform shrink-0" />
                    <span class="font-medium !text-slate-700 group-hover:!text-blue-600 leading-snug">{link.label}</span>
                  </a>
                </li>
              ))}
            </ul>

            {kategori.catatan && (
              <div class="pt-4 border-t border-gray-100 text-xs text-slate-500 italic bg-gray-50 p-4 rounded-xl" set:html={kategori.catatan}></div>
            )}
            
          </section>
        ))}

      </div>

    </main>
  </div>

</DefaultLayout>

