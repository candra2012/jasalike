---
// src/pages/direktori-layanan.astro
import DefaultLayout from '../layouts/DefaultLayout.astro'
import Hero from '../components/Hero.astro'
import { Icon } from 'astro-icon/components'

// ==========================================
// 1. DATA SEO DIREKTORI TIKTOK
// ==========================================
const title = "Peta Direktori Layanan JasaLike | Pusat Optimasi & Perlindungan TikTok";
const description = "Pusat direktori JasaLike khusus layanan TikTok: melayani jasa report akun tiktok, jasa spam tiktok, hingga optimasi wilayah jasa tiktok bandung dan surabaya.";
const keywords = "jasa like akun private, jasa auto like, jasa like and subscribe, jasa like album, jasa beli like youtube, jasa jual beli like tiktok, jasa beli like, jasa buzzer like instagram, jasa bot like, jasa buzzer like, jasa like comment instagram, jasa like comment tiktok, jasa like comment youtube, jasa tambah like tiktok, jasa like dan komen instagram, jasa like dan view tiktok, jasa like foto ig, jasa like google maps";

// ==========================================
// 2. DATA KOMPONEN HERO (Pengganti Teks Atas)
// ==========================================
const dataHero = {
  tipe: "service",
  labelTeks: "Layanan TikTok Premium",
  labelIcon: "fa-brands:tiktok",
  judulUtama: 'Jasa Like TikTok <br class="hidden md:block"/> <span class="text-blue-500">Cepat & Terpercaya</span>',
  deskripsi: "Tingkatkan performa video TikTok dengan layanan optimasi interaksi yang dirancang untuk memperkuat engagement dan menembus <strong>fyp tiktok</strong>. Kami juga spesialis dalam <strong>jasa report akun tiktok</strong> & <strong>jasa hapus akun tiktok</strong>.<br class='hidden md:block mt-2'/><span class='text-blue-400 font-semibold block mt-4'>✓ Sistem Aman & Stabil ✓ Proses Efisien ✓ Garansi Proteksi Kualitas</span>",
  teksTombol1: "Lihat Harga Paket",
  linkTombol1: "https://docs.google.com/spreadsheets/d/1BXtgxl_qcKRe4UOIm__BDH5DwufpyX-56Ru-NDDXMcI/edit?usp=drivesdk",
  teksTombol2: "Konsultasi Gratis",
  linkTombol2: "https://wa.me/6289634740308",
  gambarHero: "/image/hero-direktori.png"
};

// ==========================================
// 3. DATA KONTEN DIREKTORI (Grid di Bawah Hero)
// ==========================================
const direktoriKategori = [
  {
    icon: "fa-brands:tiktok",
    bgImage: "/image/hero-jasalike-Tiktok.png", 
    colorClass: "text-slate-900", 
    bgClass: "bg-slate-900/10",
    namaKategori: "Manajemen & Perlindungan TikTok",
    deskripsi: "Solusi lengkap dari optimasi FYP, manajemen krisis, hingga ekspansi lokal untuk <strong>jasa tiktok bandung</strong> dan <strong>jasa tiktok surabaya</strong>.",
    links: [
      { url: "/jasa-like-tiktok-permanen", label: "Pusat <strong>jasa suntik like tiktok</strong> & <strong>jasa jual beli like tiktok</strong> permanen" }
    ],
    catatan: "Butuh bantuan banding resmi? Hubungi email <strong>feedback@tiktok</strong> atau konsultasikan layanan <strong>jual jasa like tiktok</strong> bersama tim ahli kami."
  }
];
---

<DefaultLayout title={title} description={description} keywords={keywords}>
  
  <!-- BAGIAN 1: HERO (Tampilan Atas Premium) -->
  <Hero {...dataHero} />

  <!-- BAGIAN 2: GRID DIREKTORI -->
  <main class="container mx-auto px-6 py-16 max-w-4xl min-h-screen" id="harga-paket">
    
    <div class="space-y-12">
      {direktoriKategori.map((kategori) => (
        <section 
          class="relative p-6 md:p-8 rounded-2xl shadow-sm border border-gray-100 overflow-hidden bg-white"
          style={kategori.bgImage ? `background-image: url('${kategori.bgImage}'); background-size: cover; background-position: center;` : ""}
        >
          <!-- DARK OVERLAY (Hanya muncul jika diisi foto background) -->
          {kategori.bgImage && (
            <div class="absolute inset-0 bg-white/90 backdrop-blur-sm"></div>
          )}

          <!-- KONTEN GRID -->
          <div class="relative z-10">
            <div class="flex items-center gap-3 mb-4 border-b border-gray-200 pb-4">
              <Icon name={kategori.icon} class={`text-3xl ${kategori.colorClass}`} />
              <h2 class="text-2xl font-bold text-slate-800">{kategori.namaKategori}</h2>
            </div>
            
            <p class="text-sm text-slate-700 mb-6" set:html={kategori.deskripsi}></p>
            
            <ul class="space-y-3 mb-6">
              {kategori.links.map((link) => (
                <li class="flex items-start gap-2">
                  <span class="text-blue-600 mt-1">🔗</span>
                  <a 
                    href={link.url} 
                    class="text-blue-700 font-medium hover:underline leading-relaxed"
                    set:html={link.label}
                  />
                </li>
              ))}
            </ul>

            {kategori.catatan && (
              <div class="mt-4 pt-4 border-t border-gray-200 text-xs text-slate-600 italic bg-gray-50/50 p-3 rounded-lg" set:html={kategori.catatan}></div>
            )}
          </div>
        </section>
      ))}
    </div>

  </main>

</DefaultLayout>

