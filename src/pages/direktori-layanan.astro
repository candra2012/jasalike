---
// src/pages/direktori-layanan.astro
import DefaultLayout from '../layouts/DefaultLayout.astro'
import Hero from '../components/Hero.astro'
import { Icon } from 'astro-icon/components'

// ==========================================
// 1. DATA SEO DIREKTORI GLOBAL
// ==========================================
const title = "Peta Direktori Semua Layanan JasaLike | Pusat Optimasi & Perlindungan Sosmed";
const description = "Pusat direktori resmi JasaLike. Temukan semua layanan optimasi: jasa komentar YouTube indonesia, jasa report & hapus akun tiktok, hingga jasa trending topik twitter terbaik.";
const keywords = "jasa komentar YouTube indonesia, jasa report akun tiktok, jasa hapus akun tiktok, jasa spam tiktok, jasa trending topik twitter, fyp tiktok, jasa tiktok bandung, jasa tiktok surabaya, beli komentar YouTube, trending 1 today, usaha jasa terbaik, jasa like akun private";

// ==========================================
// 2. DATA KOMPONEN HERO 
// ==========================================
const dataHero = {
  tipe: "service",
  labelTeks: "Pusat Direktori JasaLike",
  labelIcon: "lucide:layout-grid", 
  judulUtama: 'Pusat Layanan Optimasi <br class="hidden md:block"/> <span class="text-blue-500">Sosial Media Terlengkap</span>',
  deskripsi: "Selamat datang di pusat layanan digital JasaLike. Kami siap membantu memperkuat aset digital Anda lintas platform, mulai dari eksekusi <strong>jasa komentar YouTube indonesia</strong>, manajemen krisis <strong>jasa report akun tiktok</strong>, hingga <strong>jasa trending topik twitter</strong>.<br class='hidden md:block mt-2'/><span class='text-blue-500 font-semibold block mt-4'>✓ Lintas Platform ✓ Eksekusi Cepat ✓ Privasi Klien Terjamin</span>",
  teksTombol1: "Pilih Kategori Layanan",
  linkTombol1: "#daftar-layanan",
  teksTombol2: "Konsultasi Gratis",
  linkTombol2: "https://wa.me/6289634740308",
  gambarHero: "/image/hero-direktori.png" 
};

// ==========================================
// 3. DATA KONTEN DIREKTORI (Daftar Layanan Spesifik)
// ==========================================
const direktoriKategori = [
  // PLATFORM 1: TIKTOK
  {
    icon: "fa-brands:tiktok",
    colorClass: "text-slate-900", 
    namaKategori: "Optimasi & Perlindungan TikTok",
    deskripsi: "Solusi lengkap pendorong interaksi untuk <strong>fyp tiktok</strong>, manajemen krisis <strong>jasa report akun tiktok</strong>, hingga ekspansi <strong>jasa tiktok bandung</strong> dan <strong>jasa surabaya</strong>.",
    links: [
      { url: "/jasa-tambah-follower-tiktok", label: "Jasa Follower TikTok" },
      { url: "/jasa-tambah-view-tiktok", label: "Jasa View TikTok" },
      { url: "/jasa-tambah-komentar-tiktok", label: "Jasa Komentar TikTok" },
      { url: "/jasa-share-video-tiktok", label: "Jasa Share Tiktok" },
      { url: "/jasa-save-video-tiktok", label: "Jasa Save Tiktok" },
      { url: "/jasa-report-akun-tiktok", label: "Jasa Report Akun TikTok" },
      { url: "/jasa-livestreaming-tiktok", label: "Jasa Livestreaming TikTok" },
      { url: "/jasa-repost-tiktok", label: "Jasa Repost TikTok" }
    ],
    catatan: "Butuh bantuan banding resmi? Hubungi email <strong>jasalike@gmail.com</strong> atau tim ahli kami."
  },
  // PLATFORM 2: YOUTUBE
  {
    icon: "fa-brands:youtube",
    colorClass: "text-red-600", 
    namaKategori: "Interaksi & Jam Tayang YouTube",
    deskripsi: "Tingkatkan kredibilitas channel Anda dengan <strong>jasa komentar YouTube indonesia</strong> real. Solusi instan bagi yang mencari <strong>cara beli komentar YouTube</strong> yang aman.",
    links: [
      { url: "/jasa-subscribe-youtube", label: "Jasa Subscriber" },
      { url: "/jasa-save-video-youtube", label: "Jasa Save Youtube" },
      { url: "/jual-jasa-view-youtube", label: "Jasa View YouTube" },
      { url: "/jasa-komen-youtube-aktif", label: "Jasa Komentar YouTube" },
      { url: "/jasa-live-youtube", label: "Penonton Live Stream" },
      { url: "/jasa-report-youtube", label: "Report Akun/Postingan" }
    ],
    catatan: "Kami menjamin keamanan akun dengan metode eksekusi dari PC admin."
  },
  // PLATFORM 3: INSTAGRAM
  {
    icon: "fa-brands:instagram",
    colorClass: "text-pink-600", 
    namaKategori: "Engagement & Estetika Instagram",
    deskripsi: "Layanan pendorong interaksi Feed, Reels, dan Story. Tersedia juga layanan <strong>jasa like akun private</strong> untuk privasi klien secara total.",
    links: [
      { url: "/jasa-tambah-follower", label: "Jasa Follower Aktif" },
      { url: "/jasa-tambah-view", label: "Jasa View Reels/Story" },
      { url: "/jasa-komen-instagram", label: "Jasa Komentar Custom" },
      { url: "/#jasa-save-instagram", label: "Jasa Save & Share" },
      { url: "/jasa-vote-ig-private", label: "Jasa Vote Polling Instagram" }
    ],
    catatan: "Cocok untuk optimasi akun bisnis dan brand personal."
  },
  // PLATFORM 4: TWITTER / X
  {
    icon: "fa-brands:twitter",
    colorClass: "text-blue-400", 
    namaKategori: "Viral Marketing & Trending Twitter",
    deskripsi: "Kuasai opini publik dengan layanan <strong>jasa trending topik twitter</strong> kami untuk mencapai target <strong>trending 1 today</strong> secara organik.",
    links: [
      { url: "/jasa-komen-twitter", label: "Jasa Komentar Twitter" },
      { url: "/#jasa-retweet", label: "Jasa Retweet Premium" },
      { url: "/jasa-tambah-follower-twitter", label: "Jasa Follower Twitter" },
      { url: "/#jasa-reply-twitter", label: "Jasa Reply / Komentar" },
      { url: "/#jasa-vote-twitter", label: "Jasa Vote Polling" }
    ],
    catatan: "Optimalkan kampanye viral marketing Anda di platform X bersama kami."
  },
      // PLATFORM: SHOPEE
  {
    icon: "lucide:shopping-bag", 
    colorClass: "text-orange-500", 
    namaKategori: "Optimasi Toko & Live Shopee",
    deskripsi: "Tingkatkan kepercayaan pembeli dan konversi penjualan dengan <strong>jasa follower toko Shopee</strong>. Solusi instan untuk mendominasi algoritma pencarian produk.",
    links: [
      { url: "/jasa-tambah-follower-shopee", label: "Jasa Follower Toko" },
      { url: "/jasa-fake-order-shopee", label: "Jasa Produk Terjual" },
      { url: "/jasa-live-shopee", label: "Jasa Live Shopee" },
      { url: "/jasa-komen-live-shopee", label: "Jasa Komen Live Shopee" },
      { url: "/jasa-view-video-shopee", label: "Jasa View Video Shopee" },
      { url: "/jasa-tambah-komen-shopee", label: "Jasa Komen Video Shopee" },
      { url: "/jasa-report-toko-shopee", label: "Jasa Report Toko Shopee" },
      { url: "/jasa-vote-produk-shopee", label: "Jasa Vote Produk Shopee" }
    ],
    catatan: "Aman 100%. Kami beroperasi dari luar tanpa pernah meminta data rahasia Seller Center Anda"
  },
     {
    icon: "fa-brands:facebook",
    colorClass: "text-blue-600", 
    namaKategori: "Optimasi & Pertumbuhan Facebook",
    deskripsi: "Solusi strategis untuk memperluas <strong>reach organik</strong> halaman Anda, membangun kredibilitas melalui <strong>jasa komentar facebook</strong> yang relevan, hingga perlindungan brand dari akun palsu.",
    links: [
      { url: "/jasa-tambah-follower-facebook", label: "Jasa Follower & Fanpage Facebook" },
      { url: "/jasa-tambah-komentar-facebook", label: "Jasa Komentar Facebook" },
      { url: "/jasa-share-facebook", label: "Jasa Share Postingan Facebook" },
      { url: "/jasa-tambah-view-facebook", label: "Jasa View Video & Reels Facebook" },
      { url: "/#jasa-report-akun-facebook", label: "Jasa Report Akun Facebook" },
      { url: "/jasa-live-facebook", label: "Jasa Penonton Live Facebook" },
      { url: "/jasa-polling-facebook", label: "Jasa Vote Kontes Facebook" }
    ],
    catatan: "Butuh konsultasi strategi Fanpage atau pengelolaan grup? Hubungi email <strong>jasalike@gmail.com</strong> atau tim operasional kami."
  },
  {
    icon: "fa-brands:telegram",
    colorClass: "text-sky-500", 
    namaKategori: "Optimasi & Pertumbuhan Telegram",
    deskripsi: "Solusi strategis untuk membesarkan <strong>Channel & Grup</strong> Anda, membangun komunitas interaktif melalui <strong>jasa member & view telegram</strong>, hingga memenangkan kontes polling secara efektif.",
    links: [
      { url: "/jasa-tambah-member-telegram", label: "Jasa Member Channel & Grup Telegram" },
      { url: "/jasa-invite-member-telegram", label: "Jasa Invite Teman Ke Bot Telegram" },
