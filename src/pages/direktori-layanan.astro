      { url: "/jasa-komentar-telegram", label: "Jasa Komentar Grup/Channel Telegram" },
      { url: "/jasa-polling-telegram", label: "Jasa Vote Polling Telegram" },
      { url: "/jasa-report-akun-telegram", label: "Jasa Report Akun & Penipu Telegram" }
    ],
    catatan: "Butuh konsultasi strategi Channel Telegram atau manajemen komunitas? Hubungi email <strong>jasalike@gmail.com</strong> atau tim operasional kami."
  },
  {
    icon: "fa-brands:discord",
    colorClass: "text-indigo-600", 
    namaKategori: "Optimasi & Pertumbuhan Discord",
