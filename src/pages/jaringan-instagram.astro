---
// src/pages/jaringan-instagram.astro
import DefaultLayout from '../layouts/DefaultLayout.astro'
import Hero from '../components/Hero.astro'
import { Icon } from 'astro-icon/components' 
import RelatedServices from '../components/RelatedServices.astro'

const title = "Jaringan Resmi JasaLike | Pusat Layanan Jasa Like Terpercaya";
const description = "Temukan jaringan resmi akun Instagram dan tiktok JasaLike. Kami berfokus memberikan layanan jasa like terbaik, cepat, dan aman untuk mendongkrak interaksi akun Anda.";
const keywords = "jasa like, jasa like instagram, beli like murah, jasa like aman, jasa like cepat, jasalike, optimasi interaksi";

const dataHero = {
  tipe: "service",
  labelTeks: "Pusat Akun JasaLike",
  labelIcon: "lucide:layout-grid", 
  judulUtama: 'Jaringan Resmi JasaLike di <span class="text-blue-500">Instagram</span> dan TikTok',
  
  // PERBAIKAN: Tag <br> yang terputus sudah disambung kembali agar tidak merusak HTML
  deskripsi: "Temukan akun resmi JasaLike untuk informasi layanan, promo terbaru, dan konsultasi langsung dengan tim admin yang kami kelola secara profesional.<br class='hidden md:block mt-2' /> <span class='text-blue-400 font-semibold block mt-4'>✓ Akun Resmi & Terverifikasi &nbsp; ✓ Update Promo Terbaru &nbsp; ✓ Konsultasi Langsung Admin</span>",
  
  teksTombol1: "Jelajahi Jaringan IG",
  linkTombol1: "#daftar-akun",
  teksTombol2: "Konsultasi Jaringan Instagram",
  linkTombol2: "https://wa.me/6289634740308",
  gambarHero: "/image/hero-direktori.png" 
};
---

<DefaultLayout title={title} description={description} keywords={keywords}>
  <Hero {...dataHero} />
  
  <main class="min-h-screen bg-gray-50 py-12 px-4 sm:px-6 lg:px-8 flex flex-col items-center">

    <!-- Bagian Tombol Linktree -->
    <div id="daftar-akun" class="w-full max-w-xl space-y-4">

      <!-- Header Mini -->
      <div class="text-center mb-6">
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-blue-50 text-blue-600 text-sm font-semibold mb-4">
          
          <!-- Menggunakan ikon fa6-solid sesuai permintaanmu -->
          <Icon name="fa6-solid:circle-check" class="w-4 h-4" />
          Direktori Resmi
        </div>

        <h2 class="text-2xl font-extrabold text-gray-900 mb-3">
          Daftar Akun Resmi JasaLike
        </h2>

        <p class="text-gray-500 text-sm md:text-base leading-relaxed">
          Temukan akun TikTok & Instagram resmi untuk layanan jasa like,
          promo terbaru, dan konsultasi admin terpercaya.
        </p>
      </div>

      <!-- Akun 1 -->
      <a href="https://tiktok.com/@jasalike.vttiktok" target="_blank" rel="noopener noreferrer"
        class="group flex items-center p-4 bg-white border-2 border-gray-200 rounded-xl hover:border-blue-500 hover:shadow-md transition-all duration-300">

        <!-- Menggunakan ikon fa-brands sesuai permintaanmu -->
        <Icon name="fa-brands:tiktok" class="w-10 h-10 text-black group-hover:text-blue-500 transition-colors mr-4 flex-shrink-0" />

        <div class="text-left">
          <h3 class="text-lg font-bold text-gray-900">
            JasaLike Official TikTok
          </h3>
          <p class="text-sm text-gray-500 line-clamp-2">
            Pusat order jasa like VT TikTok aman, cepat, dan bergaransi.
          </p>
        </div>
      </a>

         <!-- Akun 2 -->
      <a href="https://tiktok.com/@jasalike.igpermanen" target="_blank" rel="noopener noreferrer"
        class="group flex items-center p-4 bg-white border-2 border-gray-200 rounded-xl hover:border-blue-500 hover:shadow-md transition-all duration-300">

        <!-- Menggunakan ikon fa-brands sesuai permintaanmu -->
        <Icon name="fa-brands:tiktok" class="w-10 h-10 text-black group-hover:text-blue-500 transition-colors mr-4 flex-shrink-0" />

        <div class="text-left">
          <h3 class="text-lg font-bold text-gray-900">
            JasaLike Official TikTok
          </h3>
          <p class="text-sm text-gray-500 line-clamp-2">
            Pusat Akun Tiktok jasa like IG Permanent Layanan jasa tambah like IG permanent, 
          </p>
        </div>
      </a>

    </div>

    <!-- Teks Daging SEO Spesifik Jasa Like -->
    <div class="w-full max-w-2xl mt-16 bg-white p-6 rounded-xl border border-gray-200 shadow-sm text-left">
      <h3 class="text-xl font-bold text-gray-800 mb-3">Solusi Cerdas Meningkatkan Interaksi</h3>
      <p class="text-sm text-gray-600 leading-relaxed mb-3">
        Menghadapi persaingan konten yang semakin ketat, memiliki visual yang menarik saja belum cukup. Algoritma media sosial sangat bergantung pada interaksi awal. Oleh karena itu, <strong>jasa like</strong> hadir sebagai solusi strategis untuk memberikan pancingan momentum yang Anda butuhkan agar postingan Anda mendapatkan jangkauan organik yang lebih luas.
      </p>
      <p class="text-sm text-gray-600 leading-relaxed">
        JasaLike berkomitmen memberikan <strong>layanan jasa like berkualitas</strong> dengan proses yang cepat, harga kompetitif, dan tentunya mematuhi pedoman komunitas agar 100% aman untuk akun Anda. Hubungi salah satu jaringan resmi kami di atas untuk berkonsultasi lebih lanjut.
      </p>
    </div>

  </main>

  <RelatedServices category="instagram" current={Astro.url.pathname} />

</DefaultLayout>

