---
// src/pages/jaringan-instagram.astro
import DefaultLayout from '../layouts/DefaultLayout.astro'
import { Icon } from 'astro-icon/components' 

const title = "Jaringan Resmi JasaLike | Pusat Layanan Jasa Like Terpercaya";
const description = "Temukan jaringan resmi akun Instagram dan tiktok JasaLike. Kami berfokus memberikan layanan jasa like terbaik, cepat, dan aman untuk mendongkrak interaksi akun Anda.";
const keywords = "jasa like, jasa like instagram, beli like murah, jasa like aman, jasa like cepat, jasalike, optimasi interaksi";
---

<DefaultLayout title={title} description={description} keywords={keywords}>
  <main class="min-h-screen bg-gray-50 py-12 px-4 sm:px-6 lg:px-8 flex flex-col items-center">
    
    <!-- Bagian Header Profil -->
    <a href="https://tiktok.com/@jasalike.vttiktok" target="_blank" rel="noopener noreferrer" class="group flex items-center p-4 bg-white border-2 border-gray-200 rounded-xl hover:border-blue-500 hover:shadow-md transition-all duration-300">
  <Icon name="fa-brands:tiktok" class="w-10 h-10 text-black group-hover:text-blue-500 transition-colors mr-4 flex-shrink-0" />
  
  <div class="text-left">
    <h2 class="text-lg font-bold text-gray-900">JasaLike Official TikTok</h2>
    
    <p class="text-sm text-gray-500 line-clamp-2">
      Pusat order jasa like TikTok permanent, aman, cepat, dan bergaransi.
    </p>
  </div>
</a>

    <!-- Bagian Tombol Linktree (8 Akun Tiktok Fokus Jasa Like) -->
    <div class="w-full max-w-xl space-y-4">
      
      <!-- Akun 1: Utama/Pemesanan -->
      <a href="https://instagram.com/jasalike.ccom" target="_blank" rel="noopener noreferrer" class="group flex items-center p-4 bg-white border-2 border-gray-200 rounded-xl hover:border-blue-500 hover:shadow-md transition-all duration-300">
        <Icon name="lucide:instagram" class="w-10 h-10 text-pink-500 group-hover:text-blue-500 transition-colors mr-4 flex-shrink-0" />
        <div class="text-left">
          <h2 class="text-lg font-bold text-gray-900">JasaLike Official (Pemesanan)</h2>
          <p class="text-sm text-gray-500 line-clamp-2">Pusat utama untuk order <strong>jasa like</strong> yang aman, cepat, dan bergaransi penuh.</p>
        </div>
      </a>

      <!-- Akun 2: Testimoni -->
      <a href="https://instagram.com/jasalikeig.cepat" target="_blank" rel="noopener noreferrer" class="group flex items-center p-4 bg-white border-2 border-gray-200 rounded-xl hover:border-blue-500 hover:shadow-md transition-all duration-300">
        <Icon name="lucide:instagram" class="w-10 h-10 text-pink-500 group-hover:text-blue-500 transition-colors mr-4 flex-shrink-0" />
        <div class="text-left">
          <h2 class="text-lg font-bold text-gray-900">Bukti Transaksi & Testimoni</h2>
          <p class="text-sm text-gray-500 line-clamp-2">Kumpulan bukti interaksi like yang sukses masuk dan review asli dari klien setia kami.</p>
        </div>
      </a>

      <!-- Akun 3: Promo & Diskon -->
      <a href="https://instagram.com/jasalikeig.aktif" target="_blank" rel="noopener noreferrer" class="group flex items-center p-4 bg-white border-2 border-gray-200 rounded-xl hover:border-blue-500 hover:shadow-md transition-all duration-300">
        <Icon name="lucide:instagram" class="w-10 h-10 text-pink-500 group-hover:text-blue-500 transition-colors mr-4 flex-shrink-0" />
        <div class="text-left">
          <h2 class="text-lg font-bold text-gray-900">Info Harga & Diskon Like</h2>
          <p class="text-sm text-gray-500 line-clamp-2">Ikuti akun ini untuk mendapatkan <em>update</em> harga <strong>jasa like murah</strong> dan promo kilat harian.</p>
        </div>
      </a>

      <!-- Akun 4: Edukasi Algoritma -->
      <a href="https://instagram.com/likeigcepat.id" target="_blank" rel="noopener noreferrer" class="group flex items-center p-4 bg-white border-2 border-gray-200 rounded-xl hover:border-blue-500 hover:shadow-md transition-all duration-300">
        <Icon name="lucide:instagram" class="w-10 h-10 text-pink-500 group-hover:text-blue-500 transition-colors mr-4 flex-shrink-0" />
        <div class="text-left">
          <h2 class="text-lg font-bold text-gray-900">Edukasi & Tips Engagement</h2>
          <p class="text-sm text-gray-500 line-clamp-2">Berbagi rahasia cara mengoptimalkan like untuk menembus algoritma Explore secara organik.</p>
        </div>
      </a>

      <!-- Akun 5: Support / CS -->
      <a href="https://instagram.com/likeig.terpercaya" target="_blank" rel="noopener noreferrer" class="group flex items-center p-4 bg-white border-2 border-gray-200 rounded-xl hover:border-blue-500 hover:shadow-md transition-all duration-300">
        <Icon name="lucide:instagram" class="w-10 h-10 text-pink-500 group-hover:text-blue-500 transition-colors mr-4 flex-shrink-0" />
        <div class="text-left">
          <h2 class="text-lg font-bold text-gray-900">Admin Support (Bantuan Khusus)</h2>
          <p class="text-sm text-gray-500 line-clamp-2">Pusat bantuan kendala layanan. Admin kami siap membantu memastikan pesanan like Anda lancar.</p>
        </div>
      </a>

    </div>

    <!-- Teks Daging SEO Spesifik Jasa Like -->
    <div class="w-full max-w-2xl mt-16 bg-white p-6 rounded-xl border border-gray-200 shadow-sm text-left">
      <h3 class="text-xl font-bold text-gray-800 mb-3">Solusi Cerdas Meningkatkan Interaksi</h3>
      <p class="text-sm text-gray-600 leading-relaxed mb-3">
        Menghadapi persaingan konten yang semakin ketat, memiliki visual yang menarik saja belum cukup. Algoritma media sosial sangat bergantung pada interaksi awal. Oleh karena itu, <strong>jasa like</strong> hadir sebagai solusi strategis untuk memberikan pancingan momentum yang Anda butuhkan agar postingan Anda mendapatkan jangkauan organik yang lebih luas.
      </p>
      <p class="text-sm text-gray-600 leading-relaxed">
        JasaLike berkomitmen memberikan <strong>layanan jasa like berkualitas</strong> dengan proses yang cepat, harga kompetitif, dan tentunya mematuhi pedoman komunitas agar 100% aman untuk akun Anda. Hubungi salah satu jaringan resmi kami di atas untuk berkonsultasi lebih lanjut.
      </p>
    </div>

  </main>
</DefaultLayout>


