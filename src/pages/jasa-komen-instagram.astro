      "bestRating": "5",
      "worstRating": "1",
      "reviewCount": 1405
    },
    "offers": {
      "@type": "AggregateOffer",
      "lowPrice": 20000,
      "highPrice": 2000000,
      "priceCurrency": "IDR",
      "offerCount": 4
    },
    "image": "https://jasalike.com/image/jasa-like-instagram-organik-100like.png",
    "brand": {
      "@type": "Brand",
      "name": "JasaLike"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
