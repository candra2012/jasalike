---
import DefaultLayout from '@layouts/DefaultLayout.astro'
import SiteMetaLikesInstagram from '@components/SiteMetaLikesInstagram.astro'
import SchemaLikesInstagram from '@components/SchemaLikesInstagram.astro'
---

<DefaultLayout title="Jasa Like Instagram">
  <Fragment slot="head">
    <SiteMetaLikesInstagram
      title="Spesialis Jasa Like Instagram Aman, Cepat & Murah | Jasalike"
      description="Layanan spesialis penambah Like Instagram untuk Postingan Feed, Reels, dan Carousel. 100% aman, tanpa password, proses instan masuk dalam hitungan menit."
      url="https://jasalike.my.id/like-instagram/"
      image="/og-layanan.png"
      siteName="Jasalike"
      ogType="product"
      keywords={[
        'jasa like instagram',
        'beli like instagram murah',
        'tambah like reels',
        'jasa like ig tanpa password',
        'spesialis like instagram'
      ]}
    />
    <SchemaLikesInstagram
      pageUrl="https://jasalike.my.id/like-instagram/"
      pageTitle="Spesialis Jasa Like Instagram Aman, Cepat & Murah | Jasalike"
      description="Jasa tambah like Instagram untuk Reels, Feed, dan Carousel. Harga termurah, proses instan, dan dijamin aman untuk akun Anda."
      imageWebp="/layanan.webp"
      imagePng="/layanan.png"
      serviceName="Jasa Like Instagram"
      serviceUrl="https://jasalike.my.id/like-instagram/"
      price="10000"
      priceCurrency="IDR"
      unitText="per 1000 like"
    />
  </Fragment>

  <section class="container my-24 text-center">
    <div class="inline-flex items-center gap-2 rounded-full px-4 py-1 text-sm font-medium bg-gradient-to-r from-purple-100 to-pink-100 text-purple-800 dark:from-purple-900/40 dark:to-pink-900/40 dark:text-purple-100 border border-purple-200/60 dark:border-purple-800/60 mb-6">
      Layanan Spesialis Instagram • Proses Instan 1-5 Menit
    </div>

    <h1 class="text-6xl md:text-8xl font-bold tracking-tight mb-8">
      Suntik Like Instagram yang <br class="hidden md:block" />
      <span class="bg-gradient-to-r from-purple-600 to-pink-600 bg-clip-text text-transparent">Cepat, Aman & Natural</span>
    </h1>
    
    <p class="text-2xl opacity-80 max-w-4xl mx-auto leading-relaxed">
      Dorong interaksi Feed, Reels, dan Carousel Anda dengan penambahan Like instan. Bangun otoritas akun, tingkatkan kepercayaan audiens, dan perbesar peluang masuk ke halaman Explore tanpa butuh password.
    </p>

    <div class="mt-12 flex justify-center gap-4">
        <a href="#paket" class="button px-8 py-4 text-lg">Lihat Paket Harga</a>
        <a href="https://wa.me/6289634740308" class="button color-secondary px-8 py-4 text-lg">Konsultasi Gratis</a>
    </div>
  </section>

  <section class="container my-32">
    <h2 class="text-4xl md:text-5xl font-semibold mb-12 text-center">Mengapa Like Instagram Sangat Berpengaruh?</h2>
    <div class="grid gap-8 sm:grid-cols-2">
      {[
        { title: 'Sinyal Algoritma Explore', desc: 'Like adalah metrik utama algoritma Instagram. Rasio Like yang tinggi di menit-menit awal postingan tayang akan mendorong konten Anda masuk ke halaman Explore.' },
        { title: 'Social Proof & Kredibilitas', desc: 'Secara psikologis, audiens lebih percaya dan tertarik pada postingan atau bisnis yang sudah memiliki ribuan Like. Ini disebut efek Social Proof.' },
        { title: 'Meningkatkan Konversi Bisnis', desc: 'Untuk online shop, postingan produk dengan Like yang melimpah menghilangkan keraguan calon pembeli dan meningkatkan persentase closing.' },
        { title: 'Efek Domino Interaksi', desc: 'Postingan yang ramai Like memancing audiens organik untuk ikut berhenti scrolling, membaca caption, dan ikut berinteraksi (komen/share).' },
      ].map((b) => (
        <article class="p-8 rounded-3xl border bg-gradient-to-br from-purple-50 to-pink-50 dark:from-neutral-900/60 dark:to-neutral-900/20 border-purple-100 dark:border-neutral-800 shadow-sm">
          <h3 class="text-2xl font-semibold mb-3">{b.title}</h3>
          <p class="text-lg opacity-80">{b.desc}</p>
        </article>
      ))}
    </div>
  </section>

  <section id="paket" class="container my-32 py-16 bg-neutral-50 dark:bg-neutral-900/30 rounded-3xl">
  <div class="text-center mb-16">
    <h2 class="text-4xl md:text-5xl font-semibold mb-4">Paket Hemat Like Instagram</h2>
    <p class="text-xl opacity-80">Pilih paket sesuai kebutuhan Anda. Proses instan, aman, dan bergaransi.</p>
  </div>

  <div class="grid gap-8 md:grid-cols-3">
    {[
      { n: 'Paket Starter (10 Like)',   price: 'Rp 20.000',    note: 'Cocok untuk post harian & menjaga feed tetap aktif.' },
      { n: 'Paket Standart (100 Like)',  price: 'Rp 200.000',   note: 'Dorongan kuat untuk Reels masuk algoritma Explore.' },
      { n: 'Paket Grown (1.000 Like)', price: 'Rp 2.000.000', note: 'Membangun social proof maksimal untuk online shop/brand.' },
    ].map((p) => (
      <article class="rounded-3xl border border-neutral-200/70 dark:border-neutral-800/70 bg-white dark:bg-neutral-900 shadow-lg p-8 text-center hover:border-purple-500 transition-all duration-300 transform hover:-translate-y-2">
        <h3 class="text-2xl font-semibold">{p.n}</h3>
        <p class="mt-4 text-5xl font-extrabold tracking-tight text-transparent bg-clip-text bg-gradient-to-r from-purple-600 to-pink-600">{p.price}</p>
        <p class="mt-6 text-lg opacity-80 min-h-[60px]">{p.note}</p>

        <div class="mt-8">
          <a href={`https://wa.me/6289634740308?text=Halo%20Admin%20Jasalike,%20saya%20mau%20order%20${p.n}%20Instagram.`} target="_blank" rel="noopener"
             class="flex items-center justify-center w-full rounded-2xl px-6 py-4 font-bold bg-gradient-to-r from-green-500 to-emerald-600 text-white shadow-md hover:shadow-xl transition-all">
            Pesan Sekarang
          </a>
        </div>
      </article>
    ))}
  </div>
</section>

  <section id="faq" class="container my-32">
  <h2 class="text-4xl font-semibold mb-12 text-center">Pertanyaan Umum (FAQ)</h2>

  <div class="grid gap-6 md:grid-cols-2">
    <details class="rounded-2xl border border-neutral-200/70 dark:border-neutral-800/70 bg-white/60 dark:bg-neutral-900/60 p-6 group">
      <summary class="cursor-pointer text-xl font-semibold list-none flex justify-between items-center">
        Apakah aman dari banned Instagram?
        <span class="text-purple-600 group-open:rotate-180 transition-transform">↓</span>
      </summary>
      <div class="mt-4 opacity-80 pt-4 border-t border-neutral-200 dark:border-neutral-700 leading-relaxed">
        Sangat aman. Kami menggunakan metode pengiriman yang mematuhi batas wajar algoritma Instagram. Postingan Anda tidak akan dihapus dan akun Anda 100% terlindungi.
      </div>
    </details>

    <details class="rounded-2xl border border-neutral-200/70 dark:border-neutral-800/70 bg-white/60 dark:bg-neutral-900/60 p-6 group">
      <summary class="cursor-pointer text-xl font-semibold list-none flex justify-between items-center">
        Apakah bisa dipecah untuk banyak foto?
        <span class="text-purple-600 group-open:rotate-180 transition-transform">↓</span>
      </summary>
      <div class="mt-4 opacity-80 pt-4 border-t border-neutral-200 dark:border-neutral-700 leading-relaxed">
        Bisa! Minimal pemecahan adalah 10 Like per postingan. Jadi jika Anda order paket 100 Like, Anda bisa membaginya maksimal untuk 10 link foto atau Reels berbeda.
      </div>
    </details>
  </div>
</section>
</DefaultLayout>
