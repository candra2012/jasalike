---
// src/pages/kontak-admin-1.astro
import DefaultLayout from '../layouts/DefaultLayout.astro'
import Hero from '../components/Hero.astro'

const title = "Hubungi Admin | JasaLike";
const description = "Halaman kontak resmi JasaLike untuk konsultasi layanan dan bantuan operasional.";
const keywords = "admin vote jasalike, bantuan voting jasalike, layanan admin jasalike";

const dataHero = {
  tipe: "service",
  labelTeks: "Pusat Bantuan & Konsultasi",
  labelIcon: "lucide:headset",
  judulUtama: 'Solusi <span class="text-pink-600">Vote Cepat</span> untuk Hasil Maksimal',
  deskripsi: "Butuh bantuan untuk memenangkan polling atau vote? Tim admin JasaLike siap mengeksekusi strategi voting dengan cepat, aman, dan tepat sasaran.<br class='hidden md:block mt-2' /> <span class='text-pink-500 font-semibold block mt-4'>✓ Proses Vote Cepat &nbsp; ✓ Strategi Tepat Sasaran &nbsp; ✓ Kerahasiaan Terjaga</span>",
  teksTombol1: "Chat Admin Vote",
  // UBAH TEKS BAWAAN WA DI SINI SESUAI GRUP
  linkTombol1: "https://wa.me/6289634740308?text=Halo%20admin%20saya%20mau%20order%20Vote",
  teksTombol2: "Lihat Layanan Vote",
  linkTombol2: "/",
  gambarHero: "/image/hero-beranda.png" 
};
---

<DefaultLayout title={title} description={description} keywords={keywords}>
  <Fragment slot="head">
    <meta name="robots" content="noindex, nofollow" />
  </Fragment>

  <Hero {...dataHero} />
</DefaultLayout>
