---
// src/pages/layanan.astro
import DefaultLayout from '../layouts/DefaultLayout.astro'

// IMPORT KOMPONEN
import Hero from '../components/Hero.astro'
import LayananGrid from '../components/LayananGrid.astro'
import CaraOrder from '../components/CaraOrder.astro'
import DaftarHarga from '../components/DaftarHarga.astro'
import Testimonials from '../components/Testimonials.astro'
import MetodePembayaran from '../components/MetodePembayaran.astro'

// SEO DATA
const title = "Layanan Optimasi Sosmed Lengkap - JasaLike";
const description = "Pusat layanan optimasi engagement untuk semua platform sosial media. Tingkatkan kredibilitas akun Anda dengan proses aman dan hasil organik.";

// DATA HERO (Menggunakan tipe Service agar seragam)
const dataHero = {
  tipe: "service",
  labelTeks: "Solusi Optimasi Lengkap",
  labelIcon: "lucide:layers",
  judulUtama: 'Solusi <span class="text-blue-500">Optimasi Lengkap</span> <br class="hidden md:block"/> Untuk Semua Platform',
  deskripsi: "Pilih kategori platform yang ingin Anda optimasi. Kami menyediakan layanan interaksi berkualitas tinggi dengan sistem yang aman, stabil, dan profesional untuk membantu akun Anda berkembang lebih cepat. <br class='hidden md:block mt-2' /> <span class='text-blue-400 font-semibold block mt-4'>✓ Terintegrasi Semua Platform &nbsp; ✓ Proses Cepat & Garansi &nbsp; ✓ Privasi 100% Terjaga</span>",
  teksTombol1: "Lihat Semua Layanan",
  linkTombol1: "#grid-layanan",
  teksTombol2: "Konsultasi Gratis",
  linkTombol2: "https://wa.me/6289634740308",
  gambarHero: "/image/hero-layanan-lengkap.png" 
};
---

<DefaultLayout title={title} description={description}>
  
  <Hero {...dataHero} />

  <section id="grid-layanan">
    <LayananGrid />
  </section>

  <CaraOrder />

  <DaftarHarga />
  
  <div class="bg-white">
    <Testimonials />
  </div>

  <MetodePembayaran />

</DefaultLayout>
