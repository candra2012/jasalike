    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Apakah postingan atau grupnya harus bersifat Publik?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Ya, ini sangat wajib. Karena sistem kami bekerja secara eksternal, postingan Fanpage atau Grup tempat Anda berkomentar harus berstatus 'Publik' agar sistem dapat menemukan dan mendistribusikan like ke komentar tersebut."
        }
      },
      {
