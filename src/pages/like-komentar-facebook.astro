    "offers": {
      "@type": "AggregateOffer",
      "lowPrice": "200000",
      "highPrice": "2000000",
      "priceCurrency": "IDR",
      "offerCount": "4"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Beranda",
        "item": "https://jasalike.com/"
      },
      {
        "@type": "ListItem",
        "position": 2,
