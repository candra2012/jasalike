---
// src/pages/like-twitter.astro
import DefaultLayout from '../layouts/DefaultLayout.astro'
import { Icon } from 'astro-icon/components'
import Testimonials from '../components/Testimonials.astro'
import DaftarHarga from '../components/DaftarHarga.astro'
import MetodePembayaran from '../components/MetodePembayaran.astro'

const title = "Jasa Like Instagram Terpercaya & Aman - JasaLike";
const description = "Maksimalkan impresi tweet Anda dengan jasa like Twitter terpercaya. Interaksi organik manusia asli bantu dorong algoritma. Privasi aman, cukup setor tautan.";
const keywords = "jasa like twitter, jasa like retweet, jasa like retweet twitter, jasa like postingan, jasa like komen twitter, jasa like postingan twitter, jasa like twitter terpercaya";
---

<DefaultLayout title={title} description={description} keywords={keywords}>

     <Fragment slot="head">
    <script type="application/ld+json">
      [
        {
          "@context": "https://schema.org/",
          "@type": "Product",
          "name": "Jasa Like Twitter",
          "image": "https://jasalike.com/image/harga-paket-100like-twitter.png",
          "description": "Layanan optimasi penambah like Instagram secara instan, aman, dan tanpa password. Bergaransi penuh untuk meningkatkan interaksi dan masuk Explore.",
          "brand": {
            "@type": "Brand",
            "name": "JasaLike"
          },
          "aggregateRating": {
            "@type": "AggregateRating",
            "ratingValue": "4.9",
            "bestRating": "5",
            "worstRating": "1",
            "ratingCount": "1250"
          },
          "offers": {
            "@type": "AggregateOffer",
            "lowPrice": "250000",
            "highPrice": "2500000",
            "priceCurrency": "IDR",
            "offerCount": "4"
          }
        },
        {
          "@context": "https://schema.org",
          "@type": "BreadcrumbList",
          "itemListElement": [
            {
              "@type": "ListItem",
              "position": 1,
              "name": "Beranda",
              "item": "https://jasalike.com/"
            },
            {
              "@type": "ListItem",
              "position": 2,
              "name": "Layanan",
              "item": "https://jasalike.com/layanan/"
            },
            {
              "@type": "ListItem",
              "position": 3,
              "name": "Like Twitter"
            }
          ]
        }
      ]
    </script>
  </Fragment>
  
  <section class="relative pt-32 pb-24 lg:pt-40 lg:pb-32 bg-slate-950 overflow-hidden flex items-center">
    
    <div class="absolute inset-0 z-0">
      <img 
        src="/image/hero-jasalike-twitter.png" 
        alt="Background Layanan Jasa Tambah Like Twitter" 
        class="w-full h-full object-contain object-center opacity-40 block" 
      />
      <div class="absolute inset-0 bg-gradient-to-b from-slate-950 via-transparent to-slate-950"></div>
      <div class="absolute inset-0 bg-slate-950/40"></div> <div class="absolute top-1/4 left-0 w-96 h-96 bg-blue-600 rounded-full blur-[150px] opacity-20"></div>
    </div>

    <div class="relative z-10 container mx-auto px-6 text-center max-w-5xl animate-fade-in-up mt-10 lg:mt-0">
      
      <span class="inline-flex items-center gap-2 bg-blue-900/40 border border-blue-700/50 text-blue-300 px-4 py-1.5 rounded-full text-sm font-medium mb-8">
        <Icon name="lucide:twitter" class="w-4 h-4" />
        Layanan Amplifikasi Cuitan Premium
      </span>
      
      <h1 class="text-4xl md:text-6xl lg:text-7xl font-extrabold !text-white leading-[1.1] mb-8 tracking-tight">
        Jasa Like Twitter <br class="hidden md:block" /> <span class="text-blue-500">Rajai Arus Percakapan</span>
      </h1>
      
      <p class="text-lg md:text-xl text-slate-200 max-w-3xl mx-auto leading-relaxed">
        Kerap merasa cuitan atau utas berbobot Anda tenggelam di lautan <em>timeline</em>? Layanan <strong>jasa tambah like Twitter</strong> ini merupakan solusi mutakhir untuk menciptakan resonansi tinggi dan mengunci panggung di tab <strong class="text-white">For You</strong>. Lewat amplifikasi metrik interaksi yang masif, kami membantu memperluas jangkauan profil Anda, memicu keterlibatan audiens organik, serta mendongkrak otoritas opini di ekosistem X. <br class="hidden md:block mt-2" />
        <span class="text-blue-400 font-semibold block mt-4">✓ 100% Keterlibatan Akun Aktif &nbsp; ✓ Hanya Butuh URL Cuitan &nbsp; ✓ Perlindungan Performa Optimal</span>
      </p>

    </div>
  </section>

  <section class="py-24 bg-slate-900 border-t border-slate-800 overflow-hidden">
    <div class="max-w-6xl mx-auto px-6 grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
      <div class="order-2 lg:order-1 reveal-left">
        <div class="relative rounded-3xl overflow-hidden border border-slate-700 shadow-2xl">
          <img src="/image/apaitu-jasalike-twitter.png" alt="Ilustrasi Layanan Eskalasi Jangkauan Twitter" class="w-full h-auto object-cover opacity-80 hover:opacity-100 transition-opacity" />
        </div>
      </div>
      <div class="order-1 lg:order-2 reveal-right">
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-6">Mengenal Lebih Dalam Jasa Like Twitter</h2>
        <p class="text-slate-400 text-lg leading-relaxed mb-6">
          Fasilitas eskalasi jangkauan ini diformulasikan untuk menyelamatkan konten Anda dari kebisingan <em>platform mikroblog</em>. Mengingat persaingan atensi di X sangat brutal, akumulasi tombol suka yang hadir di menit-menit awal bertindak sebagai <strong>bahan bakar utama</strong> yang meyakinkan sistem untuk mendorong cuitan Anda menembus sekat pengikut (<em>followers</em>) inti.
        </p>
        <ul class="space-y-4">
          <li class="flex items-center gap-3 text-slate-300 font-medium">
            <Icon name="lucide:check-circle-2" class="w-6 h-6 text-blue-500 shrink-0" />
            Memaksimalkan potensi kemunculan di radar tab <em>For You</em> audiens yang lebih luas.
          </li>
          <li class="flex items-center gap-3 text-slate-300 font-medium">
            <Icon name="lucide:check-circle-2" class="w-6 h-6 text-blue-500 shrink-0" />
            Menancapkan reputasi digital yang kuat untuk memvalidasi opini atau promosi produk Anda.
          </li>
          <li class="flex items-center gap-3 text-slate-300 font-medium">
            <Icon name="lucide:check-circle-2" class="w-6 h-6 text-blue-500 shrink-0" />
            Distribusi apresiasi dijalankan sistematis, selaras dengan regulasi pembatasan (<em>rate limit</em>) X.
          </li>
        </ul>
      </div>
    </div>
