        </div>
      </div>
    </div>
  </section>

 <section class="py-24 bg-slate-950 overflow-hidden">
    <div class="max-w-5xl mx-auto px-6">
      <div class="text-center mb-16 reveal-up">
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">Langkah Taktis Kuasai Linimasa</h2>
        <p class="text-slate-400">Hanya butuh tiga fase singkat untuk memicu ledakan interaksi di akun X Anda.</p>
      </div>
      <div class="flex flex-col md:flex-row justify-between gap-8 relative">
