---
// src/components/MengapaMemilihJasaLike.astro
import { Icon } from 'astro-icon/components'
---
<section class="py-24 bg-slate-900 text-white overflow-hidden">
  <div class="max-w-6xl mx-auto px-6">
    
    <div class="text-center mb-20">
      <h2 class="text-3xl md:text-4xl font-extrabold mb-4 tracking-tight">
        Mengapa Memilih <span class="text-blue-400">JasaLike?</span>
      </h2>
      <p class="text-lg text-slate-400 max-w-2xl mx-auto leading-relaxed">
        Fokus melayani satu hal, membuat kami mampu memberikannya dengan sempurna. Ini alasan kreator dan pebisnis mempercayakan akunnya pada kami.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
      
      <div class="animate-on-scroll-dark opacity-0 translate-y-12 transform transition-all duration-700 ease-out p-8 rounded-2xl shadow-lg bg-slate-800 border border-slate-700 hover:border-blue-500 hover:-translate-y-2">
        <div class="w-14 h-14 bg-blue-500/20 text-blue-400 rounded-xl flex items-center justify-center mb-6">
          <Icon name="lucide:crosshair" class="w-8 h-8" />
        </div>
        <h3 class="text-xl font-bold mb-3">Sangat Fokus</h3>
        <p class="text-slate-400 text-sm leading-relaxed">
          Server kami didedikasikan khusus untuk memproses Like, menjadikannya jauh lebih stabil tanpa gangguan dari beban layanan lain.
        </p>
      </div>

      <div class="animate-on-scroll-dark opacity-0 translate-y-12 transform transition-all duration-700 ease-out delay-150 p-8 rounded-2xl shadow-lg bg-slate-800 border border-slate-700 hover:border-emerald-500 hover:-translate-y-2">
        <div class="w-14 h-14 bg-emerald-500/20 text-emerald-400 rounded-xl flex items-center justify-center mb-6">
          <Icon name="lucide:zap" class="w-8 h-8" />
        </div>
        <h3 class="text-xl font-bold mb-3">Super Cepat</h3>
        <p class="text-slate-400 text-sm leading-relaxed">
          Pesanan Like diproses secara instan karena sistem spesialis kami tidak perlu mengantre dengan pesanan bot campuran lainnya.
        </p>
      </div>

      <div class="animate-on-scroll-dark opacity-0 translate-y-12 transform transition-all duration-700 ease-out delay-300 p-8 rounded-2xl shadow-lg bg-slate-800 border border-slate-700 hover:border-purple-500 hover:-translate-y-2">
        <div class="w-14 h-14 bg-purple-500/20 text-purple-400 rounded-xl flex items-center justify-center mb-6">
          <Icon name="lucide:lock" class="w-8 h-8" />
        </div>
        <h3 class="text-xl font-bold mb-3">Privasi Terjaga</h3>
        <p class="text-slate-400 text-sm leading-relaxed">
          Transaksi 100% rahasia dan aman. Kami hanya butuh URL postingan, tanpa pernah meminta password media sosial Anda.
        </p>
      </div>

      <div class="animate-on-scroll-dark opacity-0 translate-y-12 transform transition-all duration-700 ease-out delay-[450ms] p-8 rounded-2xl shadow-lg bg-slate-800 border border-slate-700 hover:border-amber-500 hover:-translate-y-2">
        <div class="w-14 h-14 bg-amber-500/20 text-amber-400 rounded-xl flex items-center justify-center mb-6">
          <Icon name="lucide:percent" class="w-8 h-8" />
        </div>
        <h3 class="text-xl font-bold mb-3">Harga Spesial</h3>
        <p class="text-slate-400 text-sm leading-relaxed">
          Karena kami menyetok layanan Like dalam skala masif sebagai tangan pertama, kami bisa menekan harga jual jadi sangat murah.
        </p>
      </div>

    </div>
  </div>
</section>

<script>
  // 👇 is:inline dihapus, dan pelatuk diganti jadi astro:page-load
  document.addEventListener("astro:page-load", () => {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.remove('opacity-0', 'translate-y-12');
          entry.target.classList.add('opacity-100', 'translate-y-0');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1 });

    const boxes = document.querySelectorAll('.animate-on-scroll-dark');
    boxes.forEach((box) => observer.observe(box));
  });
</script>
