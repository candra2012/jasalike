---
// src/components/CaraOrder.astro
import { Icon } from 'astro-icon/components';
---
<section class="py-24 bg-slate-900 text-white">
  <div class="max-w-6xl mx-auto px-6">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-extrabold mb-4">3 Langkah Mudah <span class="text-blue-400">Order</span></h2>
      <p class="text-slate-400">Proses transaksi yang simpel dan transparan.</p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
      <div class="text-center">
        <div class="text-5xl font-black text-blue-500/20 mb-4 italic">01</div>
        <h4 class="text-xl font-bold mb-2 text-white">Pilih Paket</h4>
        <p class="text-slate-400 text-sm">Cek pricelist lengkap di spreadsheet atau tanya admin langsung.</p>
      </div>
      <div class="text-center">
        <div class="text-5xl font-black text-blue-500/20 mb-4 italic">02</div>
        <h4 class="text-xl font-bold mb-2 text-white">Kirim Link & Bayar</h4>
        <p class="text-slate-400 text-sm">Cukup kirim URL postingan (tanpa password) & lakukan pembayaran.</p>
      </div>
      <div class="text-center">
        <div class="text-5xl font-black text-blue-500/20 mb-4 italic">03</div>
        <h4 class="text-xl font-bold mb-2 text-white">Pantau Hasilnya</h4>
        <p class="text-slate-400 text-sm">Orderan diproses instan, like akan masuk secara bertahap & natural.</p>
      </div>
    </div>
  </div>
</section>
