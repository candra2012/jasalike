---
// src/components/MasalahJasaLike.astro
const {
  judulUtama,
  deskripsiUtama,
  ms1Judul, ms1Teks,
  ms2Judul, ms2Teks,
  ms3Judul, ms3Teks
} = Astro.props;
---
<section id="masalah" class="py-24 bg-slate-50">
  <div class="max-w-6xl mx-auto px-6">
    
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-extrabold text-slate-900 mb-4 tracking-tight" set:html={judulUtama}></h2>
      <p class="text-lg text-slate-600 max-w-2xl mx-auto leading-relaxed">
        {deskripsiUtama}
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      
      <div class="bg-white rounded-2xl p-8 border border-slate-200 shadow-md hover:shadow-xl hover:border-blue-200 transition-all duration-300 transform hover:-translate-y-1">
        <div class="w-14 h-14 bg-red-50 text-red-500 rounded-xl flex items-center justify-center mb-6">
          <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 17h8m0 0V9m0 8l-8-8-4 4-6-6"></path></svg>
        </div>
        <h3 class="text-xl font-bold text-slate-900 mb-3">{ms1Judul}</h3>
        <p class="text-slate-600 leading-relaxed">{ms1Teks}</p>
      </div>

      <div class="bg-white rounded-2xl p-8 border border-slate-200 shadow-md hover:shadow-xl hover:border-blue-200 transition-all duration-300 transform hover:-translate-y-1">
        <div class="w-14 h-14 bg-amber-50 text-amber-500 rounded-xl flex items-center justify-center mb-6">
          <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path></svg>
        </div>
        <h3 class="text-xl font-bold text-slate-900 mb-3">{ms2Judul}</h3>
        <p class="text-slate-600 leading-relaxed">{ms2Teks}</p>
      </div>

      <div class="bg-white rounded-2xl p-8 border border-slate-200 shadow-md hover:shadow-xl hover:border-blue-200 transition-all duration-300 transform hover:-translate-y-1">
        <div class="w-14 h-14 bg-slate-100 text-slate-600 rounded-xl flex items-center justify-center mb-6">
          <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path></svg>
        </div>
        <h3 class="text-xl font-bold text-slate-900 mb-3">{ms3Judul}</h3>
        <p class="text-slate-600 leading-relaxed">{ms3Teks}</p>
      </div>

    </div>
  </div>
</section>

