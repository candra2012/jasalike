---
// src/components/FloatingCS.astro
import { Icon } from 'astro-icon/components'
---

<!-- WA kita patenkan di bottom 30px dan right 30px -->
<a
  href="https://wa.me/6289634740308?text=Halo%20saya%20mau%20tanya%20layanan%20jasa%20like."
  target="_blank"
  rel="noopener noreferrer"
  class="fixed z-[100] group flex items-center gap-3 bg-[#0f172a] hover:bg-[#1e293b] border border-slate-700 p-2 pr-5 rounded-full shadow-2xl hover:shadow-blue-500/30 transition-all duration-300 no-underline"
  style="bottom: 30px; right: 30px;" 
  aria-label="Tanya CS JasaLike"
>
  <div class="bg-gradient-to-br from-blue-600 to-cyan-500 p-3 rounded-full group-hover:scale-110 transition-transform duration-300 shadow-md">
    <Icon name="lucide:headset" class="w-5 h-5 text-white" />
  </div>
  <span class="font-bold text-white text-sm md:text-base tracking-wide no-underline">
    Tanya Team Jasalike
  </span>
</a>

<style>
  a { animation: float 4s ease-in-out infinite; }
  @keyframes float {
    0% { transform: translateY(0px); }
    50% { transform: translateY(-8px); }
    100% { transform: translateY(0px); }
  }
</style>
