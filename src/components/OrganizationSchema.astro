---
interface Props {
  name?: string
  url?: string
  logo?: string
  sameAs?: string[]
  telephone?: string
  languages?: string[]
}

const {
  name = 'Jasalike',
  url = 'https://jasalike.my.id',
  // Menggunakan nama file yang sesuai dengan aset Anda untuk URL publik
  logo = 'https://jasalike.com/logo-jasalike.png',
  sameAs = [
    'https://www.instagram.com/jasa.like.asli'
  ],
  telephone = '+62-896-3474-0308',
  languages = ['Indonesian', 'English'],
}: Props = Astro.props

const site = url.replace(/\/$/, '')

const data = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  '@id': `${site}/#organization`,
  name,
  url: `${site}/`,
  logo: { '@type': 'ImageObject', url: logo },
  sameAs,
  contactPoint: [{
    '@type': 'ContactPoint',
    telephone,
    contactType: 'customer service',
    availableLanguage: languages
  }]
}
---

<script type="application/ld+json" set:html={JSON.stringify(data)}></script>
