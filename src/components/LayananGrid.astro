---
// src/components/LayananGrid.astro
import { Icon } from 'astro-icon/components'

// DATA SEMUA LAYANAN (FOKUS 100% JASA LIKE - TERBARU)
const allServices = [
  {
    name: "Instagram",
    icon: "lucide:instagram",
    color: "text-pink-600",
    bg: "bg-pink-600/10",
    desc: "Jasa Like Instagram aktif untuk postingan dan Reels agar konten terlihat lebih kredibel.",
    link: "/like-instagram", 
  },
  {
    name: "TikTok",
    icon: "lucide:music-2",
    color: "text-slate-900", 
    bg: "bg-slate-900/10",
    desc: "Jasa Like TikTok premium untuk mendorong video Anda lebih cepat dan mudah masuk FYP.",
    link: "/like-tiktok",
  },
  {
    name: "Facebook",
    icon: "lucide:facebook",
    color: "text-blue-600",
    bg: "bg-blue-600/10",
    desc: "Optimasi Jasa Like Facebook untuk Postingan, Fanpage, dan Reels secara natural.",
    link: "/like-facebook",
  },
  {
    name: "LinkedIn",
    icon: "lucide:linkedin",
    color: "text-blue-700",
    bg: "bg-blue-700/10",
    desc: "Jasa Like LinkedIn untuk membangun otoritas B2B & menarik perhatian HRD secara profesional.",
    link: "/like-linkedin",
  },
  {
    name: "YouTube",
    icon: "lucide:youtube",
    color: "text-red-600",
    bg: "bg-red-600/10",
    desc: "Jasa Like YouTube organik untuk meningkatkan metrik interaksi dan ranking video di pencarian.",
    link: "/like-youtube",
  },
  {
    name: "Twitter / X",
    icon: "lucide:twitter",
    color: "text-slate-800", 
    bg: "bg-slate-800/10",
    desc: "Jasa Like Twitter/X untuk meramaikan interaksi Tweet agar lebih mudah menjadi Trending Topic.",
    link: "/like-twitter",
  },
  {
    name: "Threads",
    icon: "lucide:at-sign", // Menggunakan ikon '@' khas Threads
    color: "text-neutral-900", 
    bg: "bg-neutral-900/10",
    desc: "Jasa Like Threads aktif untuk mendongkrak popularitas dan engagement postingan Threads Anda.",
    link: "/like-threads",
  },
  {
    name: "Like Komentar Instagram",
    icon: "lucide:instagram", // Ikon balon obrolan komentar
    color: "text-emerald-600", 
    bg: "bg-emerald-600/10",
    desc: "Jasa Like Komentar khusus untuk menaikkan posisi komentar Anda menjadi urutan teratas (Top Comment).",
    link: "/like-komentar-instagram",
  },
{
    name: "Like Komentar TikTok",
    icon: "lucide:music-2",
    color: "text-slate-900", 
    bg: "bg-slate-900/10",
    desc: "Jasa like komentar TikTok cepat & aman untuk membantu komentar tampil lebih menonjol.",
    link: "/like-komentar-tiktok",
  },
];
---

<section class="relative py-24 bg-[#0B1121] overflow-hidden">
  
  <div class="absolute inset-0 bg-[radial-gradient(#ffffff_2px,transparent_2px)] [background-size:32px_32px] [background-position:16px_16px] z-0 animate-twinkle opacity-30"></div>
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full max-w-7xl h-[600px] bg-blue-600/20 blur-[140px] rounded-full pointer-events-none z-0"></div>

  <div class="container relative z-10 mx-auto px-6">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {allServices.map((item) => (
        <a href={item.link} class="group block !no-underline hover:!no-underline bg-white border border-slate-200 p-8 rounded-[2rem] hover:border-blue-500 transition-all duration-300 hover:shadow-2xl hover:shadow-blue-500/20">
          <div class={`w-16 h-16 ${item.bg} ${item.color} rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform`}>
            <Icon name={item.icon} class="w-8 h-8" />
          </div>
          
          <h3 class="text-2xl font-bold text-slate-900 mb-3 !no-underline">{item.name}</h3>
          
          <p class="text-slate-600 leading-relaxed mb-6 !no-underline">
            {item.desc}
          </p>
          
          <div class="flex items-center gap-2 text-blue-600 font-semibold group-hover:gap-4 transition-all !no-underline">
            Lihat Detail Layanan <Icon name="lucide:arrow-right" class="w-5 h-5" />
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
