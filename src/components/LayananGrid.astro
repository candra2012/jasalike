---
// src/components/LayananGrid.astro
import { Icon } from 'astro-icon/components'

// DATA SEMUA LAYANAN (FOKUS 100% JASA LIKE - TERBARU)
const layananGrid = [
  {
    nama: "Instagram",
    icon: "lucide:instagram",
    colorClass: "text-pink-600",
    bgClass: "bg-pink-600/10",
    deskripsi: "Jasa Like Instagram aktif untuk postingan dan Reels agar konten terlihat lebih kredibel.",
    link: "/like-instagram", 
  },
  {
    nama: "TikTok",
    icon: "lucide:music-2",
    colorClass: "text-slate-900", 
    bgClass: "bg-slate-900/10",
    deskripsi: "Jasa Like TikTok premium untuk mendorong video Anda lebih cepat dan mudah masuk FYP.",
    link: "/like-tiktok",
  },
  {
    nama: "Facebook",
    icon: "lucide:facebook",
    colorClass: "text-blue-600",
    bgClass: "bg-blue-600/10",
    deskripsi: "Optimasi Jasa Like Facebook untuk Postingan, Fanpage, dan Reels secara natural.",
    link: "/like-facebook",
  },
  {
    nama: "LinkedIn",
    icon: "lucide:linkedin",
    colorClass: "text-blue-700",
    bgClass: "bg-blue-700/10",
    deskripsi: "Jasa Like LinkedIn untuk membangun otoritas B2B & menarik perhatian HRD secara profesional.",
    link: "/like-linkedin",
  },
  {
    nama: "YouTube",
    icon: "lucide:youtube",
    colorClass: "text-red-600",
    bgClass: "bg-red-600/10",
    deskripsi: "Jasa Like YouTube organik untuk meningkatkan metrik interaksi dan ranking video di pencarian.",
    link: "/like-youtube",
  },
  {
    nama: "Twitter / X",
    icon: "lucide:twitter",
    colorClass: "text-slate-800", 
    bgClass: "bg-slate-800/10",
    deskripsi: "Jasa Like Twitter/X untuk meramaikan interaksi Tweet agar lebih mudah menjadi Trending Topic.",
    link: "/like-twitter",
  },
  {
    nama: "Threads",
    icon: "lucide:at-sign", 
    colorClass: "text-neutral-900", 
    bgClass: "bg-neutral-900/10",
    deskripsi: "Jasa Like Threads aktif untuk mendongkrak popularitas dan engagement postingan Threads Anda.",
    link: "/like-threads",
  },
  {
    nama: "Like Komentar Instagram",
    icon: "lucide:instagram", 
    colorClass: "text-emerald-600", 
    bgClass: "bg-emerald-600/10",
    deskripsi: "Jasa Like Komentar khusus untuk menaikkan posisi komentar Anda menjadi urutan teratas (Top Comment).",
    link: "/like-komentar-instagram",
  },
  {
    nama: "Like Komentar TikTok",
    icon: "lucide:music-2",
    colorClass: "text-slate-900", 
    bgClass: "bg-slate-900/10",
    deskripsi: "Jasa like komentar TikTok cepat & aman untuk membantu komentar tampil lebih menonjol.",
    link: "/like-komentar-tiktok",
  },
{
    nama: "Like Komentar YouTube",
    icon: "lucide:youtube",
    colorClass: "text-red-600",
    bgClass: "bg-red-600/10",
    deskripsi: "Jasa like komentar YouTube terpercaya, proses cepat, aman, dan cocok untuk berbagai kebutuhan.",
    link: "/like-komentar-youtube",
  },
{
    nama: "Like Komentar Twitter / X",
    icon: "lucide:twitter", 
    colorClass: "text-sky-500", 
    bgClass: "bg-sky-500/10",
    deskripsi: "Jasa like komentar Twitter (X) premium untuk mendongkrak ulasan Anda menjadi Top Reply di cuitan populer.",
    link: "/like-komentar-twitter",
  },
{
    nama: "Like Komentar Facebook",
    icon: "lucide:facebook", 
    colorClass: "text-blue-600", 
    bgClass: "bg-blue-600/10",
    deskripsi: "Jasa like komentar Facebook terpercaya untuk mendominasi filter 'Paling Relevan' di Fanpage dan Grup Publik.",
    link: "/like-komentar-facebook",
  }
];
---

<section class="py-16 md:py-24 bg-slate-900 relative">
  <div class="container mx-auto px-6 max-w-7xl relative z-10">
    
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-5 md:gap-6 mt-10">
      
      {layananGrid.map((item) => (
        <div class="bg-white rounded-2xl p-6 shadow-sm border border-slate-200 hover:shadow-xl hover:-translate-y-1 transition-all duration-300 flex flex-col h-full">
          
          <div class={`w-12 h-12 rounded-[1rem] flex items-center justify-center mb-4 ${item.bgClass || 'bg-blue-50'} ${item.colorClass || 'text-blue-600'}`}>
            <Icon name={item.icon || 'lucide:box'} class="w-6 h-6" />
          </div>

          <h3 class="text-xl font-bold text-slate-900 mb-2">{item.nama}</h3>

          <p class="text-slate-600 text-sm leading-relaxed mb-6 flex-grow">
            {item.deskripsi}
          </p>

          <a href={item.link} class="inline-flex items-center text-blue-600 font-bold text-sm hover:text-blue-700 transition-colors mt-auto group">
            Lihat Detail Layanan 
            <Icon name="lucide:arrow-right" class="w-4 h-4 ml-1.5 transition-transform group-hover:translate-x-1" />
          </a>
          
        </div>
      ))}

    </div>
  </div>
</section>

