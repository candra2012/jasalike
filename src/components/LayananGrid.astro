<section class="py-16 md:py-24 bg-slate-900 relative">
  <div class="container mx-auto px-6 max-w-7xl relative z-10">

    <div class="text-center mb-16">
       <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">Layanan JasaLike per Platform</h2>
       <p class="text-slate-400">Pilih platform yang ingin Anda optimasi untuk melihat detail layanan kami.</p>
    </div>

    <!-- RUANG UNTUK SETIAP PLATFORM -->
    <div class="space-y-12">
      {kategoriLayanan.map((kategori) => (
        <div class="bg-slate-800/50 rounded-2xl p-6 md:p-8 border border-slate-700/50">

          <!-- Header Platform -->
          <div class={`flex items-center gap-3 mb-6 border-b ${kategori.borderKategori} pb-4`}>
            <Icon name={kategori.iconKategori} class={`w-7 h-7 md:w-8 md:h-8 ${kategori.warnaKategori}`} />
            <h2 class="text-xl md:text-2xl font-bold text-white tracking-wide">{kategori.platform}</h2>
          </div>

          <!-- Grid Layanan Compact (Minimalis) -->
          <!-- Kolom: 1 (HP), 2 (Tablet), 3 (Laptop Kecil), 4 (Layar Besar) -->
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
            {kategori.items.map((item) => (

              <!-- Seluruh Kotak Menjadi Link yang Bisa Diklik -->
             <a href={item.link} class="group !no-underline bg-white rounded-xl p-4 shadow-sm border border-slate-200 hover:shadow-md hover:border-blue-400 hover:-translate-y-1 transition-all duration-300 flex items-start gap-4">

                <!-- Ikon di Kiri -->
                <div class={`shrink-0 w-10 h-10 rounded-lg flex items-center justify-center transition-transform group-hover:scale-110 ${item.bgClass || 'bg-blue-50'} ${item.colorClass || 'text-blue-600'}`}>
                  <Icon name={item.icon || 'lucide:box'} class="w-5 h-5" />
                </div>

                <!-- Teks di Kanan -->
                <div class="flex-grow">
                  <h3 class="text-sm md:text-base font-bold text-slate-900 group-hover:text-blue-600 transition-colors">
                    {item.nama}
                  </h3>
                  <!-- line-clamp-2 akan memotong teks yang terlalu panjang jadi titik-titik (...) -->
                  <p class="text-xs text-slate-500 mt-1 leading-relaxed line-clamp-2">
                    {item.deskripsi}
                  </p>
                </div>

              </a>

            ))}
          </div>

        </div>
      ))}
    </div>

  </div>
</section>

<style>
  /* JURUS PAKSA: Menghilangkan garis bawah ungu dari CSS Global */
  a, a h3, a p {
    text-decoration: none !important;
    border-bottom: none !important;
    box-shadow: none !important;
  }
</style>
