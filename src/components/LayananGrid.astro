---

<section class="py-16 md:py-24 bg-slate-900 relative">
  <div class="container mx-auto px-6 max-w-7xl relative z-10">
    
    <div class="text-center mb-16">
       <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">Layanan JasaLike per Platform</h2>
       <p class="text-slate-400">Pilih platform yang ingin Anda optimasi untuk melihat detail layanan kami.</p>
    </div>

    <div class="space-y-16">
      {kategoriLayanan.map((kategori) => (
        <div>
          <div class={`flex items-center gap-3 mb-6 border-b ${kategori.borderKategori} pb-3`}>
            <Icon name={kategori.iconKategori} class={`w-8 h-8 ${kategori.warnaKategori}`} />
            <h2 class="text-2xl font-bold text-white">{kategori.platform}</h2>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-5 md:gap-6">
            {kategori.items.map((item) => (
              <div class="bg-white rounded-2xl p-6 shadow-sm border border-slate-200 hover:shadow-xl hover:-translate-y-1 transition-all duration-300 flex flex-col h-full group">
                
                <div class={`w-12 h-12 rounded-[1rem] flex items-center justify-center mb-4 transition-transform group-hover:scale-110 ${item.bgClass || 'bg-blue-50'} ${item.colorClass || 'text-blue-600'}`}>
                  <Icon name={item.icon || 'lucide:box'} class="w-6 h-6" />
                </div>

                <h3 class="text-xl font-bold text-slate-900 mb-2">{item.nama}</h3>

                <p class="text-slate-600 text-sm leading-relaxed mb-6 flex-grow">
                  {item.deskripsi}
                </p>

                <a href={item.link} class="inline-flex items-center text-blue-600 font-bold text-sm hover:text-blue-700 transition-colors mt-auto group/link">
                  Lihat Detail Layanan 
                  <Icon name="lucide:arrow-right" class="w-4 h-4 ml-1.5 transition-transform group-hover/link:translate-x-1" />
                </a>
                
              </div>
            ))}
          </div>

        </div>
      ))}
    </div>

  </div>
</section>

