<script is:inline>
  // 1. TANGKAP & SIMPAN KODE REFERRAL
  const params = new URLSearchParams(window.location.search);
  const ref = params.get('ref');

  if (ref) {
    localStorage.setItem('affiliate_ref', ref);
    console.log('Referral berhasil dikunci di memori:', ref);
  }

  // 2. SENSOR KLIK GLOBAL (Kebal untuk 86 Halaman & View Transitions Astro)
  window.addEventListener('click', (e) => {
    // Cari apakah elemen yang diklik (atau bungkusnya) adalah tag link <a>
    const anchor = e.target.closest('a');
    if (!anchor) return;

    const href = anchor.href;

    // Cek apakah link yang diklik menuju WhatsApp
    if (href.includes('wa.me') || href.includes('api.whatsapp.com')) {
      const savedRef = localStorage.getItem('affiliate_ref');
      if (!savedRef) return; // Jika tidak ada ref, biarkan link wa normal

      // Cegah penempelan ganda jika tombol diklik berkali-kali
      if (href.includes(savedRef)) return;

      // Amunisi teks referral yang mau disisipkan
      const textTambahan = "\n\nKode Referral: " + savedRef;

      // Logika pembentukan URL WhatsApp yang presisi
      let newHref = href;
      if (href.includes('text=')) {
        // Jika sudah ada teks bawaannya, langsung sambung di ekornya
        newHref = href + encodeURIComponent(textTambahan);
      } else {
        // Jika belum ada parameter teks, cek apakah sudah ada tanda tanya (?) di URL-nya
        const separator = href.includes('?') ? '&' : '?';
        newHref = href + separator + 'text=' + encodeURIComponent(textTambahan);
      }

      // Ubah link tujuan secara real-time tepat saat diklik
      anchor.href = newHref;
      console.log('Berhasil menyisipkan teks ke WhatsApp:', anchor.href);
    }
  });
</script>

