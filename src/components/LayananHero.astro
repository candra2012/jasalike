---
// src/components/LayananHero.astro
import { Icon } from 'astro-icon/components';
---
<section class="relative py-24 lg:py-32 bg-slate-950 overflow-hidden">
  <div class="absolute inset-0 z-0">
    <div class="absolute bottom-0 left-0 right-0 top-0 bg-[linear-gradient(to_right,#1e293b_1px,transparent_1px),linear-gradient(to_bottom,#1e293b_1px,transparent_1px)] bg-[size:4rem_4rem] [mask-image:radial-gradient(ellipse_60%_50%_at_50%_50%,#000_70%,transparent_100%)]"></div>
  </div>

  <div class="relative z-10 container mx-auto px-6 text-center pt-20">
    <h1 class="text-4xl md:text-6xl font-extrabold text-white mb-6 tracking-tight">
      Solusi <span class="text-blue-500">Optimasi Lengkap</span> <br/> Untuk Semua Platform
    </h1>
    <p class="text-lg md:text-xl text-slate-400 max-w-2xl mx-auto leading-relaxed">
      Pilih kategori platform yang ingin Anda optimasi. Kami menyediakan layanan interaksi berkualitas tinggi untuk membantu akun Anda berkembang lebih cepat.
    </p>
  </div>
</section>
