---
const API =
"https://script.google.com/macros/s/AKfycbyEREB__t-bEqEOkri9R_YB-DclLyAXJUpYbfV9O1g-BIRWK0-bSed_HcNhA74CT2-eWw/exec?action=getMateri";

const res = await fetch(API);

const json = await res.json();

const materiPromosi = json.materi;
---

<section id="materi" class="py-20 bg-slate-50">

<div class="container mx-auto px-4">

<div class="max-w-3xl mx-auto text-center mb-14">

<h2 class="text-4xl font-black mb-4">
📂 Pusat Materi Promosi
</h2>

<p class="text-slate-600 leading-8">

Silakan download seluruh materi promosi resmi
Affiliate JasaLike.

Template akan diperbarui secara berkala.

</p>

</div>

<div class="mb-10">

<input
id="searchMateri"
type="text"
placeholder="Cari template..."
class="w-full border rounded-xl px-5 py-4 shadow-sm focus:ring-2 focus:ring-blue-500 outline-none"
/>

</div>

<div
id="gridMateri"
class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-8">

{

materiPromosi.map(item=>(

<div
class="bg-white rounded-2xl shadow-lg overflow-hidden hover:shadow-xl transition">

<img
src={item.Preview}
alt={item.Judul}
class="w-full h-64 object-cover"
/>

<div class="p-6">

<div class="flex justify-between items-center mb-3">

<span
class="bg-blue-100 text-blue-700 px-3 py-1 rounded-full text-xs font-bold">

{item.Platform}

</span>

<span
class="bg-green-100 text-green-700 px-3 py-1 rounded-full text-xs font-bold">

Terbaru

</span>

    <span
class="bg-orange-100 text-orange-700 px-3 py-1 rounded-full text-xs font-bold">

🖼 {item["Jumlah Gambar"]} Gambar

</span>

</div>

<h3 class="text-xl font-bold mb-2">

{item.Judul}

</h3>

<p class="text-sm text-slate-500 mb-6">

Update :

{new Date(item.Update).toLocaleDateString("id-ID")}

</p>

<div class="grid gap-3">

    <button
class="btnPreview w-full bg-slate-700 hover:bg-slate-800 text-white font-bold py-3 rounded-xl transition flex items-center justify-center gap-2"
data-image={item.Preview}>

👁 Preview Gambar

</button>

<button
class="btnDownload w-full bg-blue-600 hover:bg-blue-700 text-white font-bold py-3 rounded-xl transition flex items-center justify-center gap-2"
data-download={item.Download}>

⬇ Download Template

</button>

<div class="space-y-2">
  <label class="text-xs font-semibold text-slate-500 uppercase tracking-wide">Caption</label>
  <textarea
    readonly
    class="w-full h-24 p-3 text-sm text-slate-700 bg-slate-50 border border-slate-200 rounded-xl resize-none focus:outline-none focus:ring-2 focus:ring-green-500"
  >{item.Caption}</textarea>
  <button
    class="btnCaption w-full bg-green-600 hover:bg-green-700 text-white font-bold py-3 rounded-xl transition flex items-center justify-center gap-2"
    data-caption={item.Caption}>
    📋 Salin Caption
  </button>
</div>

<div class="space-y-2">
  <label class="text-xs font-semibold text-slate-500 uppercase tracking-wide">Hashtag</label>
  <textarea
    readonly
    class="w-full h-20 p-3 text-sm text-slate-700 bg-slate-50 border border-slate-200 rounded-xl resize-none focus:outline-none focus:ring-2 focus:ring-purple-500"
  >{item.Hastag}</textarea>
  <button
    class="btnHashtag w-full bg-purple-600 hover:bg-purple-700 text-white font-bold py-3 rounded-xl transition flex items-center justify-center gap-2"
    data-hashtag={item.Hastag}>
    🏷 Salin Hashtag
  </button>
</div>

</div>

</div>

</div>

))

}

</div>

</div>

<div
id="lightbox"
class="hidden fixed inset-0 bg-black/80 z-50 flex items-center justify-center p-5">

<div class="relative">

<button
id="closePreview"
class="absolute -top-4 -right-4 bg-white rounded-full w-10 h-10 font-bold">

✕

</button>

<img
id="previewImage"
src=""
class="max-h-[90vh] rounded-xl shadow-2xl"/>

</div>

</div>

</section>

<script is:inline>

document.addEventListener("astro:page-load",()=>{

//==============================
// SEARCH TEMPLATE
//==============================

const search =
document.getElementById("searchMateri");

if(search){

search.addEventListener("keyup",()=>{

const keyword =
search.value.toLowerCase();

document.querySelectorAll("#gridMateri > div")

.forEach(card=>{

const teks =
card.innerText.toLowerCase();

card.style.display =
teks.includes(keyword)
? ""
: "none";

});

});

}

//==============================
// COPY CAPTION
//==============================

document
.querySelectorAll(".btnCaption")
.forEach(btn=>{

btn.addEventListener("click",()=>{

navigator.clipboard.writeText(
btn.dataset.caption
);

const lama =
btn.innerHTML;

btn.innerHTML =
"✅ Caption Tersalin";

setTimeout(()=>{

btn.innerHTML = lama;

},2000);

});

});

//==============================
// COPY HASHTAG
//==============================

document
.querySelectorAll(".btnHashtag")
.forEach(btn=>{

btn.addEventListener("click",()=>{

navigator.clipboard.writeText(
btn.dataset.hashtag
);

const lama =
btn.innerHTML;

btn.innerHTML =
"✅ Hashtag Tersalin";

setTimeout(()=>{

btn.innerHTML = lama;

},2000);

});

});

//==============================
// PREVIEW GAMBAR
//==============================

const lightbox =
document.getElementById("lightbox");

const preview =
document.getElementById("previewImage");

if(lightbox && preview){

document
.querySelectorAll(".btnPreview")
.forEach(btn=>{

btn.addEventListener("click",()=>{

preview.src =
btn.dataset.image;

lightbox.classList.remove("hidden");

});

});

document
.getElementById("closePreview")
.addEventListener("click",()=>{

lightbox.classList.add("hidden");

});

lightbox.addEventListener("click",(e)=>{

if(e.target === lightbox){

lightbox.classList.add("hidden");

}

});

}

//==============================
// DOWNLOAD TEMPLATE
//==============================

document
.querySelectorAll(".btnDownload")
.forEach(btn=>{

btn.addEventListener("click",async()=>{

const url =
btn.dataset.download;

if(!url){

alert("Link download belum tersedia.");

return;

}

try{

const response =
await fetch(url);

const blob =
await response.blob();

const blobUrl =
window.URL.createObjectURL(blob);

const a =
document.createElement("a");

a.href = blobUrl;

a.download =
"template-jasalike";

document.body.appendChild(a);

a.click();

document.body.removeChild(a);

window.URL.revokeObjectURL(blobUrl);

}catch(err){

window.open(url,"_blank");

}

});

});

});

</script>
