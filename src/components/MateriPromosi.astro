---
const materiPromosi = [

{
id:1,
judul:"Template Instagram Feed #01",
platform:"Instagram",
badge:"Terbaru",
tanggal:"20 Juni 2026",
preview:"/image/template-instagram-1.webp",
download:"#",

caption:
`🚀 Mau akun Instagram terlihat lebih ramai?

Gunakan layanan JasaLike sekarang juga.

✅ Like Instagram
✅ Followers
✅ Komentar
✅ Views

Klik link berikut:
https://jasalike.com`,

hashtag:
`#jasalike
#jasainstagram
#likeinstagram
#followersinstagram`
},

{
id:2,
judul:"Template Instagram Feed #02",
platform:"Instagram",
badge:"Terbaru",
tanggal:"20 Juni 2026",
preview:"/image/template-instagram-2.webp",
download:"#",

caption:
`🔥 Mau postingan Instagram lebih dipercaya?

Gunakan JasaLike sekarang juga.

Klik link berikut:
https://jasalike.com`,

hashtag:
`#jasalike
#instagram
#viral
#explore`
},

{
id:3,
judul:"Template TikTok #01",
platform:"TikTok",
badge:"Baru",
tanggal:"20 Juni 2026",
preview:"/image/template-tiktok-1.webp",
download:"#",

caption:
`🔥 Tingkatkan engagement TikTok Anda bersama JasaLike.`,

hashtag:
`#tiktok
#jasalike
#fyp`
}

];
---

<section id="materi" class="py-20 bg-slate-50">

<div class="container mx-auto px-4">

<div class="max-w-3xl mx-auto text-center mb-14">

<h2 class="text-4xl font-black mb-4">
📂 Pusat Materi Promosi
</h2>

<p class="text-slate-600 leading-8">

Silakan download seluruh materi promosi resmi
Affiliate JasaLike.

Template akan diperbarui secara berkala.

</p>

</div>

<div class="mb-10">

<input
id="searchMateri"
type="text"
placeholder="Cari template..."
class="w-full border rounded-xl px-5 py-4 shadow-sm focus:ring-2 focus:ring-blue-500 outline-none"
/>

</div>

<div
id="gridMateri"
class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-8">

{

materiPromosi.map(item=>(

<div
class="bg-white rounded-2xl shadow-lg overflow-hidden hover:shadow-xl transition">

<img
src={item.preview}
alt={item.judul}
class="w-full h-64 object-cover"
/>

<div class="p-6">

<div class="flex justify-between items-center mb-3">

<span
class="bg-blue-100 text-blue-700 px-3 py-1 rounded-full text-xs font-bold">

{item.platform}

</span>

<span
class="bg-green-100 text-green-700 px-3 py-1 rounded-full text-xs font-bold">

{item.badge}

</span>

    <span
class="bg-orange-100 text-orange-700 px-3 py-1 rounded-full text-xs font-bold">

🖼 4 Gambar

</span>

</div>

<h3 class="text-xl font-bold mb-2">

{item.judul}

</h3>

<p class="text-sm text-slate-500 mb-6">

Update :

{item.tanggal}

</p>

<div class="grid gap-3">

    <button
class="btnPreview w-full bg-slate-700 hover:bg-slate-800 text-white font-bold py-3 rounded-xl transition"
data-image={item.preview}>

👁 Preview Gambar

</button>

<a
href={item.download}
target="_blank"
class="w-full bg-blue-600 hover:bg-blue-700 text-white font-bold py-3 rounded-xl text-center transition">

⬇ Download Template

</a>

<button
class="btnCaption w-full bg-green-600 hover:bg-green-700 text-white font-bold py-3 rounded-xl transition"
data-caption={item.caption}>

📋 Salin Caption

</button>

<button
class="btnHashtag w-full bg-purple-600 hover:bg-purple-700 text-white font-bold py-3 rounded-xl transition"
data-hashtag={item.hashtag}>

🏷 Salin Hashtag

</button>

</div>

</div>

</div>

))

}

</div>

</div>

<div
id="lightbox"
class="hidden fixed inset-0 bg-black/80 z-50 flex items-center justify-center p-5">

<div class="relative">

<button
id="closePreview"
class="absolute -top-4 -right-4 bg-white rounded-full w-10 h-10 font-bold">

✕

</button>

<img
id="previewImage"
src=""
class="max-h-[90vh] rounded-xl shadow-2xl"/>

</div>

</div>

</section>

<script is:inline>

document.addEventListener("astro:page-load",()=>{

//==============================
// SEARCH TEMPLATE
//==============================

const search =
document.getElementById("searchMateri");

if(search){

search.addEventListener("keyup",()=>{

const keyword =
search.value.toLowerCase();

document.querySelectorAll("#gridMateri > div")

.forEach(card=>{

const teks =
card.innerText.toLowerCase();

card.style.display =
teks.includes(keyword)
? ""
: "none";

});

});

}

//==============================
// COPY CAPTION
//==============================

document
.querySelectorAll(".btnCaption")
.forEach(btn=>{

btn.addEventListener("click",()=>{

navigator.clipboard.writeText(
btn.dataset.caption
);

const lama =
btn.innerHTML;

btn.innerHTML =
"✅ Caption Tersalin";

setTimeout(()=>{

btn.innerHTML = lama;

},2000);

});

});

//==============================
// COPY HASHTAG
//==============================

document
.querySelectorAll(".btnHashtag")
.forEach(btn=>{

btn.addEventListener("click",()=>{

navigator.clipboard.writeText(
btn.dataset.hashtag
);

const lama =
btn.innerHTML;

btn.innerHTML =
"✅ Hashtag Tersalin";

setTimeout(()=>{

btn.innerHTML = lama;

},2000);

//==============================
// PREVIEW GAMBAR
//==============================

const lightbox =
document.getElementById("lightbox");

const preview =
document.getElementById("previewImage");

document
.querySelectorAll(".btnPreview")
.forEach(btn=>{

btn.addEventListener("click",()=>{

preview.src =
btn.dataset.image;

lightbox.classList.remove("hidden");

});

});

document
.getElementById("closePreview")
.addEventListener("click",()=>{

lightbox.classList.add("hidden");

});

});

});

});

</script>
