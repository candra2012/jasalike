---
// src/components/HargaPaket.astro

const {
  judulHarga = "Pilihan Paket Favorit",
  deskripsiHarga,
  
  // Data Paket 1 (Kiri)
  p1Gambar, p1Nama, p1Fitur1, p1Fitur2, p1Fitur3, p1Harga, p1Link,
  
  // Data Paket 2 (Kanan)
  p2Label = "TERLARIS", p2Gambar, p2Nama, p2Fitur1, p2Fitur2, p2Fitur3, p2HargaCoret, p2Harga, p2Link
} = Astro.props;
---
<section id="harga-paket" class="py-20 md:py-24 bg-slate-200 border-y border-slate-300 overflow-hidden">
  <div class="max-w-4xl mx-auto px-6">
    
    <div class="animate-on-scroll-hargapaket opacity-0 translate-y-8 transform transition-all duration-700 ease-out text-center mb-14">
      <h2 class="text-2xl md:text-3xl lg:text-4xl font-black text-slate-900 mb-4 tracking-tight">{judulHarga}</h2>
      <p class="text-sm md:text-base font-medium text-slate-900">{deskripsiHarga}</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-start">
      
      <div class="animate-on-scroll-hargapaket opacity-0 translate-y-8 transform transition-all duration-700 ease-out bg-white rounded-[2rem] border border-slate-300 overflow-hidden flex flex-col hover:border-blue-400 hover:shadow-2xl transition-all shadow-lg">
        
        <div class="w-full bg-slate-50 p-6 border-b border-slate-200 flex justify-center items-center h-[220px]">
          <img src={p1Gambar} alt={p1Nama} class="w-auto h-full max-h-[160px] object-contain drop-shadow-md" />
        </div>
        
        <div class="p-8 pt-6 flex-1 flex flex-col">
          <h3 class="text-xl md:text-2xl font-black text-slate-900 mb-6">{p1Nama}</h3>
          <ul class="space-y-4 mb-8 flex-1">
            <li class="flex items-start gap-3 text-slate-900">
              <span class="text-blue-500 text-xl leading-none mt-1">●</span>
              <span class="text-sm md:text-base font-semibold">{p1Fitur1}</span>
            </li>
            <li class="flex items-start gap-3 text-slate-900">
              <span class="text-blue-500 text-xl leading-none mt-1">●</span>
              <span class="text-sm md:text-base font-semibold">{p1Fitur2}</span>
            </li>
            <li class="flex items-start gap-3 text-slate-900">
              <span class="text-blue-500 text-xl leading-none mt-1">●</span>
              <span class="text-sm md:text-base font-semibold">{p1Fitur3}</span>
            </li>
          </ul>
          <div class="mb-6 border-t border-slate-200 pt-6">
            <p class="text-sm text-slate-600 mb-1 font-bold">Harga Spesial</p>
            <div class="flex items-baseline gap-2">
              <span class="text-3xl md:text-4xl font-black text-slate-900">{p1Harga}</span>
            </div>
          </div>
          <a href={p1Link} class="block w-full text-center bg-blue-600 hover:bg-blue-700 !text-white font-bold py-3.5 rounded-xl transition-colors text-sm md:text-base shadow-md hover:shadow-blue-500/30">
            Pesan Sekarang
          </a>
        </div>
      </div>

      <div class="animate-on-scroll-hargapaket opacity-0 translate-y-8 transform transition-all duration-700 ease-out delay-150 bg-white rounded-[2rem] border-2 border-blue-400 overflow-hidden flex flex-col relative hover:border-blue-500 hover:shadow-2xl transition-all shadow-xl shadow-blue-900/10 mt-0 md:-mt-4 z-10">
        
        <div class="absolute top-4 right-4 bg-blue-600 text-white text-xs font-black px-4 py-1.5 rounded-full z-20 shadow-md tracking-wider">
          {p2Label}
        </div>
        
        <div class="w-full bg-blue-50/50 p-6 border-b border-blue-100 flex justify-center items-center h-[220px]">
          <img src={p2Gambar} alt={p2Nama} class="w-auto h-full max-h-[180px] object-contain drop-shadow-lg transform scale-105" />
        </div>
        
        <div class="p-8 pt-6 flex-1 flex flex-col">
          <h3 class="text-xl md:text-2xl font-black text-slate-900 mb-6">{p2Nama}</h3>
          <ul class="space-y-4 mb-8 flex-1">
            <li class="flex items-start gap-3 text-slate-900">
              <span class="text-blue-600 text-xl leading-none mt-1">●</span>
              <span class="text-sm md:text-base font-bold">{p2Fitur1}</span>
            </li>
            <li class="flex items-start gap-3 text-slate-900">
              <span class="text-blue-600 text-xl leading-none mt-1">●</span>
              <span class="text-sm md:text-base font-bold">{p2Fitur2}</span>
            </li>
            <li class="flex items-start gap-3 text-slate-900">
              <span class="text-blue-600 text-xl leading-none mt-1">●</span>
              <span class="text-sm md:text-base font-bold">{p2Fitur3}</span>
            </li>
          </ul>
          <div class="mb-6 border-t border-slate-200 pt-6">
            <p class="text-sm text-slate-600 mb-1 font-bold">Harga Spesial</p>
            <div class="flex items-baseline gap-2">
              <span class="text-3xl md:text-4xl font-black text-slate-900">{p2Harga}</span>
              {p2HargaCoret && <span class="text-sm md:text-base text-slate-500 line-through font-bold ml-2">{p2HargaCoret}</span>}
            </div>
          </div>
          <a href={p2Link} class="block w-full text-center bg-blue-600 hover:bg-blue-700 !text-white font-bold py-4 rounded-xl transition-colors text-sm md:text-base shadow-lg hover:shadow-blue-600/40">
            Pesan Sekarang
          </a>
        </div>
      </div>

    </div>
  </div>
</section>

<script>
  document.addEventListener("astro:page-load", () => {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.remove('opacity-0', 'translate-y-8');
          entry.target.classList.add('opacity-100', 'translate-y-0');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1 });
    const items = document.querySelectorAll('.animate-on-scroll-hargapaket');
    items.forEach((item) => observer.observe(item));
  });
</script>

