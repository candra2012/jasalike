---
// src/components/HargaPaket.astro

const {
  judulHarga = "Pilihan Paket Favorit",
  deskripsiHarga,
  
  // Data Paket 1 (Paling Kiri - Server/Basic)
  p1Gambar, p1Nama, p1Fitur1, p1Fitur2, p1Fitur3, p1Harga, p1Link,
  
  // Data Paket 2 (Tengah Kiri - Real Pemula)
  p2Gambar, p2Nama, p2Fitur1, p2Fitur2, p2Fitur3, p2HargaCoret, p2Harga, p2Link,

  // Data Paket 3 (Tengah Kanan - TERLARIS / Highlight)
  p3Label = "TERLARIS", p3Gambar, p3Nama, p3Fitur1, p3Fitur2, p3Fitur3, p3HargaCoret, p3Harga, p3Link,

  // Data Paket 4 (Paling Kanan - VIP / Sultan)
  p4Gambar, p4Nama, p4Fitur1, p4Fitur2, p4Fitur3, p4HargaCoret, p4Harga, p4Link
} = Astro.props;
---
<section id="harga-paket" class="relative py-24 bg-[#0B1121] border-y border-slate-800 overflow-hidden">
  
  <div class="absolute inset-0 bg-[radial-gradient(#ffffff_2px,transparent_2px)] [background-size:32px_32px] [background-position:16px_16px] z-0 animate-twinkle opacity-30"></div>
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full max-w-7xl h-[400px] bg-blue-600/15 blur-[120px] rounded-full pointer-events-none z-0"></div>

  <!-- max-w-7xl agar 4 kotak tidak terlalu sempit -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 relative z-10">
    <div class="text-center mb-16 animate-on-scroll-hargapaket opacity-0 translate-y-8 transform transition-all duration-700 ease-out">
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">{judulHarga}</h2>
      <p class="text-slate-400">{deskripsiHarga}</p>
    </div>

    <!-- Diubah menjadi lg:grid-cols-4 untuk 4 Kotak, gap sedikit dikecilkan jadi gap-6 -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
      
      <!-- KOTAK 1: PAKET SERVER / BASIC -->
      <div class="animate-on-scroll-hargapaket opacity-0 translate-y-8 transform transition-all duration-700 ease-out bg-slate-950 rounded-[2rem] border border-slate-800 overflow-hidden flex flex-col hover:border-blue-500/50 transition-colors shadow-xl relative mt-0 lg:mt-4">
        <div class="w-full bg-slate-800 p-5 border-b border-slate-800">
          <img src={p1Gambar} alt={p1Nama} class="mx-auto h-auto object-contain" style="max-height: 140px;" />
        </div>
        <div class="p-6 pt-6 flex-1 flex flex-col">
          <h3 class="text-xl font-bold text-white mb-6">{p1Nama}</h3>
          <ul class="space-y-3 mb-8 flex-1">
            <li class="flex items-start gap-2 text-slate-300">
              <span class="text-blue-500 text-lg leading-none mt-1">●</span>
              <span class="text-base">{p1Fitur1}</span>
            </li>
            <li class="flex items-start gap-2 text-slate-300">
              <span class="text-blue-500 text-lg leading-none mt-1">●</span>
              <span class="text-base">{p1Fitur2}</span>
            </li>
            <li class="flex items-start gap-2 text-slate-300">
              <span class="text-blue-500 text-lg leading-none mt-1">●</span>
              <span class="text-base">{p1Fitur3}</span>
            </li>
          </ul>
          <div class="mb-6 border-t border-slate-800 pt-6">
            <p class="text-xs text-slate-400 mb-1">Harga Spesial</p>
            <div class="flex items-baseline gap-2">
              <span class="text-2xl font-extrabold text-white">{p1Harga}</span>
            </div>
          </div>
          <a href={p1Link} class="block w-full text-center border border-slate-600 hover:bg-slate-800 !text-white font-bold py-3 rounded-xl transition-colors text-sm">
            PESAN SEKARANG
          </a>
        </div>
      </div>

      <!-- KOTAK 2: PAKET REAL PEMULA -->
      <div class="animate-on-scroll-hargapaket opacity-0 translate-y-8 transform transition-all duration-700 ease-out delay-200 bg-slate-950 rounded-[2rem] border border-slate-800 overflow-hidden flex flex-col hover:border-blue-500/50 transition-colors shadow-xl relative mt-0 lg:mt-4">
        <div class="w-full bg-slate-800 p-5 border-b border-slate-800">
          <img src={p2Gambar} alt={p2Nama} class="mx-auto h-auto object-contain" style="max-height: 140px;" />
        </div>
        <div class="p-6 pt-6 flex-1 flex flex-col">
          <h3 class="text-xl font-bold text-white mb-6">{p2Nama}</h3>
          <ul class="space-y-3 mb-8 flex-1">
            <li class="flex items-start gap-2 text-slate-300">
              <span class="text-blue-500 text-lg leading-none mt-1">●</span>
              <span class="text-base">{p2Fitur1}</span>
            </li>
            <li class="flex items-start gap-2 text-slate-300">
              <span class="text-blue-500 text-lg leading-none mt-1">●</span>
              <span class="text-base">{p2Fitur2}</span>
            </li>
            <li class="flex items-start gap-2 text-slate-300">
              <span class="text-blue-500 text-lg leading-none mt-1">●</span>
              <span class="text-base">{p2Fitur3}</span>
            </li>
          </ul>
          <div class="mb-6 border-t border-slate-800 pt-6">
            <p class="text-xs text-slate-400 mb-1">Harga Spesial</p>
            <div class="flex items-baseline gap-2 flex-wrap">
              <span class="text-2xl font-extrabold text-white">{p2Harga}</span>
              {p2HargaCoret && <span class="text-sm text-slate-500 line-through">{p2HargaCoret}</span>}
            </div>
          </div>
          <a href={p2Link} class="block w-full text-center border border-slate-600 hover:bg-slate-800 !text-white font-bold py-3 rounded-xl transition-colors text-sm">
            PESAN SEKARANG
          </a>
        </div>
      </div>

      <!-- KOTAK 3: PAKET REAL MENENGAH (BEST SELLER / SOROTAN) -->
      <div class="animate-on-scroll-hargapaket opacity-0 translate-y-8 transform transition-all duration-700 ease-out delay-400 bg-slate-950 rounded-[2rem] border-2 border-blue-500 overflow-hidden flex flex-col relative hover:border-blue-400 transition-colors shadow-2xl shadow-blue-900/40 z-10 scale-100 lg:scale-105">
        <div class="absolute top-4 right-4 bg-blue-600 text-white text-xs font-bold px-3 py-1 rounded-full z-20 shadow-lg">{p3Label}</div>
        <div class="w-full bg-slate-800 p-5 border-b border-blue-900/50">
          <img src={p3Gambar} alt={p3Nama} class="mx-auto h-auto object-contain" style="max-height: 150px;" />
        </div>
        <div class="p-6 pt-6 flex-1 flex flex-col">
          <h3 class="text-xl font-bold text-white mb-6">{p3Nama}</h3>
          <ul class="space-y-3 mb-8 flex-1">
            <li class="flex items-start gap-2 text-slate-300">
              <span class="text-blue-400 text-lg leading-none mt-1">●</span>
              <span class="text-base">{p3Fitur1}</span>
            </li>
            <li class="flex items-start gap-2 text-slate-300">
              <span class="text-blue-400 text-lg leading-none mt-1">●</span>
              <span class="text-base">{p3Fitur2}</span>
            </li>
            <li class="flex items-start gap-2 text-slate-300">
              <span class="text-blue-400 text-lg leading-none mt-1">●</span>
              <span class="text-base">{p3Fitur3}</span>
            </li>
          </ul>
          <div class="mb-6 border-t border-slate-800 pt-6">
            <p class="text-xs text-blue-400 font-medium mb-1">Harga Spesial</p>
            <div class="flex items-baseline gap-2 flex-wrap">
              <span class="text-3xl font-extrabold text-white">{p3Harga}</span>
              {p3HargaCoret && <span class="text-sm text-slate-500 line-through">{p3HargaCoret}</span>}
            </div>
          </div>
          <a href={p3Link} class="block w-full text-center bg-blue-600 hover:bg-blue-500 !text-white font-bold py-3 rounded-xl transition-colors shadow-lg shadow-blue-600/30 text-sm">
            PPESAN SEKARANG
          </a>
        </div>
      </div>

      <!-- KOTAK 4: PAKET VIP / SULTAN -->
      <div class="animate-on-scroll-hargapaket opacity-0 translate-y-8 transform transition-all duration-700 ease-out delay-600 bg-slate-950 rounded-[2rem] border border-slate-800 overflow-hidden flex flex-col hover:border-blue-500/50 transition-colors shadow-xl relative mt-0 lg:mt-4">
        <div class="w-full bg-slate-800 p-5 border-b border-slate-800">
          <img src={p4Gambar} alt={p4Nama} class="mx-auto h-auto object-contain" style="max-height: 140px;" />
        </div>
        <div class="p-6 pt-6 flex-1 flex flex-col">
          <h3 class="text-xl font-bold text-white mb-6">{p4Nama}</h3>
          <ul class="space-y-3 mb-8 flex-1">
            <li class="flex items-start gap-2 text-slate-300">
              <span class="text-blue-500 text-lg leading-none mt-1">●</span>
              <span class="text-base">{p4Fitur1}</span>
            </li>
            <li class="flex items-start gap-2 text-slate-300">
              <span class="text-blue-500 text-lg leading-none mt-1">●</span>
              <span class="text-base">{p4Fitur2}</span>
            </li>
            <li class="flex items-start gap-2 text-slate-300">
              <span class="text-blue-500 text-lg leading-none mt-1">●</span>
              <span class="text-base">{p4Fitur3}</span>
            </li>
          </ul>
          <div class="mb-6 border-t border-slate-800 pt-6">
            <p class="text-xs text-slate-400 mb-1">Harga Spesial</p>
            <div class="flex items-baseline gap-2 flex-wrap">
              <span class="text-2xl font-extrabold text-white">{p4Harga}</span>
              {p4HargaCoret && <span class="text-sm text-slate-500 line-through">{p4HargaCoret}</span>}
            </div>
          </div>
          <a href={p4Link} class="block w-full text-center border border-slate-600 hover:bg-slate-800 !text-white font-bold py-3 rounded-xl transition-colors text-sm">
            PESAN SEKARANG
          </a>
        </div>
      </div>

    </div>
  </div>
</section>

<script>
  document.addEventListener("astro:page-load", () => {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.remove('opacity-0', 'translate-y-8');
          entry.target.classList.add('opacity-100', 'translate-y-0');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1 });
    const items = document.querySelectorAll('.animate-on-scroll-hargapaket');
    items.forEach((item) => observer.observe(item));
  });
</script>

<style>
  @keyframes smooth-twinkle {
    0%, 100% { opacity: 0.12; }
    50% { opacity: 0.35; } 
  }
  .animate-twinkle {
    animation: smooth-twinkle 8s ease-in-out infinite;
  }
</style>
