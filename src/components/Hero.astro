---
// src/components/Hero.astro
import { Icon } from 'astro-icon/components';
---

<section class="relative py-32 lg:py-48 bg-slate-950 overflow-hidden">
  <div class="absolute inset-0 z-0">
    <div class="absolute bottom-0 left-0 right-0 top-0 bg-[linear-gradient(to_right,#1e293b_1px,transparent_1px),linear-gradient(to_bottom,#1e293b_1px,transparent_1px)] bg-[size:4rem_4rem] [mask-image:radial-gradient(ellipse_60%_50%_at_50%_50%,#000_70%,transparent_100%)]"></div>
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-[500px] bg-blue-600 rounded-full blur-[180px] opacity-20"></div>
  </div>

  <div class="relative z-10 container mx-auto px-6">
    <div class="text-center max-w-4xl mx-auto mb-16 animate-fade-in-up">
      <div class="inline-flex items-center gap-2 bg-blue-900/40 border border-blue-700/50 text-blue-300 px-4 py-1.5 rounded-full text-sm font-medium mb-8">
        <Icon name="lucide:sparkles" class="w-4 h-4" />
        Spesialis Optimasi Interaksi Sosial Media No. 1
      </div>

      <h1 class="text-4xl md:text-6xl lg:text-7xl font-extrabold text-white leading-[1.1] mb-8 tracking-tight">
        Tumbuh <span class="text-blue-500">Lebih Percaya Diri</span> <br class="hidden md:block"/> di Dunia Digital
      </h1>

      <p class="text-lg md:text-xl text-slate-300 mb-10 leading-relaxed max-w-2xl mx-auto">
        Jasalike membantu meningkatkan kredibilitas akun Anda melalui interaksi nyata yang aman, cepat, dan bergaransi. Saatnya tampil profesional sekarang juga.
      </p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
        <a href="https://wa.me/6289634740308?text=Halo%20Admin%2C%20saya%20tertarik%20order%20Jasa%20Like.%20Bisa%20info%20pricelist%3F" class="w-full sm:w-auto inline-flex items-center justify-center gap-2.5 bg-blue-600 hover:bg-blue-700 text-white font-bold px-8 py-4 rounded-xl shadow-lg shadow-blue-600/30 transition-all duration-300 hover:scale-105 active:scale-95">
          Konsultasi via WhatsApp
          <Icon name="lucide:arrow-right" class="w-5 h-5" />
        </a>
        
        <a 
          href="LINK_SPREADSHEET_KAMU_DI_SINI" 
          target="_blank"
          rel="noopener noreferrer"
          class="w-full sm:w-auto inline-flex items-center justify-center gap-2 bg-white/10 hover:bg-white/20 text-white font-bold px-8 py-4 rounded-xl border border-white/20 transition-all hover:scale-105 active:scale-95"
        >
          <Icon name="lucide:file-spreadsheet" class="w-5 h-5 text-emerald-400" />
          Pricelist Lengkap
        </a>
      </div>
    </div>

    <div class="max-w-5xl mx-auto animate-fade-in-up delay-300">
      <div class="relative group">
        <div class="absolute -inset-1 bg-gradient-to-r from-blue-600 to-purple-600 rounded-[2rem] blur opacity-25 group-hover:opacity-50 transition duration-1000 group-hover:duration-200"></div>
        
        <div class="relative bg-slate-900 rounded-[2rem] p-2 border border-white/10 shadow-2xl overflow-hidden">
          <img
            src="/image/hero-jasalike.png"
            alt="Dashboard Jasa Like"
            class="w-full h-auto rounded-[1.5rem] object-cover"
            loading="eager"
          />
        </div>
      </div>
    </div>

  </div>
</section>

<style>
  .animate-fade-in-up {
    animation: fadeInUp 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    opacity: 0;
  }
  .delay-300 {
    animation-delay: 300ms;
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(40px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
