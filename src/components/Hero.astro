---
// src/components/Hero.astro
import { Icon } from 'astro-icon/components';
---

<section class="relative py-32 lg:py-40 bg-slate-950 overflow-hidden">
  <div class="absolute inset-0 z-0">
    <div class="absolute bottom-0 left-0 right-0 top-0 bg-[linear-gradient(to_right,#1e293b_1px,transparent_1px),linear-gradient(to_bottom,#1e293b_1px,transparent_1px)] bg-[size:3rem_3rem] [mask-image:radial-gradient(ellipse_60%_50%_at_50%_0%,#000_70%,transparent_110%)]"></div>
    <div class="absolute -top-40 -left-40 w-96 h-96 bg-blue-600 rounded-full blur-[160px] opacity-20"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-purple-600 rounded-full blur-[200px] opacity-10"></div>
  </div>

  <div class="relative z-10 container mx-auto px-6 grid grid-cols-1 lg:grid-cols-2 gap-16 items-center pt-28 lg:pt-10">

    <div class="text-center lg:text-left animate-fade-in-up">
      <div class="inline-flex items-center gap-2 bg-blue-900/40 border border-blue-700/50 text-blue-300 px-4 py-1.5 rounded-full text-sm font-medium mb-6">
        <Icon name="lucide:sparkles" class="w-4 h-4" />
        Spesialis Optimasi Interaksi Sosial Media No. 1
      </div>

      <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold text-white leading-tight mb-6 tracking-tight">
        Tumbuh <span class="text-blue-500">Lebih Percaya Diri</span> di Dunia Digital
      </h1>

      <p class="text-xl text-slate-300 mb-10 leading-relaxed max-w-2xl mx-auto lg:mx-0">
        Jasalike membantu meningkatkan kredibilitas akun Anda melalui interaksi nyata (Like) yang aman, cepat, dan bergaransi. Saatnya tampil profesional dan menjangkau audiens lebih luas.
      </p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start">
        <a href="https://wa.me/6289634740308?text=Halo%20Admin%2C%20saya%20tertarik%20order%20Jasa%20Like.%20Bisa%20info%20pricelist%3F" class="inline-flex items-center justify-center gap-2.5 bg-blue-600 hover:bg-blue-700 text-white font-bold px-8 py-4 rounded-xl shadow-lg shadow-blue-600/30 transition-all duration-300 hover:scale-105">
          Konsultasi via WhatsApp
          <Icon name="lucide:arrow-right" class="w-5 h-5" />
        </a>
        <a href="#masalah" class="inline-flex items-center justify-center gap-2 bg-white/10 hover:bg-white/20 text-white font-semibold px-8 py-4 rounded-xl border border-white/10 transition-all">
          Pelajari Dulu
        </a>
      </div>
    </div>

    <div class="w-full flex justify-center lg:justify-end animate-fade-in-right delay-200">
      <img
        src="/image/hero-jasalike.png"
        alt="Ilustrasi Jasa Like Sosial Media Terpercaya"
        loading="eager"
        decoding="async"
        class="rounded-3xl shadow-2xl shadow-blue-500/20 border border-slate-700 w-full max-w-lg lg:max-w-none transform lg:rotate-2 hover:rotate-0 transition-all duration-500 ease-out object-cover"
      />
    </div>

  </div>
</section>

<style>
  .animate-fade-in-up {
    animation: fadeInUp 1s ease-out forwards;
    opacity: 0;
  }
  .animate-fade-in-right {
    animation: fadeInRight 1s ease-out forwards;
    opacity: 0;
  }

  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes fadeInRight {
    from { opacity: 0; transform: translateX(30px); }
    to { opacity: 1; transform: translateX(0); }
  }
</style>
