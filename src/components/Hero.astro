---
// src/components/Hero.astro
const {
  judulUtama,
  deskripsi,
  teksTombol1,
  linkTombol1,
  teksTombol2,
  linkTombol2,
  gambarHero
} = Astro.props;
---
<section class="relative pt-32 pb-48 md:pt-40 md:pb-64 bg-[#0B1121] text-white overflow-hidden">
  
  <div class="absolute inset-0 bg-[radial-gradient(#ffffff_2px,transparent_2px)] [background-size:32px_32px] opacity-[0.25] z-0"></div>
  
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full max-w-7xl h-[600px] bg-blue-600/20 blur-[140px] rounded-full pointer-events-none z-0"></div>

  <div class="absolute inset-x-0 bottom-0 h-56 bg-gradient-to-t from-white via-transparent to-transparent z-0"></div>

  <div class="max-w-4xl mx-auto px-6 relative z-10 text-center">
    <div class="flex flex-col items-center">
      
      <div class="animate-hero-text opacity-0 translate-y-8 transform transition-all duration-1000 ease-out max-w-3xl flex flex-col items-center">
        
        <h1 class="text-3xl md:text-4xl lg:text-5xl font-black mb-6 leading-[1.2] tracking-tight text-white" set:html={judulUtama}>
        </h1>
        
        <p class="text-base md:text-lg text-slate-400 leading-relaxed font-normal max-w-2xl">
          {deskripsi}
        </p>

        <div class="flex flex-col sm:flex-row gap-4 justify-center items-center mt-10 w-full sm:w-auto">
          <a
            href={linkTombol1}
            class="inline-flex justify-center items-center bg-transparent hover:bg-white/10 text-white font-bold px-8 py-3.5 rounded-full border border-white transition-all duration-300 text-center min-w-[200px] text-sm md:text-base tracking-wide"
          >
            {teksTombol1}
          </a>
          
          <a
            href={linkTombol2}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex justify-center items-center bg-transparent hover:bg-white/10 text-white font-bold px-8 py-3.5 rounded-full border border-white transition-all duration-300 text-center min-w-[200px] text-sm md:text-base tracking-wide"
          >
            {teksTombol2}
          </a>
        </div>

      </div>

      <div class="animate-hero-image opacity-0 translate-y-8 transform transition-all duration-1000 ease-out delay-300 w-full max-w-3xl relative mt-16 md:mt-20">
        
        <div class="absolute inset-0 bg-blue-500/10 blur-[80px] rounded-full transform scale-75 -z-10"></div>
        
        <img
          src={gambarHero}
          alt="Hero Image"
          class="w-full h-auto rounded-2xl md:rounded-[2rem] object-cover shadow-2xl transform hover:scale-[1.01] transition-transform duration-500"
        />
        
      </div>

    </div>
  </div>
</section>

<script>
  document.addEventListener("astro:page-load", () => {
    const heroText = document.querySelector('.animate-hero-text');
    if (heroText) { 
      heroText.classList.remove('opacity-0', 'translate-y-8'); 
      heroText.classList.add('opacity-100', 'translate-y-0'); 
    }

    const heroImage = document.querySelector('.animate-hero-image');
    if (heroImage) { 
      heroImage.classList.remove('opacity-0', 'translate-y-8'); 
      heroImage.classList.add('opacity-100', 'translate-y-0'); 
    }
  });
</script>

