---
// src/components/Hero.astro
import { Icon } from 'astro-icon/components'

const {
  tipe = "home", 
  labelTeks,     
  labelIcon,     
  judulUtama,
  deskripsi,
  teksTombol1,
  linkTombol1,
  teksTombol2,
  linkTombol2,
  gambarHero
} = Astro.props;
---

{tipe === "home" && (
  <section class="relative pt-32 pb-48 md:pt-40 md:pb-64 bg-[#0B1121] text-white overflow-hidden">
    <div class="absolute inset-0 bg-[radial-gradient(#ffffff_2px,transparent_2px)] [background-size:32px_32px] [background-position:16px_16px] z-0 animate-twinkle"></div>
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full max-w-7xl h-[600px] bg-blue-600/20 blur-[140px] rounded-full pointer-events-none z-0"></div>

    <div class="max-w-4xl mx-auto px-6 relative z-10 text-center">
      <div class="flex flex-col items-center">
        <div class="animate-hero-text opacity-0 translate-y-8 transform transition-all duration-1000 ease-out max-w-3xl flex flex-col items-center">
          <h1 class="text-3xl md:text-4xl lg:text-5xl font-black mb-6 leading-[1.2] tracking-tight text-white" set:html={judulUtama}></h1>
          <p class="text-sm md:text-base text-slate-400 leading-relaxed font-normal max-w-2xl" set:html={deskripsi}></p>
          
          <div class="flex flex-col sm:flex-row gap-4 justify-center items-center mt-10 w-full sm:w-auto">
            <a href={linkTombol1} class="inline-flex justify-center items-center !bg-transparent hover:!bg-white hover:!text-blue-600 !text-white font-bold px-8 py-3.5 rounded-full border-2 !border-white/50 transition-all text-sm md:text-base min-w-[200px] !no-underline shadow-lg shadow-blue-900/20">
              {teksTombol1}
            </a>
            
            <a href={linkTombol2} target="_blank" rel="noopener noreferrer" class="inline-flex justify-center items-center !bg-white/10 hover:!bg-white hover:!text-blue-800 !text-white font-bold px-8 py-3.5 rounded-full border-2 !border-white/20 transition-all text-sm md:text-base min-w-[200px] backdrop-blur-sm !no-underline">
              {teksTombol2}
            </a>
          </div>

        </div>
        <div class="animate-hero-image opacity-0 translate-y-8 transform transition-all duration-1000 ease-out delay-300 w-full max-w-3xl relative mt-16 md:mt-20">
          <div class="absolute inset-0 bg-blue-500/10 blur-[80px] rounded-full transform scale-75 -z-10"></div>
          <img src={gambarHero} alt="Hero Image" class="w-full h-auto rounded-2xl md:rounded-[2rem] object-cover shadow-2xl transform hover:scale-[1.01] transition-transform duration-500" />
        </div>
      </div>
    </div>
  </section>
)}


{tipe === "service" && (
  <section class="relative pt-32 pb-24 lg:pt-40 lg:pb-32 bg-[#0B1121] overflow-hidden flex items-center border-b border-slate-800/50">
    
    <div class="absolute inset-0 z-0">
      <img src={gambarHero} alt="Background" class="w-full h-full object-contain object-center opacity-30 block" />
      <div class="absolute inset-0 bg-gradient-to-b from-[#0B1121] via-transparent to-[#0B1121]"></div>
      <div class="absolute inset-0 bg-[#0B1121]/60"></div> 
      <div class="absolute inset-0 bg-[radial-gradient(#ffffff_2px,transparent_2px)] [background-size:32px_32px] [background-position:16px_16px] z-0 animate-twinkle mix-blend-overlay"></div>
      <div class="absolute top-1/4 left-1/2 -translate-x-1/2 w-full max-w-2xl h-[400px] bg-blue-600/20 blur-[150px] rounded-full pointer-events-none"></div>
    </div>

    <div class="relative z-10 container mx-auto px-6 text-center max-w-4xl animate-hero-text opacity-0 translate-y-8 transform transition-all duration-1000 ease-out mt-10 lg:mt-0">
      
      {labelTeks && (
        <span class="inline-flex items-center gap-2 bg-blue-900/40 border border-blue-700/50 text-blue-300 px-4 py-1.5 rounded-full text-xs md:text-sm font-medium mb-6">
          {labelIcon && <Icon name={labelIcon} class="w-4 h-4" />}
          {labelTeks}
        </span>
      )}
      
      <h1 class="text-3xl md:text-4xl lg:text-5xl font-extrabold text-white leading-[1.2] mb-6 tracking-tight" set:html={judulUtama}></h1>
      <p class="text-sm md:text-base text-slate-300 max-w-3xl mx-auto leading-relaxed mb-10" set:html={deskripsi}></p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center w-full sm:w-auto">
        <a href={linkTombol1} class="inline-flex justify-center items-center !bg-transparent hover:!bg-white hover:!text-blue-600 !text-white font-extrabold px-8 py-3.5 rounded-xl border-2 !border-white/50 shadow-lg shadow-blue-900/20 transition-all text-sm md:text-base min-w-[190px] !no-underline">
          {teksTombol1}
        </a>
        
        <a href={linkTombol2} target="_blank" rel="noopener noreferrer" class="inline-flex justify-center items-center !bg-white/10 hover:!bg-white hover:!text-blue-800 !text-white font-bold px-8 py-3.5 rounded-xl border-2 !border-white/20 transition-all text-sm md:text-base min-w-[190px] backdrop-blur-sm !no-underline">
          {teksTombol2}
        </a>
      </div>

    </div>
  </section>
)}


<script>
  document.addEventListener("astro:page-load", () => {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.remove('opacity-0', 'translate-y-8');
          entry.target.classList.add('opacity-100', 'translate-y-0');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1 });

    const heroElements = document.querySelectorAll('.animate-hero-text, .animate-hero-image');
    heroElements.forEach((el) => observer.observe(el));
  });
</script>

<style>
  @keyframes smooth-twinkle {
    0%, 100% { opacity: 0.12; }
    50% { opacity: 0.35; } 
  }
  .animate-twinkle {
    animation: smooth-twinkle 8s ease-in-out infinite;
  }
</style>

