---
// src/components/FaqJasaLike.astro
import { Accordion, AccordionItem } from 'accessible-astro-components'
import { Icon } from 'astro-icon/components'

// 👇 Tangkap semua pasokan teks data FAQ dari luar
const {
  judulUtama,
  deskripsiUtama,
  linkWhatsapp,
  faq1Judul, faq1Teks,
  faq2Judul, faq2Teks,
  faq3Judul, faq3Teks,
  faq4Judul, faq4Teks,
  faq5Judul, faq5Teks,
  faq6Judul, faq6Teks
} = Astro.props;
---

<section id="faq" class="py-20 md:py-24 bg-slate-50 border-t border-slate-200">
  <div class="max-w-6xl mx-auto px-6">
    
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-start">
      
      <div class="flex flex-col gap-5 lg:sticky lg:top-32">
        <h2 class="text-2xl md:text-3xl lg:text-4xl font-extrabold text-slate-900 tracking-tight" set:html={judulUtama}>
        </h2>
        <p class="text-sm md:text-base text-slate-600 leading-relaxed">
          {deskripsiUtama}
        </p>
        <div class="mt-4">
          <a
            class="inline-flex items-center justify-center gap-2 bg-green-500 hover:bg-green-600 text-white font-bold text-sm md:text-base px-6 py-3.5 md:px-8 md:py-4 rounded-full shadow-lg shadow-green-500/30 hover:shadow-green-500/50 hover:-translate-y-1 transition-all duration-300 w-fit"
            href={linkWhatsapp}
            target="_blank"
            rel="noopener noreferrer"
          >
            <Icon name="lucide:message-circle" class="w-5 h-5" />
            Tanya Admin via WhatsApp
          </a>
        </div>
      </div>

      <div class="bg-white p-6 md:p-8 rounded-3xl shadow-sm border border-slate-100">
        <Accordion>
          <AccordionItem name="faq1" title={faq1Judul}>
            <p class="text-sm text-slate-600 leading-relaxed pt-2" set:html={faq1Teks}></p>
          </AccordionItem>

          <AccordionItem name="faq2" title={faq2Judul}>
            <p class="text-sm text-slate-600 leading-relaxed pt-2" set:html={faq2Teks}></p>
          </AccordionItem>

          <AccordionItem name="faq3" title={faq3Judul}>
            <p class="text-sm text-slate-600 leading-relaxed pt-2" set:html={faq3Teks}></p>
          </AccordionItem>

          <AccordionItem name="faq4" title={faq4Judul}>
            <p class="text-sm text-slate-600 leading-relaxed pt-2" set:html={faq4Teks}></p>
          </AccordionItem>

          <AccordionItem name="faq5" title={faq5Judul}>
            <p class="text-sm text-slate-600 leading-relaxed pt-2" set:html={faq5Teks}></p>
          </AccordionItem>

          <AccordionItem name="faq6" title={faq6Judul}>
            <p class="text-sm text-slate-600 leading-relaxed pt-2" set:html={faq6Teks}></p>
          </AccordionItem>
        </Accordion>
      </div>

    </div>
  </div>
</section>

