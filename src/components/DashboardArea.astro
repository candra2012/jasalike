---
// Jika butuh memanggil icon dari lucide/astro, bisa import di sini
// import { Icon } from 'astro-icon/components';
---

<section id="area-dashboard" class="py-16 bg-gray-50 text-gray-800 font-sans">
    <div class="container mx-auto px-4">
        
        <!-- KONTAINER LOGIN -->
        <div id="login-section" class="max-w-md mx-auto bg-white rounded-xl shadow-md p-6">
            <h2 class="text-2xl font-bold text-center text-blue-600 mb-2">Akses Dashboard</h2>
            <p class="text-center text-gray-500 mb-6">Masukkan Kode Affiliate Anda</p>
            <input type="text" id="inputKode" placeholder="Contoh: S76AHE" class="w-full px-4 py-3 border rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-400 mb-4 uppercase">
            <button id="btnMasuk" class="w-full bg-blue-600 text-white font-bold py-3 px-4 rounded-lg hover:bg-blue-700 transition">Masuk Dashboard</button>
            <p id="pesanError" class="text-red-500 text-sm text-center mt-3 hidden">Kode tidak ditemukan. Silakan coba lagi.</p>
        </div>

        <!-- KONTAINER DASHBOARD (Awalnya Disembunyikan) -->
        <div id="dashboard-section" class="max-w-4xl mx-auto hidden space-y-6">
            
            <!-- Header Profil -->
            <div class="bg-white rounded-xl shadow-md p-6 border-l-4 border-blue-600">
                <h1 class="text-xl text-gray-500">Halo, <span id="namaAfiliator" class="font-bold text-gray-800">Nama</span>! 👋</h1>
                <p class="text-sm text-gray-400 mb-4">Kode Affiliate: <span id="kodeAfiliatorDisplay" class="font-mono text-blue-600 font-bold"></span></p>
                
                <div class="p-4 bg-blue-50 rounded-lg mb-6 border border-blue-100">
                    <p class="text-sm text-gray-600 mb-2">Link Promosi Anda:</p>
                    <div class="flex flex-col sm:flex-row items-center gap-2">
                        <input type="text" id="linkPromosi" readonly class="w-full bg-white text-sm px-3 py-2 border rounded text-gray-600" value="">
                        <button id="btnSalin" class="w-full sm:w-auto bg-blue-600 text-white px-6 py-2 rounded font-bold text-sm hover:bg-blue-700 transition whitespace-nowrap">Salin Link</button>
                    </div>
                </div>
                
                <!-- Tombol Pencairan -->
                <button id="btnCairkan" class="w-full bg-green-500 text-white font-bold py-3 rounded-lg hover:bg-green-600 transition shadow-md flex justify-center items-center gap-2">
                    💰 Tarik Komisi ke WhatsApp
                </button>
            </div>

            <!-- Tabel Transaksi -->
            <div class="bg-white rounded-xl shadow-md p-6 overflow-hidden">
                <h2 class="text-lg font-bold text-gray-800 border-b pb-2 mb-4">Riwayat Transaksi</h2>
                <div class="overflow-x-auto">
                    <table class="w-full text-sm text-left whitespace-nowrap">
                        <thead class="text-gray-600 bg-gray-100">
                            <tr>
                                <th class="px-4 py-3 rounded-tl-lg">Tanggal</th>
                                <th class="px-4 py-3">Layanan</th>
                                <th class="px-4 py-3">Komisi</th>
                                <th class="px-4 py-3 rounded-tr-lg">Status</th>
                            </tr>
                        </thead>
                        <tbody id="tabelTransaksi">
                            <!-- Data transaksi akan dimunculkan di sini -->
                        </tbody>
                    </table>
                </div>
            </div>

        </div>
    </div>
</section>

<!-- SCRIPT LOGIKA BROWSER -->
<script>
    // ==========================================
    // PENGATURAN WAJIB (EDIT DI SINI)
    // ==========================================
    const URL_APPS_SCRIPT = "https://script.google.com/macros/s/AKfycbz3kEyCiznO2kkIIo6QyouUFeZUIAjVyP-qotjJCPt43kFlEA41S1NiCwHttNRwJT6lAg/exec"; 
    const NOMOR_WA_ADMIN = "6282120567299"; // Sudah disesuaikan dengan no Bos
    // ==========================================

    let dataGlobal = {}; 

    // Ambil elemen DOM
    const btnMasuk = document.getElementById('btnMasuk');
    const btnSalin = document.getElementById('btnSalin');
    const btnCairkan = document.getElementById('btnCairkan');

    if(btnMasuk) {
        btnMasuk.addEventListener('click', () => {
            const kode = document.getElementById("inputKode").value.trim().toUpperCase();
            if(!kode) return;

            btnMasuk.innerText = "Mencari Data...";
            document.getElementById("pesanError").classList.add("hidden");

            fetch(URL_APPS_SCRIPT + "?action=getDashboard&kode=" + kode)
            .then(response => response.json())
            .then(data => {
                if(data.status === "success") {
                    dataGlobal = data;
                    tampilkanDashboard();
                } else {
                    document.getElementById("pesanError").classList.remove("hidden");
                    btnMasuk.innerText = "Masuk Dashboard";
                }
            })
            .catch(error => {
                alert("Terjadi kesalahan jaringan.");
                btnMasuk.innerText = "Masuk Dashboard";
            });
        });
    }

    function tampilkanDashboard() {
        document.getElementById("login-section").classList.add("hidden");
        document.getElementById("dashboard-section").classList.remove("hidden");

        document.getElementById("namaAfiliator").innerText = dataGlobal.profil["Nama Lengkap"] || dataGlobal.profil["Nama"];
        document.getElementById("kodeAfiliatorDisplay").innerText = dataGlobal.profil["Kode Affiliate"];
        document.getElementById("linkPromosi").value = dataGlobal.profil["Link Promosi"];

        const tbody = document.getElementById("tabelTransaksi");
        tbody.innerHTML = "";
        
        if(dataGlobal.transaksi.length === 0) {
            tbody.innerHTML = "<tr><td colspan='4' class='text-center py-6 text-gray-500'>Belum ada transaksi pecah telur nih!</td></tr>";
        } else {
            dataGlobal.transaksi.forEach(trx => {
                let baris = `<tr class="border-b hover:bg-gray-50">
                    <td class="px-4 py-3">${trx["Tanggal"] || "-"}</td>
                    <td class="px-4 py-3">${trx["Layanan"] || trx["Pesanan"] || "-"}</td>
                    <td class="px-4 py-3 font-bold text-green-600">Rp ${trx["Komisi"] || "0"}</td>
                    <td class="px-4 py-3"><span class="px-2 py-1 bg-blue-100 text-blue-800 rounded-full text-xs">${trx["Status"] || "Selesai"}</span></td>
                </tr>`;
                tbody.innerHTML += baris;
            });
        }
    }

    if(btnSalin) {
        btnSalin.addEventListener('click', () => {
            const linkInput = document.getElementById("linkPromosi");
            linkInput.select();
            document.execCommand("copy");
            btnSalin.innerText = "Tersalin!";
            setTimeout(() => { btnSalin.innerText = "Salin Link"; }, 2000);
        });
    }

    if(btnCairkan) {
        btnCairkan.addEventListener('click', () => {
            let nominal = prompt("Masukkan nominal komisi yang ingin dicairkan (Minimal Rp 50.000):", "50000");
            if(nominal && !isNaN(nominal) && parseInt(nominal) >= 50000) {
                
                const nama = document.getElementById("namaAfiliator").innerText;
                const kode = document.getElementById("kodeAfiliatorDisplay").innerText;

                btnCairkan.innerText = "Memproses...";

                fetch(URL_APPS_SCRIPT + "?action=tarik&kode=" + kode + "&nama=" + encodeURIComponent(nama) + "&nominal=" + nominal)
                .then(res => res.json())
                .then(resData => {
                    let pesanWA = `Hallo admin saya affiliator ${nama} sudah melakukan penarikan sebesar Rp ${nominal}. Mohon di proses.`;
                    let urlWA = `https://wa.me/${NOMOR_WA_ADMIN}?text=${encodeURIComponent(pesanWA)}`;
                    window.open(urlWA, "_blank");
                    btnCairkan.innerHTML = "💰 Tarik Komisi ke WhatsApp";
                })
                .catch(err => {
                    alert("Gagal memproses pencairan. Coba lagi.");
                    btnCairkan.innerHTML = "💰 Tarik Komisi ke WhatsApp";
                });

            } else if(nominal) {
                alert("Nominal tidak valid atau kurang dari batas minimal pencairan!");
            }
        });
    }
</script>
