---
interface FAQ { q: string; a: string }

interface Props {
  site?: string                // asal domain, tanpa trailing slash
  siteName?: string
  pageUrl?: string             // canonical URL halaman ini
  pageTitle?: string
  description?: string
  image?: string               // absolute URL gambar og
  hasSearch?: boolean
  searchPath?: string          // path untuk SearchAction, ex: /search
  faqItems?: FAQ[]             // [{ q, a }, ...]
}

const {
  site = 'https://jasalike.com/',
  siteName = 'Jasalike',
  pageUrl = 'https://jasalike.com/',
  pageTitle = 'Gunakan jasa like terpercaya untuk meningkatkan engagement dan popularitas akun sosial media Anda',
  description = 'Platform spesialis penyedia jasa Like untuk Instagram, TikTok, Facebook, Twitter (X), YouTube, dan LinkedIn. Tingkatkan interaksi dan kredibilitas instan tanpa butuh password.',
  image = 'https://jasalike.com/hero-jasalike.webp',
  hasSearch = true,
  searchPath = '/search',
  faqItems = [],
}: Props = Astro.props

const origin = site.replace(/\/$/, '')
const canonical = pageUrl.replace(/\/?$/, '/')

const graph: any[] = [
  {
    '@type': 'WebSite',
    '@id': `${origin}/#website`,
    url: `${origin}/`,
    name: siteName,
    publisher: { '@id': `${origin}/#organization` },
    ...(hasSearch
      ? {
          potentialAction: {
            '@type': 'SearchAction',
            target: `${origin}${searchPath}?q={search_term_string}`,
            'query-input': 'required name=search_term_string',
          },
        }
      : {}),
  },
  {
    '@type': 'WebPage',
    '@id': `${origin}/#webpage`,
    url: canonical,
    name: pageTitle,
    description,
    isPartOf: { '@id': `${origin}/#website` },
    primaryImageOfPage: { '@type': 'ImageObject', url: image },
  },
  {
    '@type': 'BreadcrumbList',
    '@id': `${origin}/#breadcrumb`,
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: `${origin}/` },
    ],
  },
]

// FAQ opsional
if (faqItems.length) {
  graph.push({
    '@type': 'FAQPage',
    '@id': `${origin}/#faq`,
    mainEntity: faqItems.map(({ q, a }) => ({
      '@type': 'Question',
      name: q,
      acceptedAnswer: { '@type': 'Answer', text: a },
    })),
  })
}

const jsonld = { '@context': 'https://schema.org', '@graph': graph }
---

<script is:inline type="application/ld+json" set:html={JSON.stringify(jsonld)} />
