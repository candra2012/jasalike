---
// src/components/Testimonials.astro
// Gambar testimoni disimpan di: public/testimonials/
// Gunakan rasio potret (9:16) agar tampilan seperti screenshot Android.
import { Icon } from 'astro-icon/components'

const testimonialImages = [
  '/testimonials/testimoni-komen-yt.png',
  '/testimonials/testimoni-2.webp',
  '/testimonials/testimoni-3.webp',
  '/testimonials/testimoni-4.webp',
  '/testimonials/testimoni-5.webp',
]
---

<section id="testimoni" class="py-20 md:py-24 bg-slate-50 border-t border-slate-200 overflow-hidden">
  <div class="max-w-4xl mx-auto px-6">
    <div class="text-center mb-14">
      <h2 class="text-2xl md:text-3xl lg:text-4xl font-extrabold text-slate-900 mb-4 tracking-tight">
        Dipercaya oleh <span class="text-blue-600">Ratusan Kreator & Bisnis</span>
      </h2>
      <p class="text-sm md:text-base text-slate-600 max-w-2xl mx-auto leading-relaxed">
        Lihat bagaimana layanan optimasi interaksi membantu pelanggan kami tampil lebih meyakinkan di dunia digital.
      </p>
    </div>

    <div
      class="testimonial-slider relative max-w-xs sm:max-w-sm md:max-w-md mx-auto"
      role="region"
      aria-roledescription="carousel"
      aria-label="Testimoni pelanggan"
    >
      {testimonialImages.length > 0 ? (
        <>
          <div class="testimonial-track relative overflow-hidden rounded-2xl border border-slate-100 shadow-lg bg-white aspect-[9/16]">
            {testimonialImages.map((src, i) => (
              <div
                class="testimonial-slide absolute inset-0 opacity-0 transition-opacity duration-700 ease-in-out"
                data-index={i}
                aria-roledescription="slide"
                aria-label={`Slide ${i + 1} dari ${testimonialImages.length}`}
              >

                <img
  src={src}
  alt={`Testimoni pelanggan JasaLike ${i + 1}`}
  width="720"
  height="1280"
  loading={i === 0 ? 'eager' : 'lazy'}
  decoding="async"
  class="w-full h-full object-cover object-center aspect-[9/16]" 
  onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
/>


                <div
                  class="fallback hidden absolute inset-0 flex-col items-center justify-center bg-gradient-to-br from-blue-100 to-slate-200 text-slate-500"
                  aria-hidden="true"
                >
                  <Icon name="lucide:image" class="w-12 h-12 mb-2 opacity-50" />
                  <span class="text-sm">Testimoni {i + 1}</span>
                </div>
              </div>
            ))}
          </div>

          <div class="flex items-center justify-center gap-4 mt-6">
            <button
              type="button"
              class="testimonial-prev w-10 h-10 rounded-full bg-white border border-slate-200 shadow-sm text-slate-700 hover:bg-slate-50 hover:text-blue-600 transition-colors flex items-center justify-center"
              aria-label="Slide sebelumnya"
            >
              <Icon name="lucide:chevron-left" class="w-5 h-5" />
            </button>

            <div class="flex items-center gap-2">
              {testimonialImages.map((_, i) => (
                <button
                  type="button"
                  class="testimonial-dot w-2 h-2 rounded-full bg-slate-300 transition-all duration-300"
                  data-index={i}
                  aria-label={`Ke slide ${i + 1}`}
                />
              ))}
            </div>

            <button
              type="button"
              class="testimonial-next w-10 h-10 rounded-full bg-white border border-slate-200 shadow-sm text-slate-700 hover:bg-slate-50 hover:text-blue-600 transition-colors flex items-center justify-center"
              aria-label="Slide berikutnya"
            >
              <Icon name="lucide:chevron-right" class="w-5 h-5" />
            </button>
          </div>
        </>
      ) : (
        <div class="text-center p-8 rounded-2xl border border-slate-200 bg-white text-slate-500">
          <Icon name="lucide:image" class="w-12 h-12 mx-auto mb-3 opacity-50" />
          <p class="text-sm">Testimoni akan segera ditampilkan.</p>
        </div>
      )}
    </div>
  </div>
</section>

<script>
  const initTestimonialSlider = () => {
    const slider = document.querySelector('.testimonial-slider');
    if (!slider) return;

    const slides = [...slider.querySelectorAll('.testimonial-slide')];
    const dots = [...slider.querySelectorAll('.testimonial-dot')];
    const prevBtn = slider.querySelector('.testimonial-prev');
    const nextBtn = slider.querySelector('.testimonial-next');

    if (slides.length === 0) return;

    let current = 0;
    let timer: ReturnType<typeof setInterval> | null = null;
    const slideDuration = 5000;

    const show = (index: number) => {
      current = (index + slides.length) % slides.length;

      slides.forEach((slide, i) => {
        slide.classList.toggle('opacity-0', i !== current);
        slide.classList.toggle('opacity-100', i === current);
        slide.classList.toggle('z-0', i !== current);
        slide.classList.toggle('z-10', i === current);
      });

      dots.forEach((dot, i) => {
        dot.classList.toggle('bg-slate-300', i !== current);
        dot.classList.toggle('bg-blue-600', i === current);
        dot.classList.toggle('w-2', i !== current);
        dot.classList.toggle('w-5', i === current);
      });
    };

    const next = () => show(current + 1);
    const prev = () => show(current - 1);

    const start = () => {
      stop();
      timer = setInterval(next, slideDuration);
    };

    const stop = () => {
      if (timer) {
        clearInterval(timer);
        timer = null;
      }
    };

    prevBtn?.addEventListener('click', () => {
      prev();
      start();
    });

    nextBtn?.addEventListener('click', () => {
      next();
      start();
    });

    dots.forEach((dot, i) => {
      dot.addEventListener('click', () => {
        show(i);
        start();
      });
    });

    slider.addEventListener('mouseenter', stop);
    slider.addEventListener('mouseleave', start);
    slider.addEventListener('focusin', stop);
    slider.addEventListener('focusout', start);

    show(0);
    start();
  };

  document.addEventListener('astro:page-load', initTestimonialSlider);

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initTestimonialSlider);
  } else {
    initTestimonialSlider();
  }
</script>
