---
const {
judul = "Daftar Menjadi Affiliate",
deskripsi = "Isi formulir berikut untuk bergabung dengan Program Affiliate JasaLike."
} = Astro.props;
---

<section id="form-affiliate" class="py-16 bg-white">
  <div class="container mx-auto px-4">
    <div class="max-w-3xl mx-auto text-center mb-10">
      <h2 class="text-4xl font-bold mb-4">
        {judul}
      </h2>
      <p class="text-slate-600">
        {deskripsi}
      </p>
    </div>

    <div class="max-w-3xl mx-auto bg-slate-50 rounded-2xl shadow-lg p-8">
      <form id="affiliateForm" class="space-y-5">
        <div>
          <label class="block mb-2 font-semibold">Nama Lengkap</label>
          <input type="text" name="nama" required class="w-full border rounded-xl p-3" placeholder="Masukkan nama lengkap" />
        </div>

        <div>
          <label class="block mb-2 font-semibold">Nomor WhatsApp</label>
          <input type="text" name="wa" required class="w-full border rounded-xl p-3" placeholder="08xxxxxxxxxx" />
        </div>

        <div>
          <label class="block mb-2 font-semibold">Email</label>
          <input type="email" name="email" required class="w-full border rounded-xl p-3" placeholder="email@gmail.com" />
        </div>

        <div>
          <label class="block mb-2 font-semibold">Metode Pencairan Komisi</label>
          <select name="metode" required class="w-full border rounded-xl p-3">
            <option value="">Pilih Metode Pencairan</option>
            <option value="BCA">BCA</option>
            <option value="BRI">BRI</option>
            <option value="BNI">BNI</option>
            <option value="Mandiri">Mandiri</option>
            <option value="Dana">Dana</option>
            <option value="GoPay">GoPay</option>
            <option value="OVO">OVO</option>
            <option value="ShopeePay">ShopeePay</option>
          </select>
        </div>

        <div>
          <label class="block mb-2 font-semibold">Nomor Rekening / Nomor E-Wallet</label>
          <input type="text" name="rekening" required class="w-full border rounded-xl p-3" placeholder="Masukkan nomor rekening atau nomor e-wallet" />
        </div>

        <div>
          <label class="block mb-2 font-semibold">Nama Pemilik Rekening / Akun</label>
          <input type="text" name="pemilik" required class="w-full border rounded-xl p-3" placeholder="Nama sesuai rekening atau akun e-wallet" />
        </div>

        <button type="submit" id="submitBtn" class="w-full bg-blue-600 hover:bg-blue-700 text-white font-bold py-4 rounded-xl transition">
          Daftar Affiliate
        </button>
      </form>

      <div id="affiliateResult" class="hidden mt-6 p-4 rounded-xl bg-green-100 text-green-700"></div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById("affiliateForm") as HTMLFormElement;
  const result = document.getElementById("affiliateResult");
  const submitBtn = document.getElementById("submitBtn") as HTMLButtonElement;

  if (form) {
    form.addEventListener("submit", async (e) => {
      e.preventDefault();

      const formData = new FormData(form);
      const data = {
        nama: formData.get("nama"),
        wa: formData.get("wa"),
        email: formData.get("email"),
        metode: formData.get("metode"),
        rekening: formData.get("rekening"),
        pemilik: formData.get("pemilik")
      };

      try {
        // Ubah status tombol saat memproses
        const originalBtnText = submitBtn.innerText;
        submitBtn.innerText = "Mengirim Data...";
        submitBtn.disabled = true;
        submitBtn.classList.add("opacity-70", "cursor-not-allowed");

        const response = await fetch(
          "https://script.google.com/macros/s/AKfycbxvIqS4yPSq_cTtEOxvdYKyS6q_YSTspN2q9l6oA5Dgtyd8mEz3tTOQPt4blSf5q8k/exec",
          {
            method: "POST",
            headers: {
              // Trik text/plain agar Google tidak memblokir jalur CORS
              "Content-Type": "text/plain;charset=utf-8"
            },
            body: JSON.stringify(data)
          }
        );

        const text = await response.text();
        console.log("Response Webhook:", text);

        // Tampilkan pesan sukses
        if (result) {
          result.classList.remove("hidden", "bg-red-100", "text-red-700");
          result.classList.add("bg-green-100", "text-green-700");
          result.innerHTML = `
            <h3 class="font-bold text-xl mb-2">
              Pendaftaran Berhasil 🎉
            </h3>
            <p>Data affiliate berhasil dibuat.</p>
            <p class="mt-2">Spreadsheet affiliate telah diperbarui otomatis.</p>
            <p class="mt-2">Tim JasaLike akan menghubungi Anda untuk mengirim link spreadsheet dan informasi referral.</p>
          `;
        }

        form.reset();

        // Kembalikan tombol seperti semula
        submitBtn.innerText = originalBtnText;
        submitBtn.disabled = false;
        submitBtn.classList.remove("opacity-70", "cursor-not-allowed");

      } catch (error) {
        console.error("Fetch error:", error);

        // Tampilkan pesan error
        if (result) {
          result.classList.remove("hidden", "bg-green-100", "text-green-700");
          result.classList.add("bg-red-100", "text-red-700");
          result.innerHTML = `
            <h3 class="font-bold text-xl mb-2 text-red-600">
              Terjadi Kesalahan
            </h3>
            <p>Sistem gagal mengirim data ke server. Pastikan koneksi internet stabil dan coba beberapa saat lagi.</p>
          `;
        }

        // Kembalikan tombol seperti semula
        submitBtn.innerText = "Daftar Affiliate";
        submitBtn.disabled = false;
        submitBtn.classList.remove("opacity-70", "cursor-not-allowed");
      }
    });
  }
</script>

<style>
#form-affiliate,
#form-affiliate * {
  color: #111827 !important;
}

#form-affiliate input,
#form-affiliate select {
  background: #ffffff !important;
}
</style>

