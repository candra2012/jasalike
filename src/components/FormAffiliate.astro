---

const {
judul = "Daftar Menjadi Affiliate",
deskripsi = "Isi formulir berikut untuk bergabung dengan Program Affiliate JasaLike."
} = Astro.props;
---

<section id="form-affiliate" class="py-16 bg-white">
  <div class="container mx-auto px-4"><div class="max-w-3xl mx-auto text-center mb-10">
  <h2 class="text-4xl font-bold mb-4">
    {judul}
  </h2>

  <p class="text-slate-600">
    {deskripsi}
  </p>
</div>

<div class="max-w-3xl mx-auto bg-slate-50 rounded-2xl shadow-lg p-8">

  <form id="affiliateForm" class="space-y-5">

    <div>
      <label class="block mb-2 font-semibold">
        Nama Lengkap
      </label>

      <input
        type="text"
        name="nama"
        required
        class="w-full border rounded-xl p-3"
        placeholder="Masukkan nama lengkap"
      />
    </div>

    <div>
      <label class="block mb-2 font-semibold">
        Nomor WhatsApp
      </label>

      <input
        type="text"
        name="wa"
        required
        class="w-full border rounded-xl p-3"
        placeholder="08xxxxxxxxxx"
      />
    </div>

    <div>
      <label class="block mb-2 font-semibold">
        Email
      </label>

      <input
        type="email"
        name="email"
        required
        class="w-full border rounded-xl p-3"
        placeholder="email@gmail.com"
      />
    </div>

    <div>
  <label class="block mb-2 font-semibold">
    Metode Pencairan Komisi
  </label><select
name="metode"
required
class="w-full border rounded-xl p-3"

<option value="">Pilih Metode Pencairan</option>
<option value="BCA">BCA</option>
<option value="BRI">BRI</option>
<option value="BNI">BNI</option>
<option value="Mandiri">Mandiri</option>
<option value="Dana">Dana</option>
<option value="GoPay">GoPay</option>
<option value="OVO">OVO</option>
<option value="ShopeePay">ShopeePay</option>

  </select>
</div><div>
  <label class="block mb-2 font-semibold">
    Nomor Rekening / Nomor E-Wallet
  </label><input
type="text"
name="rekening"
required
class="w-full border rounded-xl p-3"
placeholder="Masukkan nomor rekening atau nomor e-wallet"
/>

</div><div>
  <label class="block mb-2 font-semibold">
    Nama Pemilik Rekening / Akun
  </label><input
type="text"
name="pemilik"
required
class="w-full border rounded-xl p-3"
placeholder="Nama sesuai rekening atau akun e-wallet"
/>

</div>

    <button
      type="submit"
      class="w-full bg-blue-600 hover:bg-blue-700 text-white font-bold py-4 rounded-xl transition"
    >
      Daftar Affiliate
    </button>

  </form>

  <div
    id="affiliateResult"
    class="hidden mt-6 p-4 rounded-xl bg-green-100 text-green-700"
  >
  </div>

</div>

  </div>
</section>

<script>
document.addEventListener("DOMContentLoaded", () => {

  const form = document.getElementById("affiliateForm");
  const result = document.getElementById("affiliateResult");

  form.addEventListener("submit", async (e) => {

    e.preventDefault();

    const formData = new FormData(form);

    const data = {
      nama: formData.get("nama"),
      wa: formData.get("wa"),
      email: formData.get("email"),
      metode: formData.get("metode"),
      rekening: formData.get("rekening"),
      pemilik: formData.get("pemilik")
    };

    try {

      const response = await fetch(
        "https://script.google.com/macros/s/AKfycbzfiJ5HgnmmIXTZWlp_H0K_Vque30YJYAyLjL57HVaOKSH9PP3NibO4nJtpbMSgqDuR/exec",
        {
          method: "POST",
          body: JSON.stringify(data)
        }
      );

      const json = await response.json();

      result.classList.remove("hidden");

      result.innerHTML = `
        <h3 class="font-bold text-xl mb-2">
          Pendaftaran Berhasil 🎉
        </h3>

        <p>
          Kode Referral Anda:
          <strong>${json.referral}</strong>
        </p>

        <p class="mt-2 break-all">
          Link Referral:
          <br>
          <strong>${json.link}</strong>
        </p>
      `;

      form.reset();

    } catch (error) {

      alert("Gagal mengirim data.");

      console.error(error);

    }

  });

});
</script>
