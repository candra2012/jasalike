---

const {
judul = "Daftar Menjadi Affiliate",
deskripsi = "Isi formulir berikut untuk bergabung dengan Program Affiliate JasaLike."
} = Astro.props;
---

<section id="form-affiliate" class="py-16 bg-white">
  <div class="container mx-auto px-4"><div class="max-w-3xl mx-auto text-center mb-10">
  <h2 class="text-4xl font-bold mb-4">
    {judul}
  </h2>

  <p class="text-slate-600">
    {deskripsi}
  </p>
</div>

<div class="max-w-3xl mx-auto bg-slate-50 rounded-2xl shadow-lg p-8">

  <form id="affiliateForm" class="space-y-5">

    <div>
      <label class="block mb-2 font-semibold">
        Nama Lengkap
      </label>

      <input
        type="text"
        name="nama"
        required
        class="w-full border rounded-xl p-3"
        placeholder="Masukkan nama lengkap"
      />
    </div>

    <div>
      <label class="block mb-2 font-semibold">
        Nomor WhatsApp
      </label>

      <input
        type="text"
        name="wa"
        required
        class="w-full border rounded-xl p-3"
        placeholder="08xxxxxxxxxx"
      />
    </div>

    <div>
      <label class="block mb-2 font-semibold">
        Email
      </label>

      <input
        type="email"
        name="email"
        required
        class="w-full border rounded-xl p-3"
        placeholder="email@gmail.com"
      />
    </div>

    <div>
      <label class="block mb-2 font-semibold">
        Nama Bank
      </label>

      <input
        type="text"
        name="bank"
        required
        class="w-full border rounded-xl p-3"
        placeholder="BCA / BRI / Mandiri / dll"
      />
    </div>

    <div>
      <label class="block mb-2 font-semibold">
        Nomor Rekening
      </label>

      <input
        type="text"
        name="rekening"
        required
        class="w-full border rounded-xl p-3"
        placeholder="Nomor rekening"
      />
    </div>

    <div>
      <label class="block mb-2 font-semibold">
        Nama Pemilik Rekening
      </label>

      <input
        type="text"
        name="pemilik"
        required
        class="w-full border rounded-xl p-3"
        placeholder="Nama sesuai rekening"
      />
    </div>

    <button
      type="submit"
      class="w-full bg-blue-600 hover:bg-blue-700 text-white font-bold py-4 rounded-xl transition"
    >
      Daftar Affiliate
    </button>

  </form>

  <div
    id="affiliateResult"
    class="hidden mt-6 p-4 rounded-xl bg-green-100 text-green-700"
  >
  </div>

</div>

  </div>
</section><script>
document.addEventListener("DOMContentLoaded", () => {

  const form = document.getElementById("affiliateForm");

  form.addEventListener("submit", async (e) => {

    e.preventDefault();

    alert("Form berhasil diisi. Tahap berikutnya kita sambungkan ke Google Sheet.");

  });

});
</script>
