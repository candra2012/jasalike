---
const {
judul = "Daftar Menjadi Affiliate",
deskripsi = "Isi formulir berikut untuk bergabung dengan Program Affiliate JasaLike."
} = Astro.props;
---

<section id="form-affiliate" class="py-16 bg-white">
  <div class="container mx-auto px-4">
    <div class="max-w-3xl mx-auto text-center mb-10">
      <h2 class="text-4xl font-bold mb-4">
        {judul}
      </h2>
      <p class="text-slate-600">
        {deskripsi}
      </p>
    </div>

    <div class="max-w-3xl mx-auto bg-slate-50 rounded-2xl shadow-lg p-8">
      <form id="affiliateForm" class="space-y-5">
        <div>
          <label class="block mb-2 font-semibold">Nama Lengkap</label>
          <input type="text" name="nama" required class="w-full border rounded-xl p-3" placeholder="Masukkan nama lengkap" />
        </div>

        <div>
          <label class="block mb-2 font-semibold">Nomor WhatsApp</label>
          <input type="text" name="wa" required class="w-full border rounded-xl p-3" placeholder="08xxxxxxxxxx" />
        </div>

        <div>
          <label class="block mb-2 font-semibold">Email</label>
          <input type="email" name="email" required class="w-full border rounded-xl p-3" placeholder="email@gmail.com" />
        </div>

        <div>
          <label class="block mb-2 font-semibold">Metode Pencairan Komisi</label>
          <select name="metode" required class="w-full border rounded-xl p-3">
            <option value="">Pilih Metode Pencairan</option>
            <option value="BCA">BCA</option>
            <option value="BRI">BRI</option>
            <option value="BNI">BNI</option>
            <option value="Mandiri">Mandiri</option>
            <option value="Dana">Dana</option>
            <option value="GoPay">GoPay</option>
            <option value="OVO">OVO</option>
            <option value="ShopeePay">ShopeePay</option>
          </select>
        </div>

        <div>
          <label class="block mb-2 font-semibold">Nomor Rekening / Nomor E-Wallet</label>
          <input type="text" name="rekening" required class="w-full border rounded-xl p-3" placeholder="Masukkan nomor rekening atau nomor e-wallet" />
        </div>

        <div>
          <label class="block mb-2 font-semibold">Nama Pemilik Rekening / Akun</label>
          <input type="text" name="pemilik" required class="w-full border rounded-xl p-3" placeholder="Nama sesuai rekening atau akun e-wallet" />
        </div>

        <button type="submit" id="submitBtn" class="w-full bg-blue-600 hover:bg-blue-700 text-white font-bold py-4 rounded-xl transition">
          Daftar Affiliate
        </button>
      </form>

      <div id="affiliateResult" class="hidden mt-6 p-4 rounded-xl bg-green-100 text-green-700"></div>
    </div>
  </div>
</section>

<script is:inline>
  // Dibungkus 'astro:page-load' agar kebal bug refresh saat pindah halaman
  document.addEventListener('astro:page-load', () => {
    const form = document.getElementById("affiliateForm");
    const result = document.getElementById("affiliateResult");
    const submitBtn = document.getElementById("submitBtn");

    if (form) {
      // Menggunakan form.onsubmit untuk memastikan event tidak jalan dua kali
      form.onsubmit = async (e) => {
        e.preventDefault(); // Ini penangkal refresh-nya

        const formData = new FormData(form);
        const data = {
          nama: formData.get("nama"),
          wa: formData.get("wa"),
          email: formData.get("email"),
          metode: formData.get("metode"),
          rekening: formData.get("rekening"),
          pemilik: formData.get("pemilik")
        };

        try {
          const originalBtnText = submitBtn.innerText;
          submitBtn.innerText = "Membuat Dashboard Anda...";
          submitBtn.disabled = true;
          submitBtn.classList.add("opacity-70", "cursor-not-allowed");

          const response = await fetch(
            "https://script.google.com/macros/s/AKfycbwIdnPFD0ud-vP_BewqMFevWHq6753cBjfS2UhXstiu-kNbu1mp7_pHlDQ-IIwP1rfAPQ/exec", 
            {
              method: "POST",
              headers: {
                "Content-Type": "text/plain;charset=utf-8"
              },
              body: JSON.stringify(data)
            }
          );

          const text = await response.text();
          const resData = JSON.parse(text);

          if (resData.success) {
            if (result) {
              result.classList.remove("hidden", "bg-red-100", "text-red-700");
              result.classList.add("bg-green-50", "text-green-800", "border", "border-green-200");
              result.innerHTML = `
               <div class="text-center mb-5">

<h3 class="font-black text-3xl text-green-600 mb-3">
🎉 Selamat Datang di Program Affiliate JasaLike!
</h3>

<p class="text-slate-700 leading-7">

Halo <b>${data.nama}</b>, terima kasih telah bergabung menjadi Partner Affiliate JasaLike.

<br><br>

Mulai hari ini Anda memiliki kesempatan memperoleh penghasilan tambahan dari setiap transaksi yang berhasil melalui link promosi Anda.

<br><br>

Semua aktivitas affiliate dapat dipantau langsung melalui Dashboard Affiliate, mulai dari transaksi, komisi, saldo hingga pencairan.

<br><br>

Semoga perjalanan Anda bersama JasaLike menjadi awal dari kesuksesan yang lebih besar.

<strong>Kami siap bertumbuh bersama Anda.</strong> 🚀

</p>

</div>
                <div class="bg-white p-4 rounded-xl border border-slate-200 shadow-sm text-left space-y-4">
                  <div>
                    <p class="text-xs font-bold text-slate-500 uppercase tracking-wider mb-1">Kode Affiliate</p>
                    <p class="text-2xl font-black text-blue-600">${resData.referral}</p>
                  </div>

                  <div>
                    <p class="text-xs font-bold text-slate-500 uppercase tracking-wider mb-1">Link Promosi</p>
                    <a href="${resData.link}" target="_blank" class="text-blue-500 hover:text-blue-700 underline break-all font-medium">
                      ${resData.link}
                    </a>
                  </div>

                  <div class="pt-2 border-t border-slate-100">
                    <p class="text-xs font-bold text-slate-500 uppercase tracking-wider mb-2">Laporan Komisi & Data Pembeli</p>
                    <a href="/dashboard" style="color:#ffffff !important;" class="inline-block w-full text-center bg-blue-600 hover:bg-blue-700 font-bold py-3 px-4 rounded-lg transition">
                     Buka Dashboard Affiliate
                    </a>
                    <p class="text-xs text-slate-500 mt-2 text-center">Simpan link data di atas untuk mengecek komisi Anda.</p>
                  </div>
                </div>
              `;
            }
            form.reset();
          } else {
            throw new Error(resData.message || "Gagal memproses data.");
          }

          submitBtn.innerText = originalBtnText;
          submitBtn.disabled = false;
          submitBtn.classList.remove("opacity-70", "cursor-not-allowed");

        } catch (error) {
          if (result) {
            result.classList.remove("hidden", "bg-green-50", "text-green-800");
            result.classList.add("bg-red-100", "text-red-700");
            result.innerHTML = `
              <h3 class="font-bold text-xl mb-2 text-red-600">Kesalahan Server</h3>
              <p>Detail Error: <b>${error.message}</b></p>
            `;
          }
          submitBtn.innerText = "Daftar Affiliate";
          submitBtn.disabled = false;
          submitBtn.classList.remove("opacity-70", "cursor-not-allowed");
        }
      };
    }
  });
</script>

<style>
#form-affiliate,
#form-affiliate * {
  color: #111827 !important;
}

#form-affiliate input,
#form-affiliate select {
  background: #ffffff !important;
}
</style>

