---
// src/components/ApaItuJasaLike.astro
import { Icon } from 'astro-icon/components'

// 👇 Tangkap variabel dari Frontmatter
const { 
  judulUtama, 
  deskripsiUtama, 
  poin1, 
  poin2, 
  poin3, 
  gambarSrc 
} = Astro.props;
---
<section class="py-24 bg-white overflow-hidden border-y border-slate-200">
  <div class="max-w-6xl mx-auto px-6">
    
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      
      <div class="reveal-up">
        <h2 class="text-3xl md:text-4xl font-extrabold text-slate-900 mb-6 leading-tight tracking-tight" set:html={judulUtama}>
        </h2>
        
        <p class="text-slate-600 text-lg leading-relaxed mb-8">
          {deskripsiUtama}
        </p>
        
        <ul class="space-y-5 text-slate-700 font-medium">
          <li class="flex items-start gap-4">
            <div class="bg-blue-100 p-1.5 rounded-full mt-1 shrink-0">
              <Icon name="lucide:check" class="w-5 h-5 text-blue-600" />
            </div>
            <span class="leading-relaxed">{poin1}</span>
          </li>
          <li class="flex items-start gap-4">
            <div class="bg-purple-100 p-1.5 rounded-full mt-1 shrink-0">
              <Icon name="lucide:check" class="w-5 h-5 text-purple-600" />
            </div>
            <span class="leading-relaxed">{poin2}</span>
          </li>
          <li class="flex items-start gap-4">
            <div class="bg-emerald-100 p-1.5 rounded-full mt-1 shrink-0">
              <Icon name="lucide:check" class="w-5 h-5 text-emerald-600" />
            </div>
            <span class="leading-relaxed">{poin3}</span>
          </li>
        </ul>
      </div>

      <div class="reveal-up delay-200 relative w-full">
        <div class="absolute inset-0 bg-blue-600/10 blur-[80px] rounded-full transform scale-90 -z-10"></div>
        
        <div class="bg-slate-50 border border-slate-200 rounded-[2rem] p-4 shadow-xl">
           <img 
             src={gambarSrc} 
             alt="Ilustrasi JasaLike" 
             class="w-full h-auto rounded-3xl object-cover"
           />
        </div>
      </div>

    </div>
  </div>
</section>

