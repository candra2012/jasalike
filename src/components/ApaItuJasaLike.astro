---
// src/components/ApaItuJasaLike.astro
import { Icon } from 'astro-icon/components'

// Tangkap pasokan data dari Frontmatter index.astro
const {
  judulUtama,
  deskripsiUtama,
  k1Judul, k1Teks,
  k2Judul, k2Teks
} = Astro.props;
---
<section class="relative py-20 md:py-24 bg-[#0B1121] overflow-hidden border-t border-slate-800">
  
  <div class="absolute inset-0 bg-[radial-gradient(#ffffff_2px,transparent_2px)] [background-size:32px_32px] z-0 animate-twinkle"></div>
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full max-w-5xl h-[400px] bg-blue-600/10 blur-[120px] rounded-full pointer-events-none z-0"></div>

  <div class="max-w-5xl mx-auto px-6 relative z-10">
    
    <div class="mb-12 max-w-2xl text-left animate-apaitu-item opacity-0 translate-y-6 transform transition-all duration-700 ease-out">
      <h2 class="text-2xl md:text-3xl lg:text-4xl font-extrabold text-white mb-4 tracking-tight" set:html={judulUtama}></h2>
      <p class="text-sm md:text-base text-slate-400 leading-relaxed">
        {deskripsiUtama}
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-8">
      
      <div class="animate-apaitu-item opacity-0 translate-y-6 transform transition-all duration-700 ease-out delay-150 bg-white rounded-2xl p-6 md:p-8 shadow-xl border border-slate-100 hover:-translate-y-1 hover:shadow-2xl transition-all duration-300">
        <h3 class="flex items-center gap-3 text-base md:text-lg font-bold text-slate-900 mb-4">
          <div class="w-10 h-10 rounded-full bg-red-50 flex items-center justify-center shrink-0">
            <Icon name="lucide:heart" class="w-5 h-5 text-red-500" />
          </div>
          {k1Judul}
        </h3>
        <p class="text-xs md:text-sm text-slate-600 leading-relaxed" set:html={k1Teks}></p>
      </div>

      <div class="animate-apaitu-item opacity-0 translate-y-6 transform transition-all duration-700 ease-out delay-300 bg-white rounded-2xl p-6 md:p-8 shadow-xl border border-slate-100 hover:-translate-y-1 hover:shadow-2xl transition-all duration-300">
        <h3 class="flex items-center gap-3 text-base md:text-lg font-bold text-slate-900 mb-4">
          <div class="w-10 h-10 rounded-full bg-blue-50 flex items-center justify-center shrink-0">
            <Icon name="lucide:rocket" class="w-5 h-5 text-blue-600" />
          </div>
          {k2Judul}
        </h3>
        <p class="text-xs md:text-sm text-slate-600 leading-relaxed" set:html={k2Teks}></p>
      </div>

    </div>
  </div>
</section>

<script>
  document.addEventListener("astro:page-load", () => {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.remove('opacity-0', 'translate-y-6');
          entry.target.classList.add('opacity-100', 'translate-y-0');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1 });

    const items = document.querySelectorAll('.animate-apaitu-item');
    items.forEach((item) => observer.observe(item));
  });
</script>

<style>
  @keyframes smooth-twinkle {
    0%, 100% { opacity: 0.12; } /* Paling redup (masih kelihatan samar) */
    50% { opacity: 0.35; }      /* Paling terang (tidak terlalu mencolok) */
  }
  .animate-twinkle {
    /* 👇 Durasinya kita ubah ke 8s atau 10s biar lambat dan super smooth 👇 */
    animation: smooth-twinkle 8s ease-in-out infinite;
  }
</style>


